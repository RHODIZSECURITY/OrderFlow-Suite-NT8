string group_global     = "Session Settings"
timezone = input.string("America/New_York", "Timezone", options=["America/New_York","Europe/London","Asia/Tokyo","Australia/Sydney"], group=group_global)
sessionStartText = input.string("09:30 AM", "Session Start", group=group_global, tooltip="Used by ORB and Market Levels. Example: 09:30 AM")
preMarketStartText = input.string("04:00 AM", "Pre-Market Start", group=group_global, tooltip="Used by Market Levels pre-market high/low. Example: 04:00 AM")
sessionEndText   = input.string("4:00 PM", "Session End", group=group_global, tooltip="Used by Market Levels line end. Example: 4:00 PM")

parseHour12(string timeText) =>
    int colonPos = str.pos(timeText, ":")
    int res = 9
    if not na(colonPos) and colonPos > 0
        string hourText = str.substring(timeText, 0, colonPos)
        float hourNum = str.tonumber(hourText)
        if not na(hourNum)
            res := int(hourNum)
    res

parseMinute12(string timeText) =>
    int colonPos = str.pos(timeText, ":")
    int res = 0
    if not na(colonPos) and str.length(timeText) >= colonPos + 3
        string minuteText = str.substring(timeText, colonPos + 1, colonPos + 3)
        float minuteNum = str.tonumber(minuteText)
        if not na(minuteNum)
            res := int(minuteNum)
    res

parseAmPm(string timeText) =>
    string upperText = str.upper(timeText)
    str.contains(upperText, "PM") ? "PM" : "AM"

int    sessionStartHour12 = parseHour12(sessionStartText)
int    sessionStartMin    = parseMinute12(sessionStartText)
string sessionStartAmPm   = parseAmPm(sessionStartText)
int    preMarketStartHour12 = parseHour12(preMarketStartText)
int    preMarketStartMin    = parseMinute12(preMarketStartText)
string preMarketStartAmPm   = parseAmPm(preMarketStartText)
int    sessionEndHour12   = parseHour12(sessionEndText)
int    sessionEndMin      = parseMinute12(sessionEndText)
string sessionEndAmPm     = parseAmPm(sessionEndText)
int    sessionStartHour   = sessionStartAmPm == "AM" ? (sessionStartHour12 == 12 ? 0 : sessionStartHour12) : (sessionStartHour12 == 12 ? 12 : sessionStartHour12 + 12)
int    preMarketStartHour = preMarketStartAmPm == "AM" ? (preMarketStartHour12 == 12 ? 0 : preMarketStartHour12) : (preMarketStartHour12 == 12 ? 12 : preMarketStartHour12 + 12)
int    sessionEndHour     = sessionEndAmPm == "AM" ? (sessionEndHour12 == 12 ? 0 : sessionEndHour12) : (sessionEndHour12 == 12 ? 12 : sessionEndHour12 + 12)

