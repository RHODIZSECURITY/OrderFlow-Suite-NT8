int liq_history_live        = liq_history
int liq_pools_visible_live  = liq_pools_visible
int liq_pools_store_cap_live = math.max(liq_pools_visible_live * 4, 8)
int liq_void_store_cap_live = 20
int liq_void_visible_live   = liq_void_store_cap_live
int bpr_limit_live         = bpr_limit
int bpr_zone_store_cap_live = math.max(bpr_limit_live * 4, 8)
int bpr_gap_store_cap_live  = 50
int mtf_maxVisibleZones_live = mtf_maxVisibleZones
int mtf_maxVisibleLabels_live = mtf_maxVisibleLabels
int mtf_maxAboveZones_live = math.max(1, int(math.ceil(mtf_maxVisibleZones_live * 0.5)))
int mtf_maxBelowZones_live = math.max(0, mtf_maxVisibleZones_live - mtf_maxAboveZones_live)
int dsr_maxAbove_live = dsr_visibleAbove_input
int dsr_maxBelow_live = dsr_visibleBelow_input
int dsr_visibleTotal_live = dsr_maxAbove_live + dsr_maxBelow_live
int ob_visibleAbove_live = ob_visibleAbove_input
int ob_visibleBelow_live = ob_visibleBelow_input
int ob_visibleTotal_live = ob_visibleAbove_live + ob_visibleBelow_live
var int mtf_totalAboveUsed = 0
var int mtf_totalBelowUsed = 0

//══════════════════════════════════════════════════════════════════════════════
// ORDER BLOCKS ─ EFFECTIVE SETTINGS
//══════════════════════════════════════════════════════════════════════════════
bool   ob_moduleOn      = enableOB and ob_localEnable
int    ob_sensitivity   = ob_sensitivity_input
bool   ob_showInternal  = ob_showInternal_input
int    ob_maxSwing      = ob_maxSwing_live
int    ob_maxInternal   = ob_maxInternal_live
string ob_mitigation    = ob_mitigation_input
bool   ob_volFilter     = ob_volFilter_input
float  ob_volMult       = ob_volMult_input
bool   ob_overlapFilter = ob_overlapFilter_input
string ob_overlapMode = ob_overlapMode_input
float  ob_overlapThresh = ob_overlapThresh_input
string ob_rangeMode     = ob_rangeMode_input
bool   ob_showBreakers  = ob_showBreakers_input
int    ob_breakerMaxVisible = math.max(1, ob_maxSwing + (ob_showInternal ? ob_maxInternal : 0))

//══════════════════════════════════════════════════════════════════════════════
// CORE SERIES CALCULATIONS
//══════════════════════════════════════════════════════════════════════════════
float ema1 = ta.ema(close, ema1_len)
float ema2 = ta.ema(close, ema2_len)
float ema3 = ta.ema(close, ema3_len)
float ema4 = ta.ema(close, ema4_len)

float sma1 = ta.sma(close, sma1_len)
float sma2 = ta.sma(close, sma2_len)
float sma3 = ta.sma(close, sma3_len)
float sma4 = ta.sma(close, sma4_len)
float sma5 = ta.sma(close, sma5_len)

float atrVal = ta.atr(14)
float avgVol = ta.sma(volume, 20)

float vwapSrc = getPriceSrc(vwap_source)
bool  newVwapAnchor = switch vwap_anchor
    "Session" => ta.change(time("D")) != 0
    "Week"    => ta.change(time("W")) != 0
    => ta.change(time("M")) != 0
float vwapValue = ta.vwap(vwapSrc, newVwapAnchor)
float vwapDev = ta.stdev(vwapSrc, 20) * vwap_band_mult
float vwap_upper = vwapValue + vwapDev
float vwap_lower = vwapValue - vwapDev

float basis_bb = ma_bb(bb_src, bb_length, bb_maType)
float dev_bb = bb_mult * ta.stdev(bb_src, bb_length)
float upper_bb = basis_bb + dev_bb
float lower_bb = basis_bb - dev_bb

//══════════════════════════════════════════════════════════════════════════════
// SERIES PLOTS
//══════════════════════════════════════════════════════════════════════════════
plot(enableEMA and ema1_show ? ema1 : na, "EMA 1", color=ema1_color, linewidth=3)
plot(enableEMA and ema2_show ? ema2 : na, "EMA 2", color=ema2_color, linewidth=3)
plot(enableEMA and ema3_show ? ema3 : na, "EMA 3", color=ema3_color, linewidth=3)
plot(enableEMA and ema4_show ? ema4 : na, "EMA 4", color=ema4_color, linewidth=3)

plot(enableSMA and sma1_show ? sma1 : na, "SMA 1", color=sma1_color, linewidth=3)
plot(enableSMA and sma2_show ? sma2 : na, "SMA 2", color=sma2_color, linewidth=3)
plot(enableSMA and sma3_show ? sma3 : na, "SMA 3", color=sma3_color, linewidth=3)
plot(enableSMA and sma4_show ? sma4 : na, "SMA 4", color=sma4_color, linewidth=3)
plot(enableSMA and sma5_show ? sma5 : na, "SMA 5", color=sma5_color, linewidth=3)

plot(enableVWAP and vwap_show ? vwapValue : na, "VWAP", color=vwap_color, linewidth=getLineWeight(vwapWeight))
plot(enableVWAP and vwap_show and show_vwap_bands ? vwap_upper : na, "VWAP Upper", color=vwap_band_color, linewidth=1)
plot(enableVWAP and vwap_show and show_vwap_bands ? vwap_lower : na, "VWAP Lower", color=vwap_band_color, linewidth=1)

plot(enableBB ? basis_bb : na, "BB Basis", color=bb_basis_color)
p_upper = plot(enableBB ? upper_bb : na, "BB Upper", color=bb_upper_color)
p_lower = plot(enableBB ? lower_bb : na, "BB Lower", color=bb_lower_color)
fill(p_upper, p_lower, title="BB Fill", color=enableBB ? bb_fill_color : na)

//══════════════════════════════════════════════════════════════════════════════
// MARKET LEVELS
//══════════════════════════════════════════════════════════════════════════════
if enableLevels
    int lv_time_ctx = time
    int lv_date_key = year(lv_time_ctx, timezone) * 10000 + month(lv_time_ctx, timezone) * 100 + dayofmonth(lv_time_ctx, timezone)
    bool newDay   = ta.change(lv_date_key) != 0

    int yr_lv = year(lv_time_ctx, timezone)
    int mn_lv = month(lv_time_ctx, timezone)
    int dy_lv = dayofmonth(lv_time_ctx, timezone)

    int preMarketStart = timestamp(timezone, yr_lv, mn_lv, dy_lv, preMarketStartHour, preMarketStartMin, 0)
    int preMarketEnd   = timestamp(timezone, yr_lv, mn_lv, dy_lv, sessionStartHour, sessionStartMin, 0)
    bool inPre = time >= preMarketStart and time < preMarketEnd

    if newDay
        preHigh := na
        preLow  := na
        if not na(lPreH)
            line.delete(lPreH)
            lPreH := na
        if not na(lPreL)
            line.delete(lPreL)
            lPreL := na
        if not na(lbPreH)
            label.delete(lbPreH)
            lbPreH := na
        if not na(lbPreL)
            label.delete(lbPreL)
            lbPreL := na

    if inPre
        preHigh := na(preHigh) ? high : math.max(preHigh, high)
        preLow  := na(preLow)  ? low  : math.min(preLow, low)

    [prevHigh, prevLow] = request.security(syminfo.tickerid, "D", [high[1], low[1]], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

    string labelSize = getLabelSize(lblSizeInput)
    int t_start = timestamp(timezone, yr_lv, mn_lv, dy_lv, sessionStartHour, sessionStartMin, 0)
    int pre_t_start = timestamp(timezone, yr_lv, mn_lv, dy_lv, preMarketStartHour, preMarketStartMin, 0)
    int t_end   = timestamp(timezone, yr_lv, mn_lv, dy_lv, sessionEndHour, sessionEndMin, 0)
    int cur_end = time < t_end ? time : t_end
    int day_lbl_x = etiquetaPos == "Start" ? pre_t_start : cur_end
    int pre_lbl_x = etiquetaPos == "Start" ? pre_t_start : cur_end

    if showPDH and not na(prevHigh)
        if na(lPDH)
            lPDH  := line.new(pre_t_start, prevHigh, cur_end, prevHigh, xloc.bar_time, extend.none, color=pdhColor, width=getLineWeight(pdhWeight), style=getLineStyle(pdhStyle))
            lbPDH := label.new(day_lbl_x, prevHigh, pdhText + " " + str.tostring(prevHigh), xloc.bar_time, yloc.price, color=color.new(color.black,100), textcolor=pdhColor, style=label.style_label_left, size=labelSize)
        else
            line.set_xy1(lPDH, pre_t_start, prevHigh)
            line.set_xy2(lPDH, cur_end, prevHigh)
            line.set_color(lPDH, pdhColor)
            line.set_width(lPDH, getLineWeight(pdhWeight))
            line.set_style(lPDH, getLineStyle(pdhStyle))
            label.set_xy(lbPDH, day_lbl_x, prevHigh)
            label.set_text(lbPDH, pdhText + " " + str.tostring(prevHigh))

    if showPDL and not na(prevLow)
        if na(lPDL)
            lPDL  := line.new(pre_t_start, prevLow, cur_end, prevLow, xloc.bar_time, extend.none, color=pdlColor, width=getLineWeight(pdlWeight), style=getLineStyle(pdlStyle))
            lbPDL := label.new(day_lbl_x, prevLow, pdlText + " " + str.tostring(prevLow), xloc.bar_time, yloc.price, color=color.new(color.black,100), textcolor=pdlColor, style=label.style_label_left, size=labelSize)
        else
            line.set_xy1(lPDL, pre_t_start, prevLow)
            line.set_xy2(lPDL, cur_end, prevLow)
            line.set_color(lPDL, pdlColor)
            line.set_width(lPDL, getLineWeight(pdlWeight))
            line.set_style(lPDL, getLineStyle(pdlStyle))
            label.set_xy(lbPDL, day_lbl_x, prevLow)
            label.set_text(lbPDL, pdlText + " " + str.tostring(prevLow))

    if showPreH and not na(preHigh)
        if na(lPreH)
            lPreH  := line.new(pre_t_start, preHigh, cur_end, preHigh, xloc.bar_time, extend.none, color=preHColor, width=getLineWeight(preHWeight), style=getLineStyle(preHStyle))
            lbPreH := label.new(pre_lbl_x, preHigh, preHText + " " + str.tostring(preHigh), xloc.bar_time, yloc.price, color=color.new(color.black,100), textcolor=preHColor, style=label.style_label_left, size=labelSize)
        else
            line.set_xy1(lPreH, pre_t_start, preHigh)
            line.set_xy2(lPreH, cur_end, preHigh)
            line.set_color(lPreH, preHColor)
            line.set_width(lPreH, getLineWeight(preHWeight))
            line.set_style(lPreH, getLineStyle(preHStyle))
            label.set_xy(lbPreH, pre_lbl_x, preHigh)
            label.set_text(lbPreH, preHText + " " + str.tostring(preHigh))

    if showPreL and not na(preLow)
        if na(lPreL)
            lPreL  := line.new(pre_t_start, preLow, cur_end, preLow, xloc.bar_time, extend.none, color=preLColor, width=getLineWeight(preLWeight), style=getLineStyle(preLStyle))
            lbPreL := label.new(pre_lbl_x, preLow, preLText + " " + str.tostring(preLow), xloc.bar_time, yloc.price, color=color.new(color.black,100), textcolor=preLColor, style=label.style_label_left, size=labelSize)
        else
            line.set_xy1(lPreL, pre_t_start, preLow)
            line.set_xy2(lPreL, cur_end, preLow)
            line.set_color(lPreL, preLColor)
            line.set_width(lPreL, getLineWeight(preLWeight))
            line.set_style(lPreL, getLineStyle(preLStyle))
            label.set_xy(lbPreL, pre_lbl_x, preLow)
            label.set_text(lbPreL, preLText + " " + str.tostring(preLow))
else if barstate.islast
    if not na(lPDH)
        line.delete(lPDH)
        lPDH := na
    if not na(lPDL)
        line.delete(lPDL)
        lPDL := na
    if not na(lPreH)
        line.delete(lPreH)
        lPreH := na
    if not na(lPreL)
        line.delete(lPreL)
        lPreL := na
    if not na(lbPDH)
        label.delete(lbPDH)
        lbPDH := na
    if not na(lbPDL)
        label.delete(lbPDL)
        lbPDL := na
    if not na(lbPreH)
        label.delete(lbPreH)
        lbPreH := na
    if not na(lbPreL)
        label.delete(lbPreL)
        lbPreL := na

//══════════════════════════════════════════════════════════════════════════════
// ORB
//══════════════════════════════════════════════════════════════════════════════
drawSignalLabel(int sigTime, string txt, color clr, string shapeStr, string posStr, string sizeStr, int dir, int priority, float yOverride) =>
    int existingIdx = -1
    int existingPriority = -1000
    int metaSz = array.size(orb_signal_times)
    if metaSz > 0
        for i = 0 to metaSz - 1
            if array.get(orb_signal_times, i) == sigTime
                existingIdx := i
                existingPriority := array.get(orb_signal_priorities, i)
                break
    if existingIdx != -1 and existingPriority >= priority
        label(na)
    else
        string defaultStyle = dir == 1 ? label.style_arrowup : label.style_arrowdown
        string lStyle = getLabelShape(shapeStr, defaultStyle)
        string lSz    = getLabelSize(sizeStr)
        float refY = na(yOverride) ? (dir == 1 ? low : high) : yOverride
        label newLbl = na
        if posStr == "abovebar"
            newLbl := label.new(chart.point.from_time(sigTime, refY), txt, xloc.bar_time, yloc.abovebar, color=clr, textcolor=color.white, style=lStyle, size=lSz)
        else if posStr == "belowbar"
            newLbl := label.new(chart.point.from_time(sigTime, refY), txt, xloc.bar_time, yloc.belowbar, color=clr, textcolor=color.white, style=lStyle, size=lSz)
        else if posStr == "high"
            newLbl := label.new(chart.point.from_time(sigTime, na(yOverride) ? high : yOverride), txt, xloc.bar_time, yloc.price, color=clr, textcolor=color.white, style=lStyle, size=lSz)
        else if posStr == "low"
            newLbl := label.new(chart.point.from_time(sigTime, na(yOverride) ? low : yOverride), txt, xloc.bar_time, yloc.price, color=clr, textcolor=color.white, style=lStyle, size=lSz)
        else
            newLbl := label.new(chart.point.from_time(sigTime, refY), txt, xloc.bar_time, yloc.price, color=clr, textcolor=color.white, style=lStyle, size=lSz)
        if existingIdx != -1
            label oldLb = array.get(orb_signal_labels, existingIdx)
            if not na(oldLb)
                label.delete(oldLb)
            array.set(orb_signal_labels, existingIdx, newLbl)
            array.set(orb_signal_priorities, existingIdx, priority)
        else
            array.push(orb_signal_labels, newLbl)
            array.push(orb_signal_times, sigTime)
            array.push(orb_signal_priorities, priority)
        while array.size(orb_signal_labels) > 120
            label trimLb = array.shift(orb_signal_labels)
            if not na(trimLb)
                label.delete(trimLb)
            array.shift(orb_signal_times)
            array.shift(orb_signal_priorities)
        label(na)

drawOrderflowLabel(int sigTime, string txt, color clr, int dir, int priority) =>
    int existingIdx = -1
    int existingPriority = -1000
    int metaSz = array.size(oflow_signal_times)
    if metaSz > 0
        for i = 0 to metaSz - 1
            if array.get(oflow_signal_times, i) == sigTime
                existingIdx := i
                existingPriority := array.get(oflow_signal_priorities, i)
                break
    if existingIdx != -1 and existingPriority >= priority
        label(na)
    else
        string lStyle = dir == 1 ? label.style_arrowup : label.style_arrowdown
        string lSz = getLabelSize(oflow_labelSize)
        float refY = dir == 1 ? low : high
        label newLbl = label.new(chart.point.from_time(sigTime, refY), txt, xloc.bar_time, dir == 1 ? yloc.belowbar : yloc.abovebar, color=clr, textcolor=color.white, style=lStyle, size=lSz)
        if existingIdx != -1
            label oldLb = array.get(oflow_signal_labels, existingIdx)
            if not na(oldLb)
                label.delete(oldLb)
            array.set(oflow_signal_labels, existingIdx, newLbl)
            array.set(oflow_signal_priorities, existingIdx, priority)
        else
            array.push(oflow_signal_labels, newLbl)
            array.push(oflow_signal_times, sigTime)
            array.push(oflow_signal_priorities, priority)
        while array.size(oflow_signal_labels) > 120
            label trimLb = array.shift(oflow_signal_labels)
            if not na(trimLb)
                label.delete(trimLb)
            array.shift(oflow_signal_times)
            array.shift(oflow_signal_priorities)
        label(na)

bool orbBreakAlert     = false
bool orbTrapAlert      = false
bool orbReversalAlert  = false
bool oflowA1LongAlert  = false
bool oflowA1ShortAlert = false
bool oflowA2LongAlert  = false
bool oflowA2ShortAlert = false
bool oflow3ALongAlert  = false
bool oflow3AShortAlert = false

int orb_time_ctx = time
int orb_date_key = year(orb_time_ctx, timezone) * 10000 + month(orb_time_ctx, timezone) * 100 + dayofmonth(orb_time_ctx, timezone)
bool isNewDayORB = ta.change(orb_date_key) != 0
int  orb_regularEndTime        = timestamp(timezone, year(orb_time_ctx), month(orb_time_ctx), dayofmonth(orb_time_ctx), sessionEndHour, sessionEndMin)
bool isRegular   = time >= orb_sessionStartTime and time < orb_regularEndTime

if isNewDayORB
    orb_sessionStartTime      := timestamp(timezone, year(orb_time_ctx), month(orb_time_ctx), dayofmonth(orb_time_ctx), sessionStartHour, sessionStartMin)
    orb_sessionEndTime        := orb_sessionStartTime + rangeDuration * 60 * 1000
    orb_high                  := na
    orb_low                   := na
    orb_attemptUpSeen         := false
    orb_attemptDownSeen       := false
    orb_attemptUpBarIndex     := -1
    orb_attemptDownBarIndex   := -1
    orb_firstCloseOutDir      := 0
    orb_firstCloseOutBarIndex := -1
    if not na(lastFVGbox)
        box.delete(lastFVGbox)
        lastFVGbox := na
    if not na(lastFVGlabel)
        label.delete(lastFVGlabel)
        lastFVGlabel := na
    orb_signalTime := na
    if not na(orb_highRay)
        line.delete(orb_highRay)
        orb_highRay := na
    if not na(orb_lowRay)
        line.delete(orb_lowRay)
        orb_lowRay := na
    if not na(orb_rangeBox)
        box.delete(orb_rangeBox)
        orb_rangeBox := na
    clearLabelArray(orb_signal_labels)
    array.clear(orb_signal_times)
    array.clear(orb_signal_priorities)
    orb_breakLongFired       := false
    orb_breakShortFired      := false
    orb_lastEvalBarTime      := na

bool isInOpeningRange = time >= orb_sessionStartTime and time < orb_sessionEndTime and isRegular
if isInOpeningRange
    if na(orb_high) or high > orb_high
        orb_high := high
    if na(orb_low) or low < orb_low
        orb_low := low

if not isInOpeningRange and time >= orb_sessionEndTime and enableORB
    if not na(orb_high) and not na(orb_low)
        int orbVisualEnd = timestamp(timezone, year(orb_time_ctx), month(orb_time_ctx), dayofmonth(orb_time_ctx), orb_signalCutH, 0, 0)
        int cur_end = time < orbVisualEnd ? time : orbVisualEnd

        if na(orb_highRay)
            orb_highRay := line.new(orb_sessionStartTime, orb_high, cur_end, orb_high, xloc.bar_time, extend.none, color=highColor, width=getLineWeight(highWeight), style=getLineStyle(highLineStyle))
        else
            line.set_xy1(orb_highRay, orb_sessionStartTime, orb_high)
            line.set_xy2(orb_highRay, cur_end, orb_high)

        if na(orb_lowRay)
            orb_lowRay := line.new(orb_sessionStartTime, orb_low, cur_end, orb_low, xloc.bar_time, extend.none, color=lowColor, width=getLineWeight(lowWeight), style=getLineStyle(lowLineStyle))
        else
            line.set_xy1(orb_lowRay, orb_sessionStartTime, orb_low)
            line.set_xy2(orb_lowRay, cur_end, orb_low)

        if showRangeFill
            if na(orb_rangeBox)
                orb_rangeBox := box.new(orb_sessionStartTime, orb_high, cur_end, orb_low, xloc=xloc.bar_time, bgcolor=fillColor, border_width=0)
            else
                box.set_left(orb_rangeBox, orb_sessionStartTime)
                box.set_top(orb_rangeBox, orb_high)
                box.set_right(orb_rangeBox, cur_end)
                box.set_bottom(orb_rangeBox, orb_low)
                box.set_bgcolor(orb_rangeBox, fillColor)
        else
            if not na(orb_rangeBox)
                box.delete(orb_rangeBox)
                orb_rangeBox := na

plot(enableORB and showPriceLabels and not na(orb_high) and barstate.islast ? orb_high : na, "ORB High", color.new(highColor, 95), 1, show_last = 1)
plot(enableORB and showPriceLabels and not na(orb_low) and barstate.islast ? orb_low : na, "ORB Low", color.new(lowColor, 95), 1, show_last = 1)

// Auto-cap: si el gráfico es >= al TF de validación, usar datos del gráfico directamente
string eff_vtf = timeframe.in_seconds() > timeframe.in_seconds(validation_tf) ? timeframe.period : validation_tf
[close_tf, high_tf, low_tf, open_tf, time_tf] = request.security(syminfo.tickerid, eff_vtf, [close, high, low, open, time], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

int  orb_signalBarTime = nz(time_tf[0], time)
int  _orb_cutoffTime = timestamp(timezone, year(orb_signalBarTime, timezone), month(orb_signalBarTime, timezone), dayofmonth(orb_signalBarTime, timezone), orb_signalCutH, 0, 0)
bool _orb_rangeReady = orb_signalBarTime >= orb_sessionEndTime and not na(orb_high) and not na(orb_low)
bool _orb_newEvalBar = orb_signalBarTime != nz(orb_lastEvalBarTime)
bool _orb_inWindow   = _orb_rangeReady and orb_signalBarTime < _orb_cutoffTime and _orb_newEvalBar

bool orbFvgBullNow = low_tf[0] > high_tf[2] + fvg_tolerance
bool orbFvgBearNow = high_tf[0] < low_tf[2] - fvg_tolerance

if enableORB and showDetectedFVG and (orbFvgBullNow or orbFvgBearNow)
    float _vTop   = orbFvgBullNow ? low_tf[0] : low_tf[2]
    float _vBot   = orbFvgBullNow ? high_tf[2] : high_tf[0]
    int   _vStart = time_tf[2]
    int   _vEnd   = time_tf[0]
    if not na(_vTop) and not na(_vBot) and not na(_vStart) and not na(_vEnd)
        if not na(lastFVGbox)
            box.delete(lastFVGbox)
        color _fvgC = orbFvgBullNow ? color.new(color.green, 70) : color.new(color.red, 70)
        lastFVGbox := box.new(_vStart, _vTop, _vEnd, _vBot, xloc=xloc.bar_time, bgcolor=_fvgC, border_color=_fvgC, border_width=0)
        if showDetectedFVG
            if not na(lastFVGlabel)
                label.delete(lastFVGlabel)
            lastFVGlabel := label.new(_vStart + (_vEnd - _vStart) / 2, math.avg(_vTop, _vBot), "FVG", xloc.bar_time, color=color.new(color.white, 0), textcolor=color.white, style=label.style_none, size=size.tiny)
else if enableORB and not showDetectedFVG
    if not na(lastFVGbox)
        box.delete(lastFVGbox)
        lastFVGbox := na
    if not na(lastFVGlabel)
        label.delete(lastFVGlabel)
        lastFVGlabel := na

bool orbCloseOutsideLongNow  = close_tf[0] > orb_high
bool orbCloseOutsideShortNow = close_tf[0] < orb_low
bool orbInsideRangeNow       = close_tf[0] < orb_high and close_tf[0] > orb_low
bool orbBullConfirmNow       = close_tf[0] > open_tf[0]
bool orbBearConfirmNow       = close_tf[0] < open_tf[0]

bool orbStateReady        = orb_firstCloseOutDir == 0
bool orbStateBrokeUp      = orb_firstCloseOutDir == 1
bool orbStateBrokeDown    = orb_firstCloseOutDir == -1
bool orbStateLocked       = math.abs(orb_firstCloseOutDir) == 2

bool orbFirstBreakLongBar  = close_tf[0] > orb_high and close_tf[1] <= orb_high
bool orbFirstBreakShortBar = close_tf[0] < orb_low and close_tf[1] >= orb_low
bool orbBreakLongTrig      = enableORB and enableBreakout and _orb_inWindow and orbStateReady and not orb_breakLongFired and orbFirstBreakLongBar
bool orbBreakShortTrig     = enableORB and enableBreakout and _orb_inWindow and orbStateReady and not orb_breakShortFired and orbFirstBreakShortBar

if enableORB and _orb_inWindow and orbStateReady
    if orbBreakLongTrig
        orb_attemptUpSeen := true
        orb_attemptUpBarIndex := orb_signalBarTime
        orb_firstCloseOutDir := 1
        orb_firstCloseOutBarIndex := orb_signalBarTime
    else if orbBreakShortTrig
        orb_attemptDownSeen := true
        orb_attemptDownBarIndex := orb_signalBarTime
        orb_firstCloseOutDir := -1
        orb_firstCloseOutBarIndex := orb_signalBarTime

if orbBreakLongTrig or orbBreakShortTrig
    orbBreakAlert := true
    int breakDir = orbBreakLongTrig ? 1 : -1
    orb_signalTime := orb_signalBarTime
    if breakDir == 1
        orb_breakLongFired := true
    else
        orb_breakShortFired := true
    drawSignalLabel(orb_signalTime, breakDir == 1 ? breakLongText : breakShortText, breakDir == 1 ? breakColorLong : breakColorShort, breakDir == 1 ? breakLongShape : breakShortShape, breakDir == 1 ? breakLongPosition : breakShortPosition, breakSize, breakDir, 1, na)

bool trapRetestLongTrig  = enableORB and enableTrap and _orb_inWindow and orbStateBrokeUp and orb_signalBarTime > orb_firstCloseOutBarIndex and low_tf[0] <= orb_high and close_tf[0] > orb_high and orbFvgBullNow
bool trapRetestShortTrig = enableORB and enableTrap and _orb_inWindow and orbStateBrokeDown and orb_signalBarTime > orb_firstCloseOutBarIndex and high_tf[0] >= orb_low and close_tf[0] < orb_low and orbFvgBearNow

if trapRetestLongTrig or trapRetestShortTrig
    orbTrapAlert := true
    orb_signalTime := orb_signalBarTime
    orb_firstCloseOutDir := trapRetestLongTrig ? 2 : -2
    drawSignalLabel(orb_signalTime, trapRetestLongTrig ? trapLongText : trapShortText, trapRetestLongTrig ? trapLongColor : trapShortColor, trapRetestLongTrig ? trapLongShape : trapShortShape, trapRetestLongTrig ? trapLongPosition : trapShortPosition, trapRetestLongTrig ? trapLongSize : trapShortSize, trapRetestLongTrig ? 1 : -1, 2, na)

bool orbRevLongTrig  = enableORB and enableReversal and _orb_inWindow and orbStateBrokeDown and orb_signalBarTime > orb_firstCloseOutBarIndex and low_tf[0] <= orb_low and orbInsideRangeNow and orbBullConfirmNow and orbFvgBullNow
bool orbRevShortTrig = enableORB and enableReversal and _orb_inWindow and orbStateBrokeUp and orb_signalBarTime > orb_firstCloseOutBarIndex and high_tf[0] >= orb_high and orbInsideRangeNow and orbBearConfirmNow and orbFvgBearNow

if orbRevLongTrig or orbRevShortTrig
    orbReversalAlert := true
    orb_signalTime := orb_signalBarTime
    int revDir = orbRevLongTrig ? 1 : -1
    orb_firstCloseOutDir := revDir == 1 ? 2 : -2
    drawSignalLabel(orb_signalTime, revDir == 1 ? revLongText : revShortText, revDir == 1 ? revLongColor : revShortColor, revDir == 1 ? revLongShape : revShortShape, revDir == 1 ? revLongPosition : revShortPosition, revDir == 1 ? revLongSize : revShortSize, revDir, 2, na)

if enableORB and _orb_newEvalBar
    orb_lastEvalBarTime := orb_signalBarTime

alertcondition(enableORB and showAlerts and orbBreakAlert, "ORB BREAK", "ORB Break signal")
alertcondition(enableORB and showAlerts and orbTrapAlert, "ORB TRAP", "ORB Trap signal")
alertcondition(enableORB and showAlerts and orbReversalAlert, "ORB REVERSAL", "ORB Reversal signal")

if not enableORB and barstate.islast
    if not na(orb_highRay)
        line.delete(orb_highRay)
        orb_highRay := na
    if not na(orb_lowRay)
        line.delete(orb_lowRay)
        orb_lowRay := na
    if not na(orb_rangeBox)
        box.delete(orb_rangeBox)
        orb_rangeBox := na
    if not na(lastFVGbox)
        box.delete(lastFVGbox)
        lastFVGbox := na
    if not na(lastFVGlabel)
        label.delete(lastFVGlabel)
        lastFVGlabel := na
    clearLabelArray(orb_signal_labels)
    orb_attemptUpSeen := false
    orb_attemptDownSeen := false
    orb_attemptUpBarIndex := -1
    orb_attemptDownBarIndex := -1
    orb_firstCloseOutDir := 0
    orb_firstCloseOutBarIndex := -1

// ORDERFLOW SIGNAL ENGINE
//══════════════════════════════════════════════════════════════════════════════
int oflow_time_ctx = time
int oflow_preStartTime = timestamp(timezone, year(oflow_time_ctx, timezone), month(oflow_time_ctx, timezone), dayofmonth(oflow_time_ctx, timezone), preMarketStartHour, preMarketStartMin)
int oflow_sessionStartTime = timestamp(timezone, year(oflow_time_ctx, timezone), month(oflow_time_ctx, timezone), dayofmonth(oflow_time_ctx, timezone), sessionStartHour, sessionStartMin)
int oflow_sessionEndTime = timestamp(timezone, year(oflow_time_ctx, timezone), month(oflow_time_ctx, timezone), dayofmonth(oflow_time_ctx, timezone), sessionEndHour, sessionEndMin)
bool oflow_inRegular = time >= oflow_sessionStartTime and time < oflow_sessionEndTime
bool oflow_inPremarket = time >= oflow_preStartTime and time < oflow_sessionStartTime
bool oflow_signalSession = oflow_sessionFilter == "Always" ? true : oflow_sessionFilter == "Pre-Market + Regular" ? (oflow_inPremarket or oflow_inRegular) : oflow_inRegular
int oflow_date_key = year(oflow_time_ctx, timezone) * 10000 + month(oflow_time_ctx, timezone) * 100 + dayofmonth(oflow_time_ctx, timezone)
bool oflow_newDay = ta.change(oflow_date_key) != 0

if oflow_newDay
    oflow_avwapNumer := 0.0
    oflow_avwapDenom := 0.0
    oflow_anchoredVWAP := na
    oflow_cumulativeDelta := 0.0
    oflow_bullImbalanceCount := 0
    oflow_bearImbalanceCount := 0
    oflow_tripleAPhaseLong := 0
    oflow_tripleAPhaseShort := 0
    oflow_tripleABarsLong := 0
    oflow_tripleABarsShort := 0

float oflow_rangeSafe = math.max(high - low, syminfo.mintick)
float oflow_bodyBias = math.max(0.0, math.min(1.0, 0.5 + (close - open) / (2.0 * oflow_rangeSafe)))
float oflow_closePos = math.max(0.0, math.min(1.0, (close - low) / oflow_rangeSafe))
float oflow_deltaBuyRatio = oflow_bodyBias * 0.5 + oflow_closePos * 0.5
float oflow_proxyBuyVolume = volume * oflow_deltaBuyRatio
float oflow_proxySellVolume = math.max(volume - oflow_proxyBuyVolume, 0.0)
float oflow_delta = oflow_proxyBuyVolume - oflow_proxySellVolume
float oflow_smoothDelta = ta.sma(oflow_delta, oflow_deltaLookback)
float oflow_absDeltaSma20 = ta.sma(math.abs(oflow_delta), 20)
bool oflow_buyersControl = oflow_smoothDelta > 0 and oflow_smoothDelta > nz(oflow_smoothDelta[1])
bool oflow_sellersControl = oflow_smoothDelta < 0 and oflow_smoothDelta < nz(oflow_smoothDelta[1])
bool oflow_cdImpulseBull = oflow_delta > oflow_absDeltaSma20 * 1.25 or (oflow_delta > 0 and volume > avgVol and close > open)
bool oflow_cdImpulseBear = oflow_delta < -oflow_absDeltaSma20 * 1.25 or (oflow_delta < 0 and volume > avgVol and close < open)

if oflow_signalSession
    oflow_cumulativeDelta += oflow_delta

if oflow_signalSession
    oflow_avwapNumer += hlc3 * volume
    oflow_avwapDenom += volume
    oflow_anchoredVWAP := oflow_avwapDenom > 0 ? oflow_avwapNumer / oflow_avwapDenom : na

float oflow_vwapRef = oflow_useAnchoredVWAP and not na(oflow_anchoredVWAP) ? oflow_anchoredVWAP : vwapValue
bool oflow_nearVWAP = not na(oflow_vwapRef) and math.abs(close - oflow_vwapRef) <= atrVal * oflow_vwapTolAtr
bool oflow_aboveVWAP = not na(oflow_vwapRef) and close > oflow_vwapRef
bool oflow_belowVWAP = not na(oflow_vwapRef) and close < oflow_vwapRef

float oflow_priceMove = safe_div(math.abs(close - open), atrVal)
bool oflow_highVolume = volume > avgVol * oflow_absorbVolMult
bool oflow_smallMove = oflow_priceMove < oflow_absorbPriceThresh
bool oflow_absorption = oflow_highVolume and oflow_smallMove
float oflow_midPrice = math.avg(high, low)
bool oflow_absorptionUp = oflow_absorption and (close > open or (close == open and close > oflow_midPrice) or (close == open and close == oflow_midPrice and close[1] > open[1]))
bool oflow_absorptionDown = oflow_absorption and (close < open or (close == open and close < oflow_midPrice) or (close == open and close == oflow_midPrice and close[1] <= open[1]))

bool oflow_bigBuy = volume > avgVol * oflow_bigTradeMult and close > open
bool oflow_bigSell = volume > avgVol * oflow_bigTradeMult and close < open

float oflow_upperHalf = (high - close) / oflow_rangeSafe
float oflow_lowerHalf = (close - low) / oflow_rangeSafe
bool oflow_bullImbalance = oflow_signalSession and oflow_lowerHalf > oflow_upperHalf * oflow_imbalanceRatio and volume > avgVol * 1.5 and close > open
bool oflow_bearImbalance = oflow_signalSession and oflow_upperHalf > oflow_lowerHalf * oflow_imbalanceRatio and volume > avgVol * 1.5 and close < open

if oflow_bullImbalance
    oflow_bullImbalanceCount += 1
    oflow_bearImbalanceCount := 0
else if oflow_bearImbalance
    oflow_bearImbalanceCount += 1
    oflow_bullImbalanceCount := 0
else
    oflow_bullImbalanceCount := 0
    oflow_bearImbalanceCount := 0

bool oflow_stackedBullImbalance = oflow_bullImbalanceCount >= oflow_stackedMinCount
bool oflow_stackedBearImbalance = oflow_bearImbalanceCount >= oflow_stackedMinCount
float oflow_bodyDom = safe_div(math.abs(close - open), oflow_rangeSafe)
float oflow_rangeSize = ta.highest(high, 10) - ta.lowest(low, 10)
float oflow_avgRange = ta.sma(oflow_rangeSize, 50)
bool oflow_contraction = oflow_rangeSize < oflow_avgRange * 0.6
bool oflow_expansion = oflow_rangeSize > oflow_avgRange * 1.2 and volume > avgVol * 1.5
bool oflow_aggressiveBuy = oflow_expansion and close > open and oflow_buyersControl
bool oflow_aggressiveSell = oflow_expansion and close < open and oflow_sellersControl
bool oflow_tripleAAggrBull = close > open and volume > avgVol * 1.3 and oflow_bodyDom >= 0.40 and (oflow_cdImpulseBull or oflow_bigBuy or oflow_buyersControl or oflow_stackedBullImbalance)
bool oflow_tripleAAggrBear = close < open and volume > avgVol * 1.3 and oflow_bodyDom >= 0.40 and (oflow_cdImpulseBear or oflow_bigSell or oflow_sellersControl or oflow_stackedBearImbalance)
float oflow_atrSma50 = ta.sma(atrVal, 50)
int oflow_timeout = atrVal > oflow_atrSma50 * 1.2 ? 14 : atrVal < oflow_atrSma50 * 0.8 ? 8 : 10

if not oflow_enable
    oflow_tripleAPhaseLong := 0
    oflow_tripleAPhaseShort := 0
    oflow_tripleABarsLong := 0
    oflow_tripleABarsShort := 0
else
    if oflow_absorptionUp and oflow_signalSession and oflow_tripleAPhaseLong < 1
        oflow_tripleAPhaseLong := 1
        oflow_tripleABarsLong := 0
    else if oflow_tripleAPhaseLong == 1 and oflow_contraction
        oflow_tripleAPhaseLong := 2
        oflow_tripleABarsLong := 0
    else if oflow_tripleAPhaseLong == 2 and (oflow_tripleAAggrBull or oflow_aggressiveBuy)
        oflow_tripleAPhaseLong := 3
        oflow_tripleABarsLong := 0
    else if oflow_tripleAPhaseLong == 3
        oflow_tripleAPhaseLong := 0
    else if oflow_tripleAPhaseLong > 0
        oflow_tripleABarsLong += 1
        if oflow_tripleABarsLong > oflow_timeout
            oflow_tripleAPhaseLong := 0
            oflow_tripleABarsLong := 0

    if oflow_absorptionDown and oflow_signalSession and oflow_tripleAPhaseShort < 1
        oflow_tripleAPhaseShort := 1
        oflow_tripleABarsShort := 0
    else if oflow_tripleAPhaseShort == 1 and oflow_contraction
        oflow_tripleAPhaseShort := 2
        oflow_tripleABarsShort := 0
    else if oflow_tripleAPhaseShort == 2 and (oflow_tripleAAggrBear or oflow_aggressiveSell)
        oflow_tripleAPhaseShort := 3
        oflow_tripleABarsShort := 0
    else if oflow_tripleAPhaseShort == 3
        oflow_tripleAPhaseShort := 0
    else if oflow_tripleAPhaseShort > 0
        oflow_tripleABarsShort += 1
        if oflow_tripleABarsShort > oflow_timeout
            oflow_tripleAPhaseShort := 0
            oflow_tripleABarsShort := 0

bool oflowA1Long = oflow_enable and oflow_showPhaseLabels and oflow_signalSession and oflow_tripleAPhaseLong == 1 and nz(oflow_tripleAPhaseLong[1]) != 1
bool oflowA2Long = oflow_enable and oflow_showPhaseLabels and oflow_signalSession and oflow_tripleAPhaseLong == 2 and nz(oflow_tripleAPhaseLong[1]) != 2
bool oflowA3Long = oflow_enable and oflow_showPhaseLabels and oflow_signalSession and oflow_tripleAPhaseLong == 3 and nz(oflow_tripleAPhaseLong[1]) != 3
bool oflowA1Short = oflow_enable and oflow_showPhaseLabels and oflow_signalSession and oflow_tripleAPhaseShort == 1 and nz(oflow_tripleAPhaseShort[1]) != 1
bool oflowA2Short = oflow_enable and oflow_showPhaseLabels and oflow_signalSession and oflow_tripleAPhaseShort == 2 and nz(oflow_tripleAPhaseShort[1]) != 2
bool oflowA3Short = oflow_enable and oflow_showPhaseLabels and oflow_signalSession and oflow_tripleAPhaseShort == 3 and nz(oflow_tripleAPhaseShort[1]) != 3

bool oflow3ALong = oflow_enable and oflow_show3ALabels and oflow_signalSession and oflowA3Long and (oflow_nearVWAP or oflow_aboveVWAP) and (oflow_buyersControl or oflow_cumulativeDelta > nz(oflow_cumulativeDelta[1]))
bool oflow3AShort = oflow_enable and oflow_show3ALabels and oflow_signalSession and oflowA3Short and (oflow_nearVWAP or oflow_belowVWAP) and (oflow_sellersControl or oflow_cumulativeDelta < nz(oflow_cumulativeDelta[1]))
bool oflow3APremiumLong = oflow3ALong and (oflow_stackedBullImbalance or oflow_bigBuy) and oflow_cdImpulseBull
bool oflow3APremiumShort = oflow3AShort and (oflow_stackedBearImbalance or oflow_bigSell) and oflow_cdImpulseBear

oflowA1LongAlert := oflowA1Long
oflowA1ShortAlert := oflowA1Short
oflowA2LongAlert := oflowA2Long
oflowA2ShortAlert := oflowA2Short
oflow3ALongAlert := oflow3ALong
oflow3AShortAlert := oflow3AShort

if oflowA1Long
    drawOrderflowLabel(time, "A1 LONG", color.new(#1b5e20, 0), 1, 1)
if oflowA2Long
    drawOrderflowLabel(time, "A2 LONG", color.new(#2e7d32, 0), 1, 2)
if oflowA3Long
    drawOrderflowLabel(time, "A3 LONG", color.new(#43a047, 0), 1, 3)
if oflowA1Short
    drawOrderflowLabel(time, "A1 SHORT", color.new(#b71c1c, 0), -1, 1)
if oflowA2Short
    drawOrderflowLabel(time, "A2 SHORT", color.new(#c62828, 0), -1, 2)
if oflowA3Short
    drawOrderflowLabel(time, "A3 SHORT", color.new(#e53935, 0), -1, 3)
if oflow3APremiumLong
    drawOrderflowLabel(time + 1, "3A LONG ★★★", color.new(#ffd54f, 0), 1, 4)
else if oflow3ALong
    drawOrderflowLabel(time + 1, "3A LONG ★★", color.new(#26a69a, 0), 1, 4)
if oflow3APremiumShort
    drawOrderflowLabel(time + 1, "3A SHORT ★★★", color.new(#ffb74d, 0), -1, 4)
else if oflow3AShort
    drawOrderflowLabel(time + 1, "3A SHORT ★★", color.new(#ef5350, 0), -1, 4)

alertcondition(oflow_enable and oflow_showAlerts and oflowA1LongAlert, "ORDERFLOW A1 LONG", "Orderflow A1 Long")
alertcondition(oflow_enable and oflow_showAlerts and oflowA1ShortAlert, "ORDERFLOW A1 SHORT", "Orderflow A1 Short")
alertcondition(oflow_enable and oflow_showAlerts and oflowA2LongAlert, "ORDERFLOW A2 LONG", "Orderflow A2 Long")
alertcondition(oflow_enable and oflow_showAlerts and oflowA2ShortAlert, "ORDERFLOW A2 SHORT", "Orderflow A2 Short")
alertcondition(oflow_enable and oflow_showAlerts and oflow3ALongAlert, "ORDERFLOW 3A LONG", "Orderflow 3A Long")
alertcondition(oflow_enable and oflow_showAlerts and oflow3AShortAlert, "ORDERFLOW 3A SHORT", "Orderflow 3A Short")

if not oflow_enable and barstate.islast
    clearLabelArray(oflow_signal_labels)
    array.clear(oflow_signal_times)
    array.clear(oflow_signal_priorities)

// FVG DELTA
//══════════════════════════════════════════════════════════════════════════════
if enableLiquidity and fvg_show
    string _fvg_tf_use = fvg_tf == "" ? timeframe.period : fvg_tf
    [lastClose, lastOpen, lastTime, currHigh, currLow, currTime, last2High, last2Low] = request.security(syminfo.tickerid, _fvg_tf_use, [close[1], open[1], time[1], high, low, time, high[2], low[2]], lookahead=barmerge.lookahead_off)

    bool newTF        = fvg_tf == "" ? true : timeframe.change(_fvg_tf_use)
    int  _tfMs        = timeframe.in_seconds() * 1000
    bool _isGapBar    = (time - time[1]) > _tfMs * 3
    bool bullFVG_base = currLow > last2High and lastClose > last2High and newTF and not _isGapBar
    bool bearFVG_base = currHigh < last2Low and lastClose < last2Low and newTF and not _isGapBar

    int fvg_sz = array.size(fvg_arr_top)
    if fvg_sz > 0
        for i = fvg_sz - 1 to 0
            if not array.get(fvg_arr_mit, i)
                float ft = array.get(fvg_arr_top, i)
                float fb = array.get(fvg_arr_bot, i)
                int   fb2 = array.get(fvg_arr_bias, i)
                bool isMit = fb2 == 1 ? low <= ft : high >= fb
                if isMit
                    array.set(fvg_arr_mit, i, true)
                    if not fvg_showMitigated
                        if i < array.size(fvg_arr_boxes)
                            box b = array.get(fvg_arr_boxes, i)
                            if not na(b)
                                box.delete(b)
                            array.set(fvg_arr_boxes, i, na)
                        if i < array.size(fvg_arr_labels)
                            label l = array.get(fvg_arr_labels, i)
                            if not na(l)
                                label.delete(l)
                            array.set(fvg_arr_labels, i, na)
                    else
                        if i < array.size(fvg_arr_boxes)
                            box b = array.get(fvg_arr_boxes, i)
                            if not na(b)
                                color mitColor = fb2 == 1 ? color.new(fvg_bullColor, 92) : color.new(fvg_bearColor, 92)
                                box.set_bgcolor(b, mitColor)
                                box.set_border_color(b, mitColor)

    if bullFVG_base or bearFVG_base
        float gapHeight   = bullFVG_base ? currLow - last2High : last2Low - currHigh
        float candleBody  = math.abs(lastClose - lastOpen)
        float candleRange = high[1] - low[1]
        float bodyRatio   = candleRange > 0 ? candleBody / candleRange * 100 : 0.0

        bool displacementOK = not (fvg_quality == "Balanced" or fvg_quality == "High Confluence") or bodyRatio >= disp_threshold
        bool sizeOK         = not (fvg_quality == "Balanced" or fvg_quality == "High Confluence") or gapHeight >= atrVal * atr_mult
        bool volumeOK       = not (fvg_quality == "High Confluence") or volume > avgVol * vol_mult

        color  boxColor  = bullFVG_base ? fvg_bullColor : fvg_bearColor
        string labelText = "FVG"

        if use_delta and fvg_quality == "High Confluence"
            [delta_close, delta_open, delta_volume] = request.security(syminfo.tickerid, delta_tf, [close, open, volume], lookahead=barmerge.lookahead_off)
            var float bullVol = 0.0
            var float bearVol = 0.0
            if newTF
                bullVol := 0.0
                bearVol := 0.0
            if not na(delta_close)
                if delta_close > delta_open
                    bullVol += delta_volume
                else
                    bearVol += delta_volume
            if newTF
                float totalVolD = bullVol + bearVol
                if totalVolD > 0
                    float bullPct = bullVol / totalVolD * 100
                    float bearPct = bearVol / totalVolD * 100
                    labelText := "ΔB" + str.tostring(bullPct, "#.#") + "% S" + str.tostring(bearPct, "#.#") + "%"
                    if bullFVG_base
                        boxColor := bullPct < 50 ? color.new(fvg_bullColor, 90) : fvg_bullColor
                        if use_delta_discard and bullPct < 50
                            volumeOK := false
                    if bearFVG_base
                        boxColor := bearPct < 50 ? color.new(fvg_bearColor, 90) : fvg_bearColor
                        if use_delta_discard and bearPct < 50
                            volumeOK := false

        bool bullFVG_ok = bullFVG_base and displacementOK and sizeOK and volumeOK
        bool bearFVG_ok = bearFVG_base and displacementOK and sizeOK and volumeOK

        if (bullFVG_ok or bearFVG_ok) and not na(lastTime)
            float fvg_top_val = bullFVG_ok ? currLow : last2Low
            float fvg_bot_val = bullFVG_ok ? last2High : currHigh
            int   fvg_bias_val = bullFVG_ok ? 1 : -1

            int activeCount = 0
            int oldestIdx = -1
            int fvg_sz2 = array.size(fvg_arr_top)
            if fvg_sz2 > 0
                for i = 0 to fvg_sz2 - 1
                    if not array.get(fvg_arr_mit, i)
                        activeCount += 1
                        oldestIdx := i

            if activeCount >= fvg_eff_maxCount and oldestIdx >= 0
                if oldestIdx < array.size(fvg_arr_boxes)
                    box oldB = array.get(fvg_arr_boxes, oldestIdx)
                    if not na(oldB)
                        box.delete(oldB)
                if oldestIdx < array.size(fvg_arr_labels)
                    label oldL = array.get(fvg_arr_labels, oldestIdx)
                    if not na(oldL)
                        label.delete(oldL)

                array.remove(fvg_arr_top, oldestIdx)
                array.remove(fvg_arr_bot, oldestIdx)
                array.remove(fvg_arr_bias, oldestIdx)
                array.remove(fvg_arr_mit, oldestIdx)
                if oldestIdx < array.size(fvg_arr_boxes)
                    array.remove(fvg_arr_boxes, oldestIdx)
                if oldestIdx < array.size(fvg_arr_labels)
                    array.remove(fvg_arr_labels, oldestIdx)

            int fvg_right = math.max(bar_index, bar_index + fvg_extend)
            box newBox = box.new(bar_index - 1, fvg_top_val, fvg_right, fvg_bot_val, bgcolor=boxColor, border_color=boxColor, border_width=0)
            array.unshift(fvg_arr_top, fvg_top_val)
            array.unshift(fvg_arr_bot, fvg_bot_val)
            array.unshift(fvg_arr_bias, fvg_bias_val)
            array.unshift(fvg_arr_mit, false)
            array.unshift(fvg_arr_boxes, newBox)
            if fvg_show_labels
                int fvg_label_x = bar_index + int(math.floor(fvg_extend * 0.5))
                label newLbl = label.new(fvg_label_x, math.avg(fvg_top_val, fvg_bot_val), labelText, color=color.new(color.white,0), textcolor=color.white, style=label.style_none, size=size.tiny)
                array.unshift(fvg_arr_labels, newLbl)
            else
                array.unshift(fvg_arr_labels, na)
else if barstate.islast
    clearBoxArray(fvg_arr_boxes)
    clearLabelArray(fvg_arr_labels)

//══════════════════════════════════════════════════════════════════════════════
// ORDER BLOCKS
//══════════════════════════════════════════════════════════════════════════════
int _ob_swLen  = ob_sensitivity == 1 ? 3 : ob_sensitivity == 2 ? 5 : ob_sensitivity == 3 ? 8 : ob_sensitivity == 4 ? 13 : 21
int _ob_intLen = 3

float _ob_ph_sw = ta.pivothigh(high, _ob_swLen, _ob_swLen)
float _ob_pl_sw = ta.pivotlow(low, _ob_swLen, _ob_swLen)
float _ob_ph_in = ta.pivothigh(high, _ob_intLen, _ob_intLen)
float _ob_pl_in = ta.pivotlow(low, _ob_intLen, _ob_intLen)

float _ob_avgVol = ta.sma(volume, 20)
float _ob_atr200 = ta.atr(200)

bool _ob_highVolBar = (high - low) >= 2.0 * _ob_atr200
array.push(ob_parsedHighs, _ob_highVolBar ? low : high)
array.push(ob_parsedLows, _ob_highVolBar ? high : low)
array.push(ob_allHighs, high)
array.push(ob_allLows, low)
array.push(ob_allOpens, open)
array.push(ob_allCloses, close)
array.push(ob_allTimes, time)
array.push(ob_allVols, nz(volume, 0.0))

while array.size(ob_allTimes) > ob_arrayCap
    array.shift(ob_parsedHighs)
    array.shift(ob_parsedLows)
    array.shift(ob_allHighs)
    array.shift(ob_allLows)
    array.shift(ob_allOpens)
    array.shift(ob_allCloses)
    array.shift(ob_allTimes)
    array.shift(ob_allVols)
    ob_arrayBaseBar += 1

obZoneFromMode(float candleHigh, float candleLow, float candleOpen, float candleClose, int obBias, string rangeMode) =>
    float zoneTop = candleHigh
    float zoneBot = candleLow
    float bodyTop = math.max(candleOpen, candleClose)
    float bodyBot = math.min(candleOpen, candleClose)

    if rangeMode == "Body Only"
        zoneTop := bodyTop
        zoneBot := bodyBot
    else if rangeMode == "Open to Wick"
        if obBias == 1
            zoneTop := bodyTop
            zoneBot := candleLow
        else
            zoneTop := candleHigh
            zoneBot := bodyBot
    else if rangeMode == "50% Threshold"
        if obBias == 1
            float refinedTop = bodyTop
            float refinedBot = candleLow
            float refinedMid = math.avg(refinedTop, refinedBot)
            zoneTop := refinedTop
            zoneBot := refinedMid
        else
            float refinedTop = candleHigh
            float refinedBot = bodyBot
            float refinedMid = math.avg(refinedTop, refinedBot)
            zoneTop := refinedMid
            zoneBot := refinedBot
    else if rangeMode == "75% Threshold"
        if obBias == 1
            float refinedTop = bodyTop
            float refinedBot = candleLow
            float refinedThr = refinedBot + (refinedTop - refinedBot) * 0.25
            zoneTop := refinedTop
            zoneBot := refinedThr
        else
            float refinedTop = candleHigh
            float refinedBot = bodyBot
            float refinedThr = refinedBot + (refinedTop - refinedBot) * 0.75
            zoneTop := refinedThr
            zoneBot := refinedBot

    float finalTop = math.max(zoneTop, zoneBot)
    float finalBot = math.min(zoneTop, zoneBot)
    float minVisibleWidth = syminfo.mintick * 2.0
    if finalTop - finalBot < minVisibleWidth
        float mid = math.avg(finalTop, finalBot)
        finalTop := mid + minVisibleWidth * 0.5
        finalBot := mid - minVisibleWidth * 0.5
    [finalTop, finalBot]

obFindZoneFromArrays(array<float> parsedHighs, array<float> parsedLows, array<float> allHighs, array<float> allLows, array<float> allOpens, array<float> allCloses, array<int> allTimes, array<float> allVols, int startIdx, int lastSearchIdx, int obBias) =>
    float zoneH = na
    float zoneL = na
    int   zoneT = na
    float zoneVol = 0.0
    int   bestIdx = na

    if lastSearchIdx >= startIdx
        for i = startIdx to lastSearchIdx
            zoneVol += array.get(allVols, i)
            if na(bestIdx)
                bestIdx := i
            else
                float cur  = obBias == -1 ? array.get(parsedHighs, i) : array.get(parsedLows, i)
                float best = obBias == -1 ? array.get(parsedHighs, bestIdx) : array.get(parsedLows, bestIdx)
                if (obBias == -1 and cur > best) or (obBias == 1 and cur < best)
                    bestIdx := i
        if not na(bestIdx)
            float candleHigh  = array.get(allHighs, bestIdx)
            float candleLow   = array.get(allLows, bestIdx)
            float candleOpen  = array.get(allOpens, bestIdx)
            float candleClose = array.get(allCloses, bestIdx)
            [zoneTop, zoneBot] = obZoneFromMode(candleHigh, candleLow, candleOpen, candleClose, obBias, ob_rangeMode_input)
            zoneH := zoneTop
            zoneL := zoneBot
            zoneT := array.get(allTimes, bestIdx)

    [zoneH, zoneL, zoneT, zoneVol]

mtfObSignalsFull(int len) =>
    var array<float> parsedHighs = array.new<float>()
    var array<float> parsedLows  = array.new<float>()
    var array<float> allHighs    = array.new<float>()
    var array<float> allLows     = array.new<float>()
    var array<float> allOpens    = array.new<float>()
    var array<float> allCloses   = array.new<float>()
    var array<int>   allTimes    = array.new<int>()
    var array<float> allVols     = array.new<float>()
    var int arrayBaseBar = 0

    float mtf_avgVol = ta.sma(volume, 20)
    float atr200 = ta.atr(200)
    bool highVolBar = (high - low) >= 2.0 * atr200
    array.push(parsedHighs, highVolBar ? low : high)
    array.push(parsedLows, highVolBar ? high : low)
    array.push(allHighs, high)
    array.push(allLows, low)
    array.push(allOpens, open)
    array.push(allCloses, close)
    array.push(allTimes, time)
    array.push(allVols, nz(volume, 0.0))
    while array.size(allTimes) > 1000
        array.shift(parsedHighs)
        array.shift(parsedLows)
        array.shift(allHighs)
        array.shift(allLows)
        array.shift(allOpens)
        array.shift(allCloses)
        array.shift(allTimes)
        array.shift(allVols)
        arrayBaseBar += 1

    var float swingHigh = na
    var float swingLow = na
    var int swingHighBar = na
    var int swingLowBar = na
    var bool highCrossed = false
    var bool lowCrossed = false

    float ph = ta.pivothigh(high, len, len)
    float pl = ta.pivotlow(low, len, len)

    if not na(ph)
        swingHigh := ph
        swingHighBar := bar_index - len
        highCrossed := false
    if not na(pl)
        swingLow := pl
        swingLowBar := bar_index - len
        lowCrossed := false

    bool crossHigh = ta.crossover(close, nz(swingHigh, 10e10))
    bool crossLow  = ta.crossunder(close, nz(swingLow, -10e10))

    int bullEvt = 0
    float bullTop = na
    float bullBot = na
    int bullTime = na
    float bullVol = na
    if not na(swingHigh) and not highCrossed and crossHigh and not na(swingHighBar)
        highCrossed := true
        int startIdx = math.max(0, swingHighBar - arrayBaseBar)
        int endIdx = array.size(allTimes) - 1
        int lastSearchIdx = endIdx - 1
        [zTop, zBot, zTime, accVol] = obFindZoneFromArrays(parsedHighs, parsedLows, allHighs, allLows, allOpens, allCloses, allTimes, allVols, startIdx, lastSearchIdx, 1)
        bool volOK = not ob_volFilter_input or accVol >= mtf_avgVol * ob_volMult_input
        if not na(zTop) and volOK
            bullEvt := 1
            bullTop := zTop
            bullBot := zBot
            bullTime := zTime
            bullVol := accVol

    int bearEvt = 0
    float bearTop = na
    float bearBot = na
    int bearTime = na
    float bearVol = na
    if not na(swingLow) and not lowCrossed and crossLow and not na(swingLowBar)
        lowCrossed := true
        int startIdx = math.max(0, swingLowBar - arrayBaseBar)
        int endIdx = array.size(allTimes) - 1
        int lastSearchIdx = endIdx - 1
        [zTop, zBot, zTime, accVol] = obFindZoneFromArrays(parsedHighs, parsedLows, allHighs, allLows, allOpens, allCloses, allTimes, allVols, startIdx, lastSearchIdx, -1)
        bool volOK = not ob_volFilter_input or accVol >= mtf_avgVol * ob_volMult_input
        if not na(zTop) and volOK
            bearEvt := 1
            bearTop := zTop
            bearBot := zBot
            bearTime := zTime
            bearVol := accVol

    [bullEvt, bullTop, bullBot, bullTime, bullVol, bearEvt, bearTop, bearBot, bearTime, bearVol]

mtfObBundle(int len) =>
    [bullEvt, bullTop, bullBot, bullTime, bullVol, bearEvt, bearTop, bearBot, bearTime, bearVol] = mtfObSignalsFull(len)
    [bullEvt, bullTop, bullBot, bullTime, bullVol, bearEvt, bearTop, bearBot, bearTime, bearVol, high, low, close, volume]

mtfRemoveSrAt(int idx) =>
    array.remove(mtf_sr_tops, idx)
    array.remove(mtf_sr_bottoms, idx)
    array.remove(mtf_sr_biases, idx)
    array.remove(mtf_sr_times, idx)
    array.remove(mtf_sr_tfSecs, idx)
    array.remove(mtf_sr_tfLabels, idx)
    array.remove(mtf_sr_startBars, idx)
    array.remove(mtf_sr_basePrices, idx)
    array.remove(mtf_sr_isFlips, idx)
    array.remove(mtf_sr_isMitigated, idx)
    array.remove(mtf_sr_isUserHidden, idx)
    array.remove(mtf_sr_mitTimes, idx)
    array.remove(mtf_sr_entries, idx)
    array.remove(mtf_sr_sweeps, idx)
    array.remove(mtf_sr_tradedVolume, idx)

mtfRemoveObAt(int idx) =>
    array.remove(mtf_ob_tops, idx)
    array.remove(mtf_ob_bottoms, idx)
    array.remove(mtf_ob_biases, idx)
    array.remove(mtf_ob_times, idx)
    array.remove(mtf_ob_tfSecs, idx)
    array.remove(mtf_ob_tfLabels, idx)
    array.remove(mtf_ob_vols, idx)

mtfStoreSr(float topV, float botV, float baseV, int biasV, int timeV, int tfSecV, string tfLblV) =>
    if mtfIsValidZone(topV, botV) and not na(timeV) and tfSecV > 0
        bool shouldAdd = true
        int sz = mtfSrSyncedSize()
        if sz > 0
            for i = sz - 1 to 0
                if array.get(mtf_sr_tfSecs, i) == tfSecV and array.get(mtf_sr_biases, i) == biasV and array.get(mtf_sr_times, i) == timeV
                    shouldAdd := false
                    break
                if array.get(mtf_sr_tfSecs, i) == tfSecV and array.get(mtf_sr_biases, i) == biasV and not array.get(mtf_sr_isMitigated, i) and not array.get(mtf_sr_isUserHidden, i)
                    float eTop = array.get(mtf_sr_tops, i)
                    float eBot = array.get(mtf_sr_bottoms, i)
                    bool overlaps = math.max(botV, eBot) < math.min(topV, eTop)
                    if overlaps
                        if dsr_overlapMode_input == "Hide Overlapping (Oldest Precedence)"
                            shouldAdd := false
                            break
                        else if dsr_overlapMode_input == "Hide Overlapping (Youngest Precedence)"
                            array.set(mtf_sr_isUserHidden, i, true)
                        else if dsr_overlapMode_input == "Merge Overlapping"
                            array.set(mtf_sr_tops, i, math.max(eTop, topV))
                            array.set(mtf_sr_bottoms, i, math.min(eBot, botV))
                            shouldAdd := false
                            break
        if shouldAdd
            array.unshift(mtf_sr_tops, topV)
            array.unshift(mtf_sr_bottoms, botV)
            array.unshift(mtf_sr_biases, biasV)
            array.unshift(mtf_sr_times, timeV)
            array.unshift(mtf_sr_tfSecs, tfSecV)
            array.unshift(mtf_sr_tfLabels, tfLblV)
            array.unshift(mtf_sr_startBars, bar_index)
            array.unshift(mtf_sr_basePrices, baseV)
            array.unshift(mtf_sr_isFlips, false)
            array.unshift(mtf_sr_isMitigated, false)
            array.unshift(mtf_sr_isUserHidden, false)
            array.unshift(mtf_sr_mitTimes, 0)
            array.unshift(mtf_sr_entries, 0)
            array.unshift(mtf_sr_sweeps, 0)
            array.unshift(mtf_sr_tradedVolume, 0.0)
        int countTf = 0
        int keepTf = math.max(1, dsr_mtf_history)
        int idx = mtfSrSyncedSize() - 1
        while idx >= 0
            if array.get(mtf_sr_tfSecs, idx) == tfSecV
                countTf += 1
                if countTf > keepTf
                    mtfRemoveSrAt(idx)
            idx -= 1

obStoreShared(array<float> aH, array<float> aL, array<int> aT, array<int> aB, array<float> aV, float h, float l, int t, int bias, float vol, int maxCount, bool overlapFilter, string overlapMode, float overlapThresh) =>
    bool isDuplicate = false
    int sz = array.size(aH)
    if sz > 0
        for i = 0 to sz - 1
            if array.get(aB, i) == bias
                float eH = array.get(aH, i)
                float eL = array.get(aL, i)
                float eV = array.get(aV, i)
                float overlapRatio = obOverlapRatio(h, l, eH, eL)
                bool newInsideOld  = obInside(h, l, eH, eL)
                bool oldInsideNew  = obInside(eH, eL, h, l)

                if overlapFilter and overlapMode != "None" and (overlapRatio > overlapThresh or newInsideOld or oldInsideNew)
                    isDuplicate := true
                    if overlapMode == "Hide Oldest"
                        array.set(aH, i, h)
                        array.set(aL, i, l)
                        array.set(aT, i, t)
                        array.set(aV, i, vol)
                    else if overlapMode == "Merge"
                        float mergedTop = math.max(h, eH)
                        float mergedBot = math.min(l, eL)
                        if mergedTop > mergedBot
                            array.set(aH, i, mergedTop)
                            array.set(aL, i, mergedBot)
                        else
                            bool keepNew = vol > eV or (vol == eV and t >= array.get(aT, i))
                            if keepNew
                                array.set(aH, i, h)
                                array.set(aL, i, l)
                                array.set(aT, i, t)
                                array.set(aV, i, vol)
                        array.set(aT, i, math.min(t, array.get(aT, i)))
                        array.set(aV, i, math.max(vol, eV))
                    break
    if not isDuplicate
        array.unshift(aH, h)
        array.unshift(aL, l)
        array.unshift(aT, t)
        array.unshift(aB, bias)
        array.unshift(aV, vol)
        if array.size(aH) > maxCount
            array.pop(aH)
            array.pop(aL)
            array.pop(aT)
            array.pop(aB)
            array.pop(aV)


mtfStoreOb(float topV, float botV, int biasV, int timeV, int tfSecV, string tfLblV, float volV) =>
    if mtfIsValidZone(topV, botV) and not na(timeV) and tfSecV > 0
        bool exists = false
        int sz = array.size(mtf_ob_times)
        if sz > 0
            for i = 0 to sz - 1
                if array.get(mtf_ob_tfSecs, i) == tfSecV and array.get(mtf_ob_biases, i) == biasV and array.get(mtf_ob_times, i) == timeV
                    exists := true
                    break
        if not exists
            int _szBefore = array.size(mtf_ob_times)
            obStoreShared(mtf_ob_tops, mtf_ob_bottoms, mtf_ob_times, mtf_ob_biases, mtf_ob_vols, topV, botV, timeV, biasV, volV, math.max(1, ob_mtf_history), ob_overlapFilter, ob_overlapMode, ob_overlapThresh)
            int _szAfter = array.size(mtf_ob_times)
            if _szAfter > _szBefore
                array.unshift(mtf_ob_tfSecs, tfSecV)
                array.unshift(mtf_ob_tfLabels, tfLblV)
        int countTf = 0
        int idx = array.size(mtf_ob_times) - 1
        while idx >= 0
            if idx >= array.size(mtf_ob_tfSecs) or idx >= array.size(mtf_ob_tfLabels)
                mtfRemoveObAt(idx)
            else if array.get(mtf_ob_tfSecs, idx) == tfSecV
                countTf += 1
                if countTf > math.max(1, ob_mtf_history)
                    mtfRemoveObAt(idx)
            idx -= 1

dsrZoneEnteredCalc(int biasV, float topV, float botV, float barHigh, float barLow, float barClose) =>
    biasV == 1 ? (barLow <= topV and barClose >= botV) : (barHigh >= botV and barClose <= topV)

dsrZoneSweptCalc(int biasV, float topV, float botV, float barOpen, float barHigh, float barLow, float barClose) =>
    biasV == 1 ? (barLow < botV and math.min(barClose, barOpen) > botV) : (barHigh > topV and math.max(barClose, barOpen) < topV)

dsrZoneBrokenCalc(int biasV, float topV, float botV, float breakBuf, float barClose) =>
    biasV == 1 ? barClose < botV - breakBuf : barClose > topV + breakBuf

dsrFlipZoneInvalidatedCalc(float topV, float botV, float breakBuf, float barClose) =>
    barClose > topV + breakBuf or barClose < botV - breakBuf

dsrFlipSignalLongCalc(float topV, float botV, float barLow, float barClose, float prevClose) =>
    barLow <= topV and barClose > botV and prevClose < botV

dsrFlipSignalShortCalc(float topV, float botV, float barHigh, float barClose, float prevClose) =>
    barHigh >= botV and barClose < topV and prevClose > topV

dsrVisibilityPass(int entriesV, int sweepsV, int ageBarsV, bool isFlipV, bool isMitigatedV, bool showFlipV) =>
    bool meetsBase = entriesV >= dsr_eff_minEntries and sweepsV >= dsr_eff_minSweeps and ageBarsV >= dsr_eff_minDur
    not isMitigatedV and ((isFlipV and showFlipV) or (not isFlipV and meetsBase))

dsrRenderBand(float topV, float btmV, float refPriceV) =>
    float midV = math.avg(topV, btmV)
    float halfV = math.max((topV - btmV) * 0.5 * dsr_visualWidthMult, syminfo.mintick * 0.5)
    [midV + halfV, midV - halfV]

mtfSupportDistance(float topV, float botV, float refPrice) =>
    botV <= refPrice ? math.max(refPrice - topV, 0.0) : 10e10

mtfResistanceDistance(float topV, float botV, float refPrice) =>
    topV >= refPrice ? math.max(botV - refPrice, 0.0) : 10e10

mtfObDistance(int biasV, float topV, float botV, float refPrice) =>
    biasV == 1 ? (botV <= refPrice ? math.max(refPrice - topV, 0.0) : 10e10) : (topV >= refPrice ? math.max(botV - refPrice, 0.0) : 10e10)

localSrSuppressedByHtf(float topV, float botV, bool isSupport) =>
    bool suppressed = false
    bool allowSuppression = mtf_hideNested
    int biasV = isSupport ? 1 : -1
    int localTfSec = timeframe.in_seconds(timeframe.period)
    int sz = mtfSrSyncedSize()
    if allowSuppression and sz > 0
        for j = 0 to sz - 1
            bool sameDirection = array.get(mtf_sr_biases, j) == biasV
            bool higherTf = array.get(mtf_sr_tfSecs, j) > localTfSec
            bool activeHtf = not array.get(mtf_sr_isMitigated, j) and not array.get(mtf_sr_isUserHidden, j)
            if sameDirection and higherTf and activeHtf
                float hTop = array.get(mtf_sr_tops, j)
                float hBot = array.get(mtf_sr_bottoms, j)
                if mtfPriorityMatch(topV, botV, hTop, hBot, mtf_nestedThreshold)
                    suppressed := true
                    break
    suppressed

localObSuppressedByHtf(float topV, float botV, int biasV) =>
    bool suppressed = false
    bool allowSuppression = mtf_hideNested
    int localTfSec = timeframe.in_seconds(timeframe.period)
    int sz = mtfObSyncedSize()
    if allowSuppression and sz > 0
        for j = 0 to sz - 1
            bool sameDirection = array.get(mtf_ob_biases, j) == biasV
            bool higherTf = array.get(mtf_ob_tfSecs, j) > localTfSec
            if sameDirection and higherTf
                float hTop = array.get(mtf_ob_tops, j)
                float hBot = array.get(mtf_ob_bottoms, j)
                if mtfPriorityMatch(topV, botV, hTop, hBot, mtf_nestedThreshold)
                    suppressed := true
                    break
    suppressed

chartTfLabel() =>
    mtfResolvedTfLabel(tfPretty(timeframe.period), timeframe.in_seconds(timeframe.period))

appendTfUnique(string acc, string tfLbl) =>
    string cleanLbl = str.trim(tfLbl)
    string out = acc
    if str.length(cleanLbl) > 0
        string hay = " & " + acc + " & "
        string needle = " & " + cleanLbl + " & "
        if not str.contains(hay, needle)
            out := str.length(acc) > 0 ? acc + " & " + cleanLbl : cleanLbl
    out

dsrConfluenceMatch(float lowTop, float lowBot, float lowBase, float highTop, float highBot, float highBase) =>
    float overlapRatio = mtfZoneOverlapRatio(lowTop, lowBot, highTop, highBot)
    float lowSz = math.max(lowTop - lowBot, syminfo.mintick)
    float highSz = math.max(highTop - highBot, syminfo.mintick)
    float refSz = math.max(math.min(lowSz, highSz), syminfo.mintick)
    float baseGapRatio = math.abs(lowBase - highBase) / refSz
    bool baseAligned = baseGapRatio <= 0.28
    bool shapeAligned = mtfRepresentationMatch(lowTop, lowBot, highTop, highBot, mtf_nestedThreshold)
    bool overlapAligned = overlapRatio >= 0.55
    baseAligned and (shapeAligned or overlapAligned)

dsrCombinedTfListLocal(float topV, float botV, float baseV, int biasV) =>
    string acc = ""
    int localTfSec = timeframe.in_seconds(timeframe.period)
    int sz = mtfSrSyncedSize()
    bool foundHtfMatch = false
    if sz > 0
        for j = 0 to sz - 1
            bool sameDirection = array.get(mtf_sr_biases, j) == biasV
            bool higherTf = array.get(mtf_sr_tfSecs, j) > localTfSec
            bool activeHtf = not array.get(mtf_sr_isMitigated, j) and not array.get(mtf_sr_isUserHidden, j)
            if sameDirection and higherTf and activeHtf
                float hTop = array.get(mtf_sr_tops, j)
                float hBot = array.get(mtf_sr_bottoms, j)
                float hBase = array.get(mtf_sr_basePrices, j)
                if dsrConfluenceMatch(topV, botV, baseV, hTop, hBot, hBase)
                    if not foundHtfMatch
                        acc := appendTfUnique(acc, chartTfLabel())
                        foundHtfMatch := true
                    acc := appendTfUnique(acc, mtfResolvedTfLabel(array.get(mtf_sr_tfLabels, j), array.get(mtf_sr_tfSecs, j)))
    acc

obCombinedTfListLocal(float topV, float botV, int biasV) =>
    string acc = ""
    int localTfSec = timeframe.in_seconds(timeframe.period)
    int sz = mtfObSyncedSize()
    bool foundHtfMatch = false
    if sz > 0
        for j = 0 to sz - 1
            bool sameDirection = array.get(mtf_ob_biases, j) == biasV
            bool higherTf = array.get(mtf_ob_tfSecs, j) > localTfSec
            if sameDirection and higherTf
                float hTop = array.get(mtf_ob_tops, j)
                float hBot = array.get(mtf_ob_bottoms, j)
                float obBreakSrcDown = ob_mitigation == "Close" ? close : low
                float obBreakSrcUp = ob_mitigation == "Close" ? close : high
                bool activeHtf = biasV == 1 ? obBreakSrcDown >= hBot : obBreakSrcUp <= hTop
                if activeHtf and mtfRepresentationMatch(topV, botV, hTop, hBot, mtf_nestedThreshold)
                    if not foundHtfMatch
                        acc := appendTfUnique(acc, chartTfLabel())
                        foundHtfMatch := true
                    acc := appendTfUnique(acc, mtfResolvedTfLabel(array.get(mtf_ob_tfLabels, j), array.get(mtf_ob_tfSecs, j)))
    acc

srLocalVisibleMatch(float topV, float botV, int biasV) =>
    bool matched = false
    int sz = array.size(dsr_visible_tops)
    if sz > 0
        for j = 0 to sz - 1
            if array.get(dsr_visible_biases, j) == biasV
                float lTop = array.get(dsr_visible_tops, j)
                float lBot = array.get(dsr_visible_bottoms, j)
                if dsrConfluenceMatch(topV, botV, math.avg(topV, botV), lTop, lBot, math.avg(lTop, lBot))
                    matched := true
                    break
    matched

obLocalVisibleMatch(float topV, float botV, int biasV) =>
    bool matched = false
    int sz = array.size(ob_visible_tops)
    if sz > 0
        for j = 0 to sz - 1
            if array.get(ob_visible_biases, j) == biasV
                float lTop = array.get(ob_visible_tops, j)
                float lBot = array.get(ob_visible_bottoms, j)
                if mtfRepresentationMatch(topV, botV, lTop, lBot, mtf_nestedThreshold)
                    matched := true
                    break
    matched

mtfUpdateSrForTf(int tfSecV, float tfOpen, float tfHigh, float tfLow, float tfClose, float tfAtr, float tfVolume) =>
    int sz = mtfSrSyncedSize()
    if sz > 0
        for i = 0 to sz - 1
            if array.get(mtf_sr_tfSecs, i) == tfSecV and not array.get(mtf_sr_isUserHidden, i)
                bool isMit = array.get(mtf_sr_isMitigated, i)
                int biasV = array.get(mtf_sr_biases, i)
                float topV = array.get(mtf_sr_tops, i)
                float botV = array.get(mtf_sr_bottoms, i)
                if not isMit
                    bool broken = biasV == 1 ? tfClose < botV : tfClose > topV
                    if broken
                        array.set(mtf_sr_isMitigated, i, true)
                        array.set(mtf_sr_mitTimes, i, time)
                    else
                        if tfHigh >= botV and tfLow <= topV
                            array.set(mtf_sr_tradedVolume, i, array.get(mtf_sr_tradedVolume, i) + tfVolume)
                        bool entered = biasV == 1 ? (tfLow <= topV and tfClose >= botV) : (tfHigh >= botV and tfClose <= topV)
                        if entered
                            array.set(mtf_sr_entries, i, array.get(mtf_sr_entries, i) + 1)
                        bool swept = biasV == 1 ? (tfLow < botV and math.min(tfClose, tfOpen) > botV) : (tfHigh > topV and math.max(tfClose, tfOpen) < topV)
                        if swept
                            array.set(mtf_sr_sweeps, i, array.get(mtf_sr_sweeps, i) + 1)

mtfObBreaksDown(float botV, float srcClose, float srcLow) =>
    (ob_mitigation == "Close" ? srcClose : srcLow) < botV

mtfObBreaksUp(float topV, float srcClose, float srcHigh) =>
    (ob_mitigation == "Close" ? srcClose : srcHigh) > topV

mtfUpdateObForTf(int tfSecV, float tfHigh, float tfLow, float tfClose) =>
    int idx = mtfObSyncedSize() - 1
    while idx >= 0
        if array.get(mtf_ob_tfSecs, idx) == tfSecV
            int biasV = array.get(mtf_ob_biases, idx)
            float topV = array.get(mtf_ob_tops, idx)
            float botV = array.get(mtf_ob_bottoms, idx)
            bool broken = biasV == 1 ? mtfObBreaksDown(botV, tfClose, tfLow) : mtfObBreaksUp(topV, tfClose, tfHigh)
            if broken
                mtfRemoveObAt(idx)
        idx -= 1

mtfCompactSrForTf(int tfSecV) =>
    int countTf = 0
    int keepTf = math.max(1, dsr_mtf_history)
    int idx = mtfSrSyncedSize() - 1
    while idx >= 0
        if array.get(mtf_sr_tfSecs, idx) == tfSecV
            bool hidden = array.get(mtf_sr_isUserHidden, idx)
            bool mitigated = array.get(mtf_sr_isMitigated, idx)
            if hidden
                mtfRemoveSrAt(idx)
            else
                countTf += 1
                if countTf > keepTf and mitigated
                    mtfRemoveSrAt(idx)
        idx -= 1

mtfCompactObForTf(int tfSecV) =>
    int countTf = 0
    int keepTf = math.max(1, ob_mtf_history)
    int idx = mtfObSyncedSize() - 1
    while idx >= 0
        if array.get(mtf_ob_tfSecs, idx) == tfSecV
            countTf += 1
            if countTf > keepTf
                mtfRemoveObAt(idx)
        idx -= 1

mtfNestedStateSr(int idx) =>
    int state = 0
    int sz = mtfSrSyncedSize()
    if idx >= 0 and idx < sz
        float topV = array.get(mtf_sr_tops, idx)
        float botV = array.get(mtf_sr_bottoms, idx)
        int biasV = array.get(mtf_sr_biases, idx)
        int tfSecV = array.get(mtf_sr_tfSecs, idx)
        bool mitigatedV = array.get(mtf_sr_isMitigated, idx)
        bool hiddenV = array.get(mtf_sr_isUserHidden, idx)
        if not mitigatedV and not hiddenV
            for j = 0 to sz - 1
                if j != idx
                    bool sameDirection = array.get(mtf_sr_biases, j) == biasV
                    bool activeOther = not array.get(mtf_sr_isMitigated, j) and not array.get(mtf_sr_isUserHidden, j)
                    if sameDirection and activeOther
                        float oTop = array.get(mtf_sr_tops, j)
                        float oBot = array.get(mtf_sr_bottoms, j)
                        if mtfPriorityMatch(topV, botV, oTop, oBot, mtf_nestedThreshold)
                            int otherTfSec = array.get(mtf_sr_tfSecs, j)
                            if otherTfSec > tfSecV
                                state := 1
                                break
    state

mtfNestedStateOb(int idx) =>
    int state = 0
    int sz = mtfObSyncedSize()
    if idx >= 0 and idx < sz
        float topV = array.get(mtf_ob_tops, idx)
        float botV = array.get(mtf_ob_bottoms, idx)
        int biasV = array.get(mtf_ob_biases, idx)
        int tfSecV = array.get(mtf_ob_tfSecs, idx)
        for j = 0 to sz - 1
            if j != idx
                bool sameDirection = array.get(mtf_ob_biases, j) == biasV
                if sameDirection
                    float oTop = array.get(mtf_ob_tops, j)
                    float oBot = array.get(mtf_ob_bottoms, j)
                    if obMtfNestedHit(topV, botV, oTop, oBot, mtf_nestedThreshold)
                        int otherTfSec = array.get(mtf_ob_tfSecs, j)
                        if otherTfSec > tfSecV
                            state := 1
                            break
    state

mtfInheritedFill(color baseInput, bool isDimmed) =>
    color.new(solidColor(baseInput), int(math.round(isDimmed ? math.min(100.0, color.t(baseInput) + mtf_dimOpacityBoost) : color.t(baseInput))))

mtfInheritedLine(color baseInput, bool isDimmed) =>
    float baseT = color.t(baseInput)
    int lineAlpha = isDimmed ? int(math.min(100.0, math.max(0.0, baseT - 10.0) + mtf_dimOpacityBoost)) : math.max(0, int(baseT) - 10)
    color.new(solidColor(baseInput), lineAlpha)

mtfInheritedBorder(color baseInput, bool isDimmed) =>
    float baseT = color.t(baseInput)
    int borderAlpha = isDimmed ? int(math.min(100.0, baseT + mtf_dimOpacityBoost - 8.0)) : math.max(0, int(baseT) - 8)
    color.new(solidColor(baseInput), borderAlpha)

trimBoxArrayTo(array<box> arr, int keepCount) =>
    while array.size(arr) > keepCount
        box bx = array.pop(arr)
        if not na(bx)
            box.delete(bx)

trimLabelArrayTo(array<label> arr, int keepCount) =>
    while array.size(arr) > keepCount
        label lb = array.pop(arr)
        if not na(lb)
            label.delete(lb)

trimLineArrayTo(array<line> arr, int keepCount) =>
    while array.size(arr) > keepCount
        line ln = array.pop(arr)
        if not na(ln)
            line.delete(ln)


addOB(array<float> aH, array<float> aL, array<int> aT, array<int> aB, array<float> aV, float h, float l, int t, int bias, float vol, int maxCount) =>
    obStoreShared(aH, aL, aT, aB, aV, h, l, t, bias, vol, maxCount, ob_overlapFilter, ob_overlapMode, ob_overlapThresh)

mitigateOBs(array<float> aH, array<float> aL, array<int> aT, array<int> aB, array<float> aV, array<box> aBoxes, array<label> aLabels, array<label> aLeftLabels, string mitMode) =>
    int i = array.size(aH) - 1
    while i >= 0
        int   bias = array.get(aB, i)
        float obH  = array.get(aH, i)
        float obL  = array.get(aL, i)
        int   obT  = array.get(aT, i)
        bool broken = bias == 1 ? (mitMode == "Close" ? close : low) < obL : (mitMode == "Close" ? close : high) > obH
        if broken
            if ob_showBreakers
                array.unshift(ob_bb_highs, obH)
                array.unshift(ob_bb_lows, obL)
                array.unshift(ob_bb_times, obT)
                array.unshift(ob_bb_bias, bias)
                while array.size(ob_bb_highs) > ob_breakerMaxVisible
                    array.pop(ob_bb_highs)
                    array.pop(ob_bb_lows)
                    array.pop(ob_bb_times)
                    array.pop(ob_bb_bias)
            if i < array.size(aBoxes)
                box bx = array.get(aBoxes, i)
                if not na(bx)
                    box.delete(bx)
                array.remove(aBoxes, i)
            if i < array.size(aLabels)
                label lb = array.get(aLabels, i)
                if not na(lb)
                    label.delete(lb)
                array.remove(aLabels, i)
            if i < array.size(aLeftLabels)
                label ll = array.get(aLeftLabels, i)
                if not na(ll)
                    label.delete(ll)
                array.remove(aLeftLabels, i)
            array.remove(aH, i)
            array.remove(aL, i)
            array.remove(aT, i)
            array.remove(aB, i)
            array.remove(aV, i)
        i -= 1


redrawOBs(array<float> aH, array<float> aL, array<int> aT, array<int> aB, array<float> aV, array<box> aBoxes, array<label> aLabels, array<label> aLeftLabels, color bullColor, color bearColor, bool showLbls, float sharedTotalVol, bool hideIfCoveredBySwing = false, int aboveUsedIn = 0, int belowUsedIn = 0) =>
    int aboveUsed = aboveUsedIn
    int belowUsed = belowUsedIn
    int nOBs = array.size(aH)
    array<bool> skipOB = array.new<bool>(nOBs, false)

    if nOBs > 1
        for i = 0 to nOBs - 2
            if not array.get(skipOB, i)
                float iH = array.get(aH, i)
                float iL = array.get(aL, i)
                float iVol = array.get(aV, i)
                for j = i + 1 to nOBs - 1
                    if not array.get(skipOB, j)
                        float jH = array.get(aH, j)
                        float jL = array.get(aL, j)
                        float jVol = array.get(aV, j)
                        float overlapRatio = obOverlapRatio(iH, iL, jH, jL)
                        bool iInsideJ = obInside(iH, iL, jH, jL)
                        bool jInsideI = obInside(jH, jL, iH, iL)
                        if ob_overlapFilter and ob_overlapMode != "None" and (overlapRatio > ob_overlapThresh or iInsideJ or jInsideI)
                            int iT = array.get(aT, i)
                            int jT = array.get(aT, j)
                            if ob_overlapMode == "Merge"
                                float mergedTop = math.max(iH, jH)
                                float mergedBot = math.min(iL, jL)
                                if mergedTop > mergedBot
                                    array.set(aH, i, mergedTop)
                                    array.set(aL, i, mergedBot)
                                else
                                    bool keepIOnFallback = iVol > jVol or (iVol == jVol and iT >= jT)
                                    if not keepIOnFallback
                                        array.set(aH, i, jH)
                                        array.set(aL, i, jL)
                                        array.set(aT, i, jT)
                                        array.set(aV, i, jVol)
                                array.set(aT, i, math.min(iT, jT))
                                array.set(aV, i, math.max(iVol, jVol))
                                array.set(skipOB, j, true)
                            else
                                bool keepI = ob_overlapMode == "Hide Youngest" ? iT <= jT : ob_overlapMode == "Hide Oldest" ? iT >= jT : (iVol > jVol or (iVol == jVol and iT >= jT))
                                if keepI
                                    array.set(skipOB, j, true)
                                else
                                    array.set(skipOB, i, true)
                                break

    string _szOB = ob_labelSize == "Tiny" ? size.tiny : ob_labelSize == "Small" ? size.small : ob_labelSize == "Normal" ? size.normal : size.large
    float totalVol = sharedTotalVol > 0.0 ? sharedTotalVol : 1.0
    int boxUsed = 0
    int rightLabelUsed = 0

    if nOBs > 0
        for i = 0 to nOBs - 1
            if array.get(skipOB, i)
                continue

            int   bias  = array.get(aB, i)
            float obH   = array.get(aH, i)
            float obL   = array.get(aL, i)
            int   obT   = array.get(aT, i)
            float obV   = array.get(aV, i)
            float obMid = math.avg(obH, obL)

            bool coveredBySwing = false
            if hideIfCoveredBySwing and ob_overlapFilter and array.size(ob_sw_highs) > 0
                for s = 0 to array.size(ob_sw_highs) - 1
                    if array.get(ob_sw_bias, s) == bias
                        float swH = array.get(ob_sw_highs, s)
                        float swL = array.get(ob_sw_lows, s)
                        float swV = array.get(ob_sw_vols, s)
                        float overlapSwing = obOverlapRatio(obH, obL, swH, swL)
                        bool insideSwing = obInside(obH, obL, swH, swL)
                        bool swingInside = obInside(swH, swL, obH, obL)
                        if insideSwing or overlapSwing > ob_overlapThresh or (swingInside and swV >= obV)
                            coveredBySwing := true
                            break
            if coveredBySwing
                continue

            bool obIsAbove = obMid >= close
            bool obAllowSide = obIsAbove ? aboveUsed < ob_visibleAbove_live : belowUsed < ob_visibleBelow_live
            if not obAllowSide
                continue

            color fillOB   = bias == 1 ? bullColor : bearColor
            color borderOB = solidColor(fillOB)
            string obTfList = obCombinedTfListLocal(obH, obL, bias)
            string obLabelTxt = str.length(obTfList) > 0 ? "OB [" + obTfList + "]" : "OB"

            if boxUsed >= array.size(aBoxes)
                array.push(aBoxes, box.new(obT, obH, last_bar_time, obL, xloc=xloc.bar_time, extend=extend.right, bgcolor=fillOB, border_color=borderOB, border_width=1, text=showLbls ? obLabelTxt : "", text_color=color.white, text_size=_szOB, text_halign=text.align_left, text_valign=text.align_center))
            box bx = array.get(aBoxes, boxUsed)
            box.set_left(bx, obT)
            box.set_right(bx, last_bar_time)
            box.set_top(bx, obH)
            box.set_bottom(bx, obL)
            box.set_extend(bx, extend.right)
            box.set_bgcolor(bx, fillOB)
            box.set_border_color(bx, borderOB)
            box.set_border_width(bx, 1)
            box.set_text(bx, showLbls ? obLabelTxt : "")
            box.set_text_color(bx, color.white)
            box.set_text_size(bx, _szOB)
            box.set_text_halign(bx, text.align_left)
            box.set_text_valign(bx, text.align_center)
            boxUsed += 1

            if showLbls
                float pct = obV / totalVol * 100.0
                string cTxt = str.tostring(pct, "#.##") + "% (" + fmtVol(obV) + ")"
                if rightLabelUsed >= array.size(aLabels)
                    array.push(aLabels, label.new(last_bar_time, obMid, cTxt, xloc=xloc.bar_time, yloc=yloc.price, style=label.style_label_right, color=color.new(color.black, 100), textcolor=color.white, size=_szOB))
                label lbR = array.get(aLabels, rightLabelUsed)
                label.set_x(lbR, last_bar_time)
                label.set_y(lbR, obMid)
                label.set_text(lbR, cTxt)
                label.set_style(lbR, label.style_label_right)
                label.set_color(lbR, color.new(color.black, 100))
                label.set_textcolor(lbR, color.white)
                label.set_size(lbR, _szOB)
                rightLabelUsed += 1

            array.push(ob_visible_tops, obH)
            array.push(ob_visible_bottoms, obL)
            array.push(ob_visible_biases, bias)
            if obIsAbove
                aboveUsed += 1
            else
                belowUsed += 1

    trimBoxArrayTo(aBoxes, boxUsed)
    trimLabelArrayTo(aLabels, showLbls ? rightLabelUsed : 0)
    trimLabelArrayTo(aLeftLabels, 0)
    [aboveUsed, belowUsed]

redrawBreakers() =>
    clearBoxArray(ob_bb_boxes)
    clearLabelArray(ob_bb_labels)
    string _szBreaker = ob_breakerLabelSize == "Tiny" ? size.tiny : ob_breakerLabelSize == "Small" ? size.small : ob_breakerLabelSize == "Normal" ? size.normal : size.large
    int breakerCount = math.min(array.size(ob_bb_highs), ob_breakerMaxVisible)
    if breakerCount > 0
        for i = 0 to breakerCount - 1
            int bias = array.get(ob_bb_bias, i)
            float bbH = array.get(ob_bb_highs, i)
            float bbL = array.get(ob_bb_lows, i)
            int bbT = array.get(ob_bb_times, i)
            float bbMid = math.avg(bbH, bbL)
            color bkFill = bias == 1 ? ob_breakerBearColor : ob_breakerBullColor
            color bkBorder = solidColor(bkFill)
            box bx = box.new(bbT, bbH, last_bar_time, bbL, xloc=xloc.bar_time, extend=extend.right, bgcolor=bkFill, border_color=bkBorder, border_width=ob_breakerBorderWidth)
            array.push(ob_bb_boxes, bx)
            if ob_breakerShowLabels
                string bkTxt = bias == 1 ? "Breaker ▼" : "Breaker ▲"
                label lbB = label.new(bbT, bbMid, bkTxt, xloc=xloc.bar_time, yloc=yloc.price, style=label.style_label_left, color=color.new(color.black, 100), textcolor=bkBorder, size=_szBreaker)
                array.push(ob_bb_labels, lbB)

var float ob_sw_swingHigh    = na
var float ob_sw_swingLow     = na
var int   ob_sw_swingHighBar = na
var int   ob_sw_swingLowBar  = na
var bool  ob_sw_highCrossed  = false
var bool  ob_sw_lowCrossed   = false

var float ob_in_swingHigh    = na
var float ob_in_swingLow     = na
var int   ob_in_swingHighBar = na
var int   ob_in_swingLowBar  = na
var bool  ob_in_highCrossed  = false
var bool  ob_in_lowCrossed   = false

if not na(_ob_ph_sw)
    ob_sw_swingHigh := _ob_ph_sw
    ob_sw_swingHighBar := bar_index - _ob_swLen
    ob_sw_highCrossed := false
if not na(_ob_pl_sw)
    ob_sw_swingLow := _ob_pl_sw
    ob_sw_swingLowBar := bar_index - _ob_swLen
    ob_sw_lowCrossed := false
if not na(_ob_ph_in)
    ob_in_swingHigh := _ob_ph_in
    ob_in_swingHighBar := bar_index - _ob_intLen
    ob_in_highCrossed := false
if not na(_ob_pl_in)
    ob_in_swingLow := _ob_pl_in
    ob_in_swingLowBar := bar_index - _ob_intLen
    ob_in_lowCrossed := false

bool _ob_sw_crossH = ta.crossover(close, ob_sw_swingHigh)
bool _ob_sw_crossL = ta.crossunder(close, ob_sw_swingLow)
bool _ob_in_crossH = ta.crossover(close, ob_in_swingHigh)
bool _ob_in_crossL = ta.crossunder(close, ob_in_swingLow)

[obSwBullEvt, obSwBullTop, obSwBullBot, obSwBullTime, obSwBullVol, obSwBearEvt, obSwBearTop, obSwBearBot, obSwBearTime, obSwBearVol] = mtfObSignalsFull(_ob_swLen)
[obInBullEvt, obInBullTop, obInBullBot, obInBullTime, obInBullVol, obInBearEvt, obInBearTop, obInBearBot, obInBearTime, obInBearVol] = mtfObSignalsFull(_ob_intLen)

if ob_moduleOn
    if obSwBullEvt == 1 and not na(obSwBullTop)
        addOB(ob_sw_highs, ob_sw_lows, ob_sw_times, ob_sw_bias, ob_sw_vols, obSwBullTop, obSwBullBot, obSwBullTime, 1, obSwBullVol, ob_maxSwing)
    if obSwBearEvt == 1 and not na(obSwBearTop)
        addOB(ob_sw_highs, ob_sw_lows, ob_sw_times, ob_sw_bias, ob_sw_vols, obSwBearTop, obSwBearBot, obSwBearTime, -1, obSwBearVol, ob_maxSwing)

    if ob_showInternal
        if obInBullEvt == 1 and not na(obInBullTop)
            addOB(ob_in_highs, ob_in_lows, ob_in_times, ob_in_bias, ob_in_vols, obInBullTop, obInBullBot, obInBullTime, 1, obInBullVol, ob_maxInternal)
        if obInBearEvt == 1 and not na(obInBearTop)
            addOB(ob_in_highs, ob_in_lows, ob_in_times, ob_in_bias, ob_in_vols, obInBearTop, obInBearBot, obInBearTime, -1, obInBearVol, ob_maxInternal)

    mitigateOBs(ob_sw_highs, ob_sw_lows, ob_sw_times, ob_sw_bias, ob_sw_vols, ob_sw_boxes, ob_sw_labels, ob_sw_left_labels, ob_mitigation)
    if ob_showInternal
        mitigateOBs(ob_in_highs, ob_in_lows, ob_in_times, ob_in_bias, ob_in_vols, ob_in_boxes, ob_in_labels, ob_in_left_labels, ob_mitigation)

if ob_moduleOn and doHeavyRender
    array.clear(ob_visible_tops)
    array.clear(ob_visible_bottoms)
    array.clear(ob_visible_biases)
    ob_visible_above_used := 0
    ob_visible_below_used := 0
    float _sharedVol = 0.0
    for _v in ob_sw_vols
        _sharedVol += nz(_v, 0.0)
    if ob_showInternal
        for _v in ob_in_vols
            _sharedVol += nz(_v, 0.0)
    if _sharedVol <= 0.0
        _sharedVol := 1.0

    [_obAboveAfterSwing, _obBelowAfterSwing] = redrawOBs(ob_sw_highs, ob_sw_lows, ob_sw_times, ob_sw_bias, ob_sw_vols, ob_sw_boxes, ob_sw_labels, ob_sw_left_labels, ob_bullColor, ob_bearColor, ob_showLabels, _sharedVol, false, 0, 0)
    int _obAboveAfterInternal = _obAboveAfterSwing
    int _obBelowAfterInternal = _obBelowAfterSwing
    if ob_showInternal
        [_obAboveInternalTmp, _obBelowInternalTmp] = redrawOBs(ob_in_highs, ob_in_lows, ob_in_times, ob_in_bias, ob_in_vols, ob_in_boxes, ob_in_labels, ob_in_left_labels, ob_bullColor, ob_bearColor, ob_showLabels, _sharedVol, true, _obAboveAfterSwing, _obBelowAfterSwing)
        _obAboveAfterInternal := _obAboveInternalTmp
        _obBelowAfterInternal := _obBelowInternalTmp
    ob_visible_above_used := _obAboveAfterInternal
    ob_visible_below_used := _obBelowAfterInternal
    if ob_showBreakers
        redrawBreakers()
else if barstate.islast
    clearBoxArray(ob_sw_boxes)
    clearLabelArray(ob_sw_labels)
    clearLabelArray(ob_sw_left_labels)
    clearBoxArray(ob_in_boxes)
    clearLabelArray(ob_in_labels)
    clearLabelArray(ob_in_left_labels)
    clearBoxArray(ob_bb_boxes)
    clearLabelArray(ob_bb_labels)

//══════════════════════════════════════════════════════════════════════════════
// Support & Resistance shared MTF signal helpers
int dsrSrSensInt = math.max(1, int(dsr_swingSensitivity_input))

dsrSrSignalBundle(string methodInputV, int sensIntV, float sensFloatV, float zoneDepthMultV, float breakoutBufMultV, int atrPeriodV) =>
    float currentAtrV = ta.atr(atrPeriodV)
    float srPhV = na
    float srPlV = na
    int srPhTimeV = na
    int srPlTimeV = na
    float phPivotV = ta.pivothigh(sensIntV, sensIntV)
    float plPivotV = ta.pivotlow(sensIntV, sensIntV)
    if methodInputV == "Pivots"
        srPhV := phPivotV
        srPlV := plPivotV
        if not na(srPhV)
            srPhTimeV := time[sensIntV]
        if not na(srPlV)
            srPlTimeV := time[sensIntV]
    float donchHighestV = ta.highest(high, sensIntV)
    float donchLowestV = ta.lowest(low, sensIntV)
    var int donchOsV = 0
    var float donchValV = na
    var int donchValTimeV = na
    if methodInputV == "Donchian"
        donchOsV := donchHighestV > donchHighestV[1] ? 1 : donchLowestV < donchLowestV[1] ? -1 : donchOsV
        if donchOsV != donchOsV[1]
            if donchOsV == 1
                srPlV := donchValV
                srPlTimeV := donchValTimeV
                donchValV := high
                donchValTimeV := time
            else
                srPhV := donchValV
                srPhTimeV := donchValTimeV
                donchValV := low
                donchValTimeV := time
        else
            if donchOsV == 1 and high >= nz(donchValV, -1.0e10)
                donchValV := high
                donchValTimeV := time
            else if donchOsV == -1 and low <= nz(donchValV, 1.0e10)
                donchValV := low
                donchValTimeV := time
    float csidHighestV = ta.highest(high, sensIntV)
    float csidLowestV = ta.lowest(low, sensIntV)
    int csidHbarsV = ta.highestbars(high, sensIntV)
    int csidLbarsV = ta.lowestbars(low, sensIntV)
    var int bullCountV = 0
    var int bearCountV = 0
    if methodInputV == "CSID"
        bullCountV := close > open ? bullCountV + 1 : 0
        bearCountV := close < open ? bearCountV + 1 : 0
        if bullCountV == sensIntV
            srPhV := csidHighestV
            srPhTimeV := time[int(math.abs(csidHbarsV))]
        if bearCountV == sensIntV
            srPlV := csidLowestV
            srPlTimeV := time[int(math.abs(csidLbarsV))]
    var float zzHighV = na
    var float zzLowV = na
    var int zzHighTimeV = na
    var int zzLowTimeV = na
    var int zzDirV = 0
    if methodInputV == "ZigZag"
        float devV = (close * sensFloatV) / 100.0
        if zzDirV == 0
            zzHighV := high
            zzLowV := low
            zzHighTimeV := time
            zzLowTimeV := time
            zzDirV := close > open ? 1 : -1
        else if zzDirV == 1
            if high > zzHighV
                zzHighV := high
                zzHighTimeV := time
            else if low < zzHighV - devV
                srPhV := zzHighV
                srPhTimeV := zzHighTimeV
                zzLowV := low
                zzLowTimeV := time
                zzDirV := -1
        else
            if low < zzLowV
                zzLowV := low
                zzLowTimeV := time
            else if high > zzLowV + devV
                srPlV := zzLowV
                srPlTimeV := zzLowTimeV
                zzHighV := high
                zzHighTimeV := time
                zzDirV := 1
    int supEvtV = 0
    float supTopV = na
    float supBotV = na
    float supBaseV = na
    int supTimeOutV = na
    int resEvtV = 0
    float resTopV = na
    float resBotV = na
    float resBaseV = na
    int resTimeOutV = na
    if not na(srPhV) and not na(srPhTimeV)
        resEvtV := 1
        resTopV := srPhV + currentAtrV * breakoutBufMultV
        resBotV := srPhV - currentAtrV * zoneDepthMultV
        resBaseV := srPhV
        resTimeOutV := srPhTimeV
    if not na(srPlV) and not na(srPlTimeV)
        supEvtV := 1
        supTopV := srPlV + currentAtrV * zoneDepthMultV
        supBotV := srPlV - currentAtrV * breakoutBufMultV
        supBaseV := srPlV
        supTimeOutV := srPlTimeV
    [supEvtV, supTopV, supBotV, supBaseV, supTimeOutV, resEvtV, resTopV, resBotV, resBaseV, resTimeOutV, open, high, low, close, volume]

runMtfSrOverlay(int totalAboveUsedIn, int totalBelowUsedIn) =>
    int totalAboveUsed = totalAboveUsedIn
    int totalBelowUsed = totalBelowUsedIn
    // MTF S/R + OB OVERLAY
    //══════════════════════════════════════════════════════════════════════════════
    int chartTfSecMtf = timeframe.in_seconds(timeframe.period)
    bool dsr_useTf1 = dsr_mtf_runtime_enable and mtfTfIsUsable(dsr_mtf_tf1, chartTfSecMtf, mtf_requireHigherTf)
    bool dsr_useTf2 = dsr_mtf_runtime_enable and mtfTfIsUsable(dsr_mtf_tf2, chartTfSecMtf, mtf_requireHigherTf) and (not mtf_ignoreDuplicateTfs or not mtfTfIsDuplicate(dsr_mtf_tf2, dsr_mtf_tf1, "", "", ""))
    bool dsr_useTf3 = dsr_mtf_runtime_enable and mtfTfIsUsable(dsr_mtf_tf3, chartTfSecMtf, mtf_requireHigherTf) and (not mtf_ignoreDuplicateTfs or not mtfTfIsDuplicate(dsr_mtf_tf3, dsr_mtf_tf1, dsr_mtf_tf2, "", ""))
    bool dsr_anyTf = dsr_useTf1 or dsr_useTf2 or dsr_useTf3

    int dsr_tfSec1 = timeframe.in_seconds(dsr_mtf_tf1)
    int dsr_tfSec2 = timeframe.in_seconds(dsr_mtf_tf2)
    int dsr_tfSec3 = timeframe.in_seconds(dsr_mtf_tf3)
    string dsr_tfLbl1 = tfPretty(dsr_mtf_tf1)
    string dsr_tfLbl2 = tfPretty(dsr_mtf_tf2)
    string dsr_tfLbl3 = tfPretty(dsr_mtf_tf3)
    string dsr_tfReq1 = str.length(dsr_mtf_tf1) > 0 ? dsr_mtf_tf1 : timeframe.period
    string dsr_tfReq2 = str.length(dsr_mtf_tf2) > 0 ? dsr_mtf_tf2 : timeframe.period
    string dsr_tfReq3 = str.length(dsr_mtf_tf3) > 0 ? dsr_mtf_tf3 : timeframe.period

    [supEvt1, supTop1, supBot1, supBase1, supTime1, resEvt1, resTop1, resBot1, resBase1, resTime1, dsr_o1, dsr_h1, dsr_l1, dsr_c1, dsr_v1] = request.security(syminfo.tickerid, dsr_tfReq1, dsrSrSignalBundle(dsr_detectionMethod_input, dsrSrSensInt, dsr_swingSensitivity_input, dsr_zoneDepth_input, dsr_sr_breakoutBuffer_input, int(dsr_sr_atrPeriod_input)), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
    [supEvt2, supTop2, supBot2, supBase2, supTime2, resEvt2, resTop2, resBot2, resBase2, resTime2, dsr_o2, dsr_h2, dsr_l2, dsr_c2, dsr_v2] = request.security(syminfo.tickerid, dsr_tfReq2, dsrSrSignalBundle(dsr_detectionMethod_input, dsrSrSensInt, dsr_swingSensitivity_input, dsr_zoneDepth_input, dsr_sr_breakoutBuffer_input, int(dsr_sr_atrPeriod_input)), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
    [supEvt3, supTop3, supBot3, supBase3, supTime3, resEvt3, resTop3, resBot3, resBase3, resTime3, dsr_o3, dsr_h3, dsr_l3, dsr_c3, dsr_v3] = request.security(syminfo.tickerid, dsr_tfReq3, dsrSrSignalBundle(dsr_detectionMethod_input, dsrSrSensInt, dsr_swingSensitivity_input, dsr_zoneDepth_input, dsr_sr_breakoutBuffer_input, int(dsr_sr_atrPeriod_input)), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

    if dsr_mtf_runtime_enable and dsr_anyTf
        if dsr_useTf1
            if supEvt1 == 1
                mtfStoreSr(supTop1, supBot1, supBase1, 1, supTime1, dsr_tfSec1, dsr_tfLbl1)
            if resEvt1 == 1
                mtfStoreSr(resTop1, resBot1, resBase1, -1, resTime1, dsr_tfSec1, dsr_tfLbl1)
            mtfUpdateSrForTf(dsr_tfSec1, dsr_o1, dsr_h1, dsr_l1, dsr_c1, 0.0, dsr_v1)
        if dsr_useTf2
            if supEvt2 == 1
                mtfStoreSr(supTop2, supBot2, supBase2, 1, supTime2, dsr_tfSec2, dsr_tfLbl2)
            if resEvt2 == 1
                mtfStoreSr(resTop2, resBot2, resBase2, -1, resTime2, dsr_tfSec2, dsr_tfLbl2)
            mtfUpdateSrForTf(dsr_tfSec2, dsr_o2, dsr_h2, dsr_l2, dsr_c2, 0.0, dsr_v2)
        if dsr_useTf3
            if supEvt3 == 1
                mtfStoreSr(supTop3, supBot3, supBase3, 1, supTime3, dsr_tfSec3, dsr_tfLbl3)
            if resEvt3 == 1
                mtfStoreSr(resTop3, resBot3, resBase3, -1, resTime3, dsr_tfSec3, dsr_tfLbl3)
            mtfUpdateSrForTf(dsr_tfSec3, dsr_o3, dsr_h3, dsr_l3, dsr_c3, 0.0, dsr_v3)
        if doHeavyRender and not dsr_sr_engine_enabled
            if dsr_useTf1
                mtfCompactSrForTf(dsr_tfSec1)
            if dsr_useTf2
                mtfCompactSrForTf(dsr_tfSec2)
            if dsr_useTf3
                mtfCompactSrForTf(dsr_tfSec3)
    else if barstate.islast
        array.clear(mtf_sr_tops)
        array.clear(mtf_sr_bottoms)
        array.clear(mtf_sr_biases)
        array.clear(mtf_sr_times)
        array.clear(mtf_sr_tfSecs)
        array.clear(mtf_sr_tfLabels)
        array.clear(mtf_sr_startBars)
        array.clear(mtf_sr_basePrices)
        array.clear(mtf_sr_isFlips)
        array.clear(mtf_sr_isMitigated)
        array.clear(mtf_sr_isUserHidden)
        array.clear(mtf_sr_mitTimes)
        array.clear(mtf_sr_entries)
        array.clear(mtf_sr_sweeps)
        array.clear(mtf_sr_tradedVolume)
        clearBoxArray(mtf_sr_boxes)
        clearLabelArray(mtf_sr_labels)
        clearLineArray(mtf_sr_lines)

    if doHeavyRender
        int srBoxUsed = 0
        int srLineUsed = 0
        int srLabelUsed = 0
        bool srZoneMode = dsr_eff_display == "Zones"
        if not (dsr_mtf_runtime_enable and dsr_anyTf)
            trimBoxArrayTo(mtf_sr_boxes, 0)
            trimLineArrayTo(mtf_sr_lines, 0)
            trimLabelArrayTo(mtf_sr_labels, 0)
        else
            int srSz = mtfSrSyncedSize()
            string _szSRMtf = dsr_labelSize == "Tiny" ? size.tiny : dsr_labelSize == "Small" ? size.small : dsr_labelSize == "Normal" ? size.normal : size.large
            array<int> selectedSr = array.new_int()
            array<float> selectedSrDist = array.new_float()
            if srSz > 0
                for i = 0 to srSz - 1
                    bool isMitigated = array.get(mtf_sr_isMitigated, i)
                    bool isHidden = array.get(mtf_sr_isUserHidden, i)
                    bool isFlip = array.get(mtf_sr_isFlips, i)
                    bool showByRules = not isMitigated and not isHidden and ((isFlip and dsr_showFlip) or not isFlip)
                    if showByRules
                        int nestedState = mtfNestedStateSr(i)
                        int tfSecV = array.get(mtf_sr_tfSecs, i)
                        if tfSecV > chartTfSecMtf
                            float topCand = array.get(mtf_sr_tops, i)
                            float botCand = array.get(mtf_sr_bottoms, i)
                            int biasCand = array.get(mtf_sr_biases, i)
                            float distCand = biasCand == 1 ? mtfSupportDistance(topCand, botCand, close) : mtfResistanceDistance(topCand, botCand, close)
                            int insertPos = array.size(selectedSr)
                            int curSelSz = math.min(array.size(selectedSr), array.size(selectedSrDist))
                            if curSelSz > 0
                                for p = 0 to curSelSz - 1
                                    float curDist = array.get(selectedSrDist, p)
                                    int curIdx = array.get(selectedSr, p)
                                    int curTfSec = array.get(mtf_sr_tfSecs, curIdx)
                                    if distCand < curDist or (distCand == curDist and tfSecV > curTfSec)
                                        insertPos := p
                                        break
                            int insertPosSrIdx = math.min(insertPos, array.size(selectedSr))
                            int insertPosSrDist = math.min(insertPos, array.size(selectedSrDist))
                            array.insert(selectedSr, insertPosSrIdx, i)
                            array.insert(selectedSrDist, insertPosSrDist, distCand)
                            int srSyncSel = math.min(array.size(selectedSr), array.size(selectedSrDist))
                            while array.size(selectedSr) > srSyncSel
                                array.pop(selectedSr)
                            while array.size(selectedSrDist) > srSyncSel
                                array.pop(selectedSrDist)
            int a = 0
            while a < math.min(array.size(selectedSr), array.size(selectedSrDist))
                int keepIdx = array.get(selectedSr, a)
                float keepDist = array.get(selectedSrDist, a)
                float keepTop = array.get(mtf_sr_tops, keepIdx)
                float keepBot = array.get(mtf_sr_bottoms, keepIdx)
                int keepBias = array.get(mtf_sr_biases, keepIdx)
                int keepTfSec = array.get(mtf_sr_tfSecs, keepIdx)
                int keepTime = array.get(mtf_sr_times, keepIdx)
                int b = a + 1
                while b < math.min(array.size(selectedSr), array.size(selectedSrDist))
                    int candIdx = array.get(selectedSr, b)
                    float candTop = array.get(mtf_sr_tops, candIdx)
                    float candBot = array.get(mtf_sr_bottoms, candIdx)
                    int candBias = array.get(mtf_sr_biases, candIdx)
                    if candBias == keepBias and mtfPriorityMatch(candTop, candBot, keepTop, keepBot, mtf_nestedThreshold)
                        float candDist = array.get(selectedSrDist, b)
                        int candTfSec = array.get(mtf_sr_tfSecs, candIdx)
                        int candTime = array.get(mtf_sr_times, candIdx)
                        if mtfCandidateWins(candTfSec, candTime, candDist, keepTfSec, keepTime, keepDist)
                            array.set(selectedSr, a, candIdx)
                            array.set(selectedSrDist, a, candDist)
                            keepIdx := candIdx
                            keepDist := candDist
                            keepTop := candTop
                            keepBot := candBot
                            keepTfSec := candTfSec
                            keepTime := candTime
                        array.remove(selectedSr, b)
                        array.remove(selectedSrDist, b)
                    else
                        b += 1
                a += 1
            int selSrSz = math.min(array.size(selectedSr), math.max(1, dsr_visibleTotal_live))
            int srAboveUsed = 0
            int srBelowUsed = 0
            if selSrSz > 0
                for k = 0 to selSrSz - 1
                    int i = array.get(selectedSr, k)
                    bool isMitigated = array.get(mtf_sr_isMitigated, i)
                    bool isFlip = array.get(mtf_sr_isFlips, i)
                    float topV = array.get(mtf_sr_tops, i)
                    float botV = array.get(mtf_sr_bottoms, i)
                    int biasV = array.get(mtf_sr_biases, i)
                    float srMidV = math.avg(topV, botV)
                    bool srIsAbove = srMidV >= close
                    bool srAllowSide = srIsAbove ? totalAboveUsed < dsr_maxAbove_live : totalBelowUsed < dsr_maxBelow_live
                    if not srAllowSide
                        continue
                    int timeV = array.get(mtf_sr_times, i)
                    bool hasLocalConfluence = srLocalVisibleMatch(topV, botV, biasV)
                    if hasLocalConfluence
                        continue
                    string tfLblVRaw = array.get(mtf_sr_tfLabels, i)
                    string tfLblV = mtfResolvedTfLabel(tfLblVRaw, array.get(mtf_sr_tfSecs, i))
                    int nestedState = mtfNestedStateSr(i)
                    bool isDimmed = nestedState == 1
                    color zoneInputC = biasV == 1 ? dsr_supportColor : dsr_resistColor
                    color zoneFillC = mtfInheritedFill(zoneInputC, isDimmed)
                    string zoneTxt = isFlip ? "FLIP [" + tfLblV + "]" : (biasV == 1 ? "SUPPORT [" : "RESISTANCE [") + tfLblV + "]"
                    [bandTopV, bandBotV] = dsrRenderBand(topV, botV, biasV == 1 ? topV : botV)
                    float srLabelPrice = srZoneMode ? math.avg(bandTopV, bandBotV) : array.get(mtf_sr_basePrices, i)
                    if srZoneMode
                        if srBoxUsed >= array.size(mtf_sr_boxes)
                            array.push(mtf_sr_boxes, box.new(timeV, bandTopV, last_bar_time, bandBotV, xloc=xloc.bar_time, extend=extend.right, bgcolor=zoneFillC, border_color=na, border_width=0, text=dsr_mtf_showLabels ? zoneTxt : "", text_color=dsr_labelColor, text_size=_szSRMtf, text_halign=text.align_left, text_valign=text.align_center))
                        box srBx = array.get(mtf_sr_boxes, srBoxUsed)
                        box.set_left(srBx, timeV)
                        box.set_right(srBx, last_bar_time)
                        box.set_top(srBx, bandTopV)
                        box.set_bottom(srBx, bandBotV)
                        box.set_bgcolor(srBx, zoneFillC)
                        box.set_border_color(srBx, na)
                        box.set_border_width(srBx, 0)
                        box.set_extend(srBx, extend.right)
                        box.set_text(srBx, dsr_mtf_showLabels ? zoneTxt : "")
                        box.set_text_color(srBx, dsr_labelColor)
                        box.set_text_size(srBx, _szSRMtf)
                        box.set_text_halign(srBx, text.align_left)
                        box.set_text_valign(srBx, text.align_center)
                        srBoxUsed += 1
                    else
                        float midV = array.get(mtf_sr_basePrices, i)
                        if srLineUsed >= array.size(mtf_sr_lines)
                            array.push(mtf_sr_lines, line.new(timeV, midV, last_bar_time, midV, xloc=xloc.bar_time, extend=extend.right, color=mtfInheritedLine(zoneInputC, isDimmed), width=1))
                        line srLn = array.get(mtf_sr_lines, srLineUsed)
                        line.set_xy1(srLn, timeV, midV)
                        line.set_xy2(srLn, last_bar_time, midV)
                        line.set_extend(srLn, extend.right)
                        line.set_color(srLn, mtfInheritedLine(zoneInputC, isDimmed))
                        line.set_width(srLn, 1)
                        srLineUsed += 1
                    if dsr_mtf_showLabels and not srZoneMode and srLabelUsed < mtf_maxVisibleLabels_live
                        if srLabelUsed >= array.size(mtf_sr_labels)
                            array.push(mtf_sr_labels, label.new(last_bar_time, srLabelPrice, zoneTxt, xloc=xloc.bar_time, yloc=yloc.price, style=label.style_label_left, color=color.new(color.black,100), textcolor=dsr_labelColor, size=_szSRMtf))
                        label srLb = array.get(mtf_sr_labels, srLabelUsed)
                        label.set_x(srLb, last_bar_time)
                        label.set_y(srLb, srLabelPrice)
                        label.set_text(srLb, zoneTxt)
                        label.set_style(srLb, label.style_label_left)
                        label.set_color(srLb, color.new(color.black,100))
                        label.set_textcolor(srLb, dsr_labelColor)
                        label.set_size(srLb, _szSRMtf)
                        srLabelUsed += 1
                    if srIsAbove
                        totalAboveUsed += 1
                    else
                        totalBelowUsed += 1
            trimBoxArrayTo(mtf_sr_boxes, srZoneMode ? srBoxUsed : 0)
            trimLineArrayTo(mtf_sr_lines, srZoneMode ? 0 : srLineUsed)
            trimLabelArrayTo(mtf_sr_labels, dsr_mtf_showLabels and not srZoneMode ? srLabelUsed : 0)
    [totalAboveUsed, totalBelowUsed]

runMtfObOverlay(int totalAboveUsedIn, int totalBelowUsedIn) =>
    int totalAboveUsed = totalAboveUsedIn
    int totalBelowUsed = totalBelowUsedIn
    // MTF S/R + OB OVERLAY
    //══════════════════════════════════════════════════════════════════════════════
    int chartTfSecMtf = timeframe.in_seconds(timeframe.period)
    bool ob_useTf1 = ob_mtf_enable and mtfTfIsUsable(ob_mtf_tf1, chartTfSecMtf, mtf_requireHigherTf)
    bool ob_useTf2 = ob_mtf_enable and mtfTfIsUsable(ob_mtf_tf2, chartTfSecMtf, mtf_requireHigherTf) and (not mtf_ignoreDuplicateTfs or not mtfTfIsDuplicate(ob_mtf_tf2, ob_mtf_tf1, "", "", ""))
    bool ob_useTf3 = ob_mtf_enable and mtfTfIsUsable(ob_mtf_tf3, chartTfSecMtf, mtf_requireHigherTf) and (not mtf_ignoreDuplicateTfs or not mtfTfIsDuplicate(ob_mtf_tf3, ob_mtf_tf1, ob_mtf_tf2, "", ""))
    bool ob_anyTf = ob_useTf1 or ob_useTf2 or ob_useTf3
    int obLenMtf = ob_sensitivity == 1 ? 3 : ob_sensitivity == 2 ? 5 : ob_sensitivity == 3 ? 8 : ob_sensitivity == 4 ? 13 : 21
    int obIntLenMtf = 3
    int ob_tfSec1 = timeframe.in_seconds(ob_mtf_tf1)
    int ob_tfSec2 = timeframe.in_seconds(ob_mtf_tf2)
    int ob_tfSec3 = timeframe.in_seconds(ob_mtf_tf3)
    string ob_tfLbl1 = tfPretty(ob_mtf_tf1)
    string ob_tfLbl2 = tfPretty(ob_mtf_tf2)
    string ob_tfLbl3 = tfPretty(ob_mtf_tf3)
    string ob_tfReq1 = str.length(ob_mtf_tf1) > 0 ? ob_mtf_tf1 : timeframe.period
    string ob_tfReq2 = str.length(ob_mtf_tf2) > 0 ? ob_mtf_tf2 : timeframe.period
    string ob_tfReq3 = str.length(ob_mtf_tf3) > 0 ? ob_mtf_tf3 : timeframe.period

    [bullEvt1, bullTop1, bullBot1, bullTime1, bullVol1, bearEvt1, bearTop1, bearBot1, bearTime1, bearVol1, ob_h1, ob_l1, ob_c1, ob_v1] = request.security(syminfo.tickerid, ob_tfReq1, mtfObBundle(obLenMtf), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
    [bullEvt2, bullTop2, bullBot2, bullTime2, bullVol2, bearEvt2, bearTop2, bearBot2, bearTime2, bearVol2, ob_h2, ob_l2, ob_c2, ob_v2] = request.security(syminfo.tickerid, ob_tfReq2, mtfObBundle(obLenMtf), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
    [bullEvt3, bullTop3, bullBot3, bullTime3, bullVol3, bearEvt3, bearTop3, bearBot3, bearTime3, bearVol3, ob_h3, ob_l3, ob_c3, ob_v3] = request.security(syminfo.tickerid, ob_tfReq3, mtfObBundle(obLenMtf), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
    [bullEvtI1, bullTopI1, bullBotI1, bullTimeI1, bullVolI1, bearEvtI1, bearTopI1, bearBotI1, bearTimeI1, bearVolI1, ob_hi1, ob_li1, ob_ci1, ob_vi1] = request.security(syminfo.tickerid, ob_tfReq1, mtfObBundle(obIntLenMtf), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
    [bullEvtI2, bullTopI2, bullBotI2, bullTimeI2, bullVolI2, bearEvtI2, bearTopI2, bearBotI2, bearTimeI2, bearVolI2, ob_hi2, ob_li2, ob_ci2, ob_vi2] = request.security(syminfo.tickerid, ob_tfReq2, mtfObBundle(obIntLenMtf), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
    [bullEvtI3, bullTopI3, bullBotI3, bullTimeI3, bullVolI3, bearEvtI3, bearTopI3, bearBotI3, bearTimeI3, bearVolI3, ob_hi3, ob_li3, ob_ci3, ob_vi3] = request.security(syminfo.tickerid, ob_tfReq3, mtfObBundle(obIntLenMtf), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

    if ob_mtf_enable and ob_anyTf
        if ob_useTf1
            if bullEvt1 == 1
                mtfStoreOb(bullTop1, bullBot1, 1, bullTime1, ob_tfSec1, ob_tfLbl1, bullVol1)
            if bearEvt1 == 1
                mtfStoreOb(bearTop1, bearBot1, -1, bearTime1, ob_tfSec1, ob_tfLbl1, bearVol1)
            if ob_showInternal
                if bullEvtI1 == 1
                    mtfStoreOb(bullTopI1, bullBotI1, 1, bullTimeI1, ob_tfSec1, ob_tfLbl1, bullVolI1)
                if bearEvtI1 == 1
                    mtfStoreOb(bearTopI1, bearBotI1, -1, bearTimeI1, ob_tfSec1, ob_tfLbl1, bearVolI1)
            mtfUpdateObForTf(ob_tfSec1, ob_h1, ob_l1, ob_c1)
        if ob_useTf2
            if bullEvt2 == 1
                mtfStoreOb(bullTop2, bullBot2, 1, bullTime2, ob_tfSec2, ob_tfLbl2, bullVol2)
            if bearEvt2 == 1
                mtfStoreOb(bearTop2, bearBot2, -1, bearTime2, ob_tfSec2, ob_tfLbl2, bearVol2)
            if ob_showInternal
                if bullEvtI2 == 1
                    mtfStoreOb(bullTopI2, bullBotI2, 1, bullTimeI2, ob_tfSec2, ob_tfLbl2, bullVolI2)
                if bearEvtI2 == 1
                    mtfStoreOb(bearTopI2, bearBotI2, -1, bearTimeI2, ob_tfSec2, ob_tfLbl2, bearVolI2)
            mtfUpdateObForTf(ob_tfSec2, ob_h2, ob_l2, ob_c2)
        if ob_useTf3
            if bullEvt3 == 1
                mtfStoreOb(bullTop3, bullBot3, 1, bullTime3, ob_tfSec3, ob_tfLbl3, bullVol3)
            if bearEvt3 == 1
                mtfStoreOb(bearTop3, bearBot3, -1, bearTime3, ob_tfSec3, ob_tfLbl3, bearVol3)
            if ob_showInternal
                if bullEvtI3 == 1
                    mtfStoreOb(bullTopI3, bullBotI3, 1, bullTimeI3, ob_tfSec3, ob_tfLbl3, bullVolI3)
                if bearEvtI3 == 1
                    mtfStoreOb(bearTopI3, bearBotI3, -1, bearTimeI3, ob_tfSec3, ob_tfLbl3, bearVolI3)
            mtfUpdateObForTf(ob_tfSec3, ob_h3, ob_l3, ob_c3)
        if doHeavyRender
            if ob_useTf1
                mtfCompactObForTf(ob_tfSec1)
            if ob_useTf2
                mtfCompactObForTf(ob_tfSec2)
            if ob_useTf3
                mtfCompactObForTf(ob_tfSec3)
    else if barstate.islast
        array.clear(mtf_ob_tops)
        array.clear(mtf_ob_bottoms)
        array.clear(mtf_ob_biases)
        array.clear(mtf_ob_times)
        array.clear(mtf_ob_tfSecs)
        array.clear(mtf_ob_tfLabels)
        array.clear(mtf_ob_vols)
        clearBoxArray(mtf_ob_boxes)
        clearLabelArray(mtf_ob_labels)

    if doHeavyRender
        int obBoxUsed = 0
        if not (ob_mtf_enable and ob_anyTf)
            trimBoxArrayTo(mtf_ob_boxes, 0)
            trimLabelArrayTo(mtf_ob_labels, 0)
        else
            int obSz = mtfObSyncedSize()
            string _szOBMtf = ob_labelSize == "Tiny" ? size.tiny : ob_labelSize == "Small" ? size.small : ob_labelSize == "Normal" ? size.normal : size.large
            array<int> selectedOb = array.new_int()
            array<float> selectedObDist = array.new_float()
            if obSz > 0
                for i = 0 to obSz - 1
                    int nestedState = mtfNestedStateOb(i)
                    int tfSecV = array.get(mtf_ob_tfSecs, i)
                    if tfSecV > chartTfSecMtf
                        float topCand = array.get(mtf_ob_tops, i)
                        float botCand = array.get(mtf_ob_bottoms, i)
                        int biasCand = array.get(mtf_ob_biases, i)
                        float distCand = mtfObDistance(biasCand, topCand, botCand, close)
                        int insertPos = array.size(selectedOb)
                        int curSelSz = math.min(array.size(selectedOb), array.size(selectedObDist))
                        if curSelSz > 0
                            for p = 0 to curSelSz - 1
                                float curDist = array.get(selectedObDist, p)
                                int curIdx = array.get(selectedOb, p)
                                int curTfSec = array.get(mtf_ob_tfSecs, curIdx)
                                if distCand < curDist or (distCand == curDist and tfSecV > curTfSec)
                                    insertPos := p
                                    break
                        int insertPosObIdx = math.min(insertPos, array.size(selectedOb))
                        int insertPosObDist = math.min(insertPos, array.size(selectedObDist))
                        array.insert(selectedOb, insertPosObIdx, i)
                        array.insert(selectedObDist, insertPosObDist, distCand)
                        int obSyncSel = math.min(array.size(selectedOb), array.size(selectedObDist))
                        while array.size(selectedOb) > obSyncSel
                            array.pop(selectedOb)
                        while array.size(selectedObDist) > obSyncSel
                            array.pop(selectedObDist)
            int a = 0
            while a < math.min(array.size(selectedOb), array.size(selectedObDist))
                int keepIdx = array.get(selectedOb, a)
                float keepDist = array.get(selectedObDist, a)
                float keepTop = array.get(mtf_ob_tops, keepIdx)
                float keepBot = array.get(mtf_ob_bottoms, keepIdx)
                int keepBias = array.get(mtf_ob_biases, keepIdx)
                int keepTfSec = array.get(mtf_ob_tfSecs, keepIdx)
                int keepTime = array.get(mtf_ob_times, keepIdx)
                int b = a + 1
                while b < math.min(array.size(selectedOb), array.size(selectedObDist))
                    int candIdx = array.get(selectedOb, b)
                    float candTop = array.get(mtf_ob_tops, candIdx)
                    float candBot = array.get(mtf_ob_bottoms, candIdx)
                    int candBias = array.get(mtf_ob_biases, candIdx)
                    if candBias == keepBias and obMtfNestedHit(candTop, candBot, keepTop, keepBot, mtf_nestedThreshold)
                        float candDist = array.get(selectedObDist, b)
                        int candTfSec = array.get(mtf_ob_tfSecs, candIdx)
                        int candTime = array.get(mtf_ob_times, candIdx)
                        if mtfCandidateWins(candTfSec, candTime, candDist, keepTfSec, keepTime, keepDist)
                            array.set(selectedOb, a, candIdx)
                            array.set(selectedObDist, a, candDist)
                            keepIdx := candIdx
                            keepDist := candDist
                            keepTop := candTop
                            keepBot := candBot
                            keepTfSec := candTfSec
                            keepTime := candTime
                        array.remove(selectedOb, b)
                        array.remove(selectedObDist, b)
                    else
                        b += 1
                a += 1
            int selObSz = math.min(array.size(selectedOb), math.max(1, ob_visibleTotal_live))
            int obAboveUsed = 0
            int obBelowUsed = 0
            if selObSz > 0
                for k = 0 to selObSz - 1
                    int i = array.get(selectedOb, k)
                    int nestedState = mtfNestedStateOb(i)
                    bool isDimmed = nestedState == 1
                    float topV = array.get(mtf_ob_tops, i)
                    float botV = array.get(mtf_ob_bottoms, i)
                    int biasV = array.get(mtf_ob_biases, i)
                    float obMidV = math.avg(topV, botV)
                    bool obIsAbove = obMidV >= close
                    bool obAllowSide = obIsAbove ? totalAboveUsed < ob_visibleAbove_live : totalBelowUsed < ob_visibleBelow_live
                    if not obAllowSide
                        continue
                    if obLocalVisibleMatch(topV, botV, biasV)
                        continue
                    int timeV = array.get(mtf_ob_times, i)
                    string tfLblVRaw = array.get(mtf_ob_tfLabels, i)
                    string tfLblV = mtfResolvedTfLabel(tfLblVRaw, array.get(mtf_ob_tfSecs, i))
                    string zoneTxt = "OB [" + tfLblV + "]"
                    color fillInputC = biasV == 1 ? ob_bullColor : ob_bearColor
                    color zoneFillC = mtfInheritedFill(fillInputC, isDimmed)
                    color zoneBorderC = mtfInheritedBorder(fillInputC, isDimmed)
                    string obBoxTxt = ob_mtf_showLabels ? zoneTxt : ""
                    if obBoxUsed >= array.size(mtf_ob_boxes)
                        array.push(mtf_ob_boxes, box.new(timeV, topV, last_bar_time, botV, xloc=xloc.bar_time, extend=extend.right, bgcolor=zoneFillC, border_color=zoneBorderC, border_width=1, text=obBoxTxt, text_color=color.white, text_size=_szOBMtf, text_halign=text.align_left, text_valign=text.align_center))
                    box obBx = array.get(mtf_ob_boxes, obBoxUsed)
                    box.set_left(obBx, timeV)
                    box.set_right(obBx, last_bar_time)
                    box.set_top(obBx, topV)
                    box.set_bottom(obBx, botV)
                    box.set_bgcolor(obBx, zoneFillC)
                    box.set_border_color(obBx, zoneBorderC)
                    box.set_border_width(obBx, 1)
                    box.set_extend(obBx, extend.right)
                    box.set_text(obBx, obBoxTxt)
                    box.set_text_color(obBx, color.white)
                    box.set_text_size(obBx, _szOBMtf)
                    box.set_text_halign(obBx, text.align_left)
                    box.set_text_valign(obBx, text.align_center)
                    obBoxUsed += 1
                    if obIsAbove
                        totalAboveUsed += 1
                    else
                        totalBelowUsed += 1
        trimBoxArrayTo(mtf_ob_boxes, obBoxUsed)
        trimLabelArrayTo(mtf_ob_labels, 0)
    [totalAboveUsed, totalBelowUsed]

runLiquidityPoolsOverlay() =>
    // LIQUIDITY POOLS
    //══════════════════════════════════════════════════════════════════════════════
    if enableLiquidity and liq_pools_show
        float liqPoolMargin = ta.atr(10) / liq_pools_marginDiv

        if not na(liq_pool_ph)
            float pivotPriceH = liq_pool_ph
            int   pivotBarH   = bar_index - liq_pools_pivotLen
            array.unshift(liq_recentHighVals, pivotPriceH)
            array.unshift(liq_recentHighBars, pivotBarH)
            if array.size(liq_recentHighVals) > 60
                array.pop(liq_recentHighVals)
                array.pop(liq_recentHighBars)

            int countH = 0
            float minPH = 10e10
            float maxPH = -10e10
            int leftH = pivotBarH
            int recentHighSz = array.size(liq_recentHighVals)
            if recentHighSz > 0
                for i = 0 to recentHighSz - 1
                    float v = array.get(liq_recentHighVals, i)
                    if math.abs(v - pivotPriceH) <= liqPoolMargin
                        countH += 1
                        minPH := math.min(minPH, v)
                        maxPH := math.max(maxPH, v)
                        leftH := math.min(leftH, array.get(liq_recentHighBars, i))

            if countH >= liq_pools_minTouches
                float midH = math.avg(minPH, maxPH)
                float topH = midH + liqPoolMargin
                float botH = midH - liqPoolMargin
                bool foundH = false
                int poolSzH = array.size(liq_pool_prices)
                if poolSzH > 0
                    for i = 0 to poolSzH - 1
                        if array.get(liq_pool_sides, i) == 1 and math.abs(array.get(liq_pool_prices, i) - midH) <= liqPoolMargin
                            array.set(liq_pool_prices, i, midH)
                            array.set(liq_pool_tops, i, math.max(array.get(liq_pool_tops, i), topH))
                            array.set(liq_pool_bottoms, i, math.min(array.get(liq_pool_bottoms, i), botH))
                            array.set(liq_pool_leftBars, i, math.min(array.get(liq_pool_leftBars, i), leftH))
                            array.set(liq_pool_swept, i, false)
                            foundH := true
                            break
                if not foundH
                    array.unshift(liq_pool_tops, topH)
                    array.unshift(liq_pool_bottoms, botH)
                    array.unshift(liq_pool_prices, midH)
                    array.unshift(liq_pool_leftBars, leftH)
                    array.unshift(liq_pool_sides, 1)
                    array.unshift(liq_pool_swept, false)
                    while array.size(liq_pool_prices) > liq_pools_store_cap_live
                        array.pop(liq_pool_tops)
                        array.pop(liq_pool_bottoms)
                        array.pop(liq_pool_prices)
                        array.pop(liq_pool_leftBars)
                        array.pop(liq_pool_sides)
                        array.pop(liq_pool_swept)

        if not na(liq_pool_pl)
            float pivotPriceL = liq_pool_pl
            int   pivotBarL   = bar_index - liq_pools_pivotLen
            array.unshift(liq_recentLowVals, pivotPriceL)
            array.unshift(liq_recentLowBars, pivotBarL)
            if array.size(liq_recentLowVals) > 60
                array.pop(liq_recentLowVals)
                array.pop(liq_recentLowBars)

            int countL = 0
            float minPL = 10e10
            float maxPL = -10e10
            int leftL = pivotBarL
            int recentLowSz = array.size(liq_recentLowVals)
            if recentLowSz > 0
                for i = 0 to recentLowSz - 1
                    float v = array.get(liq_recentLowVals, i)
                    if math.abs(v - pivotPriceL) <= liqPoolMargin
                        countL += 1
                        minPL := math.min(minPL, v)
                        maxPL := math.max(maxPL, v)
                        leftL := math.min(leftL, array.get(liq_recentLowBars, i))

            if countL >= liq_pools_minTouches
                float midL = math.avg(minPL, maxPL)
                float topL = midL + liqPoolMargin
                float botL = midL - liqPoolMargin
                bool foundL = false
                int poolSzL = array.size(liq_pool_prices)
                if poolSzL > 0
                    for i = 0 to poolSzL - 1
                        if array.get(liq_pool_sides, i) == -1 and math.abs(array.get(liq_pool_prices, i) - midL) <= liqPoolMargin
                            array.set(liq_pool_prices, i, midL)
                            array.set(liq_pool_tops, i, math.max(array.get(liq_pool_tops, i), topL))
                            array.set(liq_pool_bottoms, i, math.min(array.get(liq_pool_bottoms, i), botL))
                            array.set(liq_pool_leftBars, i, math.min(array.get(liq_pool_leftBars, i), leftL))
                            array.set(liq_pool_swept, i, false)
                            foundL := true
                            break
                if not foundL
                    array.unshift(liq_pool_tops, topL)
                    array.unshift(liq_pool_bottoms, botL)
                    array.unshift(liq_pool_prices, midL)
                    array.unshift(liq_pool_leftBars, leftL)
                    array.unshift(liq_pool_sides, -1)
                    array.unshift(liq_pool_swept, false)
                    while array.size(liq_pool_prices) > liq_pools_store_cap_live
                        array.pop(liq_pool_tops)
                        array.pop(liq_pool_bottoms)
                        array.pop(liq_pool_prices)
                        array.pop(liq_pool_leftBars)
                        array.pop(liq_pool_sides)
                        array.pop(liq_pool_swept)

        int liqPoolSz = array.size(liq_pool_prices)
        if liqPoolSz > 0
            for i = 0 to liqPoolSz - 1
                if not array.get(liq_pool_swept, i)
                    int side = array.get(liq_pool_sides, i)
                    float topV = array.get(liq_pool_tops, i)
                    float botV = array.get(liq_pool_bottoms, i)
                    bool sweptNow = side == 1 ? high > topV : low < botV
                    if sweptNow
                        array.set(liq_pool_swept, i, true)

        if doHeavyRender
            int shownBuy = 0
            int shownSell = 0
            int liqPoolRenderSz = array.size(liq_pool_prices)
            int liqPoolBoxUsed = 0
            int liqPoolLineUsed = 0
            int liqPoolLabelUsed = 0
            string liqPoolLblSz = liq_aux_label_size_val
            if liqPoolRenderSz > 0
                for i = 0 to liqPoolRenderSz - 1
                    bool swept = array.get(liq_pool_swept, i)
                    if swept
                        continue
                    int side = array.get(liq_pool_sides, i)
                    if side == 1 and shownBuy >= liq_pools_visible_live
                        continue
                    if side == -1 and shownSell >= liq_pools_visible_live
                        continue

                    int leftBar = math.max(array.get(liq_pool_leftBars, i), bar_index - 4900)
                    int histEndBar = math.max(leftBar, bar_index - 1)
                    int rightBar = math.max(histEndBar, leftBar + liq_pools_extendBars)
                    float topV = array.get(liq_pool_tops, i)
                    float botV = array.get(liq_pool_bottoms, i)
                    float priceV = array.get(liq_pool_prices, i)
                    color poolC = side == 1 ? liq_pool_buyColor : liq_pool_sellColor
                    string poolTxt = side == 1 ? "Buyside Liquidity" : "Sellside Liquidity"

                    if liqPoolBoxUsed >= array.size(liq_pool_boxes)
                        array.push(liq_pool_boxes, box.new(leftBar, topV, rightBar, botV, border_color=na, bgcolor=color.new(poolC, 88)))
                    box poolBx = array.get(liq_pool_boxes, liqPoolBoxUsed)
                    box.set_left(poolBx, leftBar)
                    box.set_top(poolBx, topV)
                    box.set_right(poolBx, rightBar)
                    box.set_bottom(poolBx, botV)
                    box.set_border_color(poolBx, na)
                    box.set_bgcolor(poolBx, color.new(poolC, 88))
                    liqPoolBoxUsed += 1

                    if liqPoolLineUsed >= array.size(liq_pool_lines)
                        array.push(liq_pool_lines, line.new(leftBar, priceV, histEndBar, priceV, color=color.new(poolC, 0), width=1))
                    line poolLnA = array.get(liq_pool_lines, liqPoolLineUsed)
                    line.set_xy1(poolLnA, leftBar, priceV)
                    line.set_xy2(poolLnA, histEndBar, priceV)
                    line.set_color(poolLnA, color.new(poolC, 0))
                    line.set_width(poolLnA, 1)
                    line.set_style(poolLnA, line.style_solid)
                    liqPoolLineUsed += 1

                    if liqPoolLineUsed >= array.size(liq_pool_lines)
                        array.push(liq_pool_lines, line.new(histEndBar, priceV, rightBar, priceV, color=color.new(poolC, 0), width=1, style=line.style_dotted))
                    line poolLnB = array.get(liq_pool_lines, liqPoolLineUsed)
                    line.set_xy1(poolLnB, histEndBar, priceV)
                    line.set_xy2(poolLnB, rightBar, priceV)
                    line.set_color(poolLnB, color.new(poolC, 0))
                    line.set_width(poolLnB, 1)
                    line.set_style(poolLnB, line.style_dotted)
                    liqPoolLineUsed += 1

                    if liq_pools_showLabels
                        if liqPoolLabelUsed >= array.size(liq_pool_labels)
                            array.push(liq_pool_labels, label.new(leftBar + 1, priceV, poolTxt, xloc=xloc.bar_index, yloc=yloc.price, style=label.style_none, color=color.new(color.black, 100), textcolor=color.new(poolC, 0), size=liqPoolLblSz))
                        label poolLb = array.get(liq_pool_labels, liqPoolLabelUsed)
                        label.set_x(poolLb, leftBar + 1)
                        label.set_y(poolLb, priceV)
                        label.set_text(poolLb, poolTxt)
                        label.set_style(poolLb, label.style_none)
                        label.set_color(poolLb, color.new(color.black, 100))
                        label.set_textcolor(poolLb, color.new(poolC, 0))
                        label.set_size(poolLb, liqPoolLblSz)
                        liqPoolLabelUsed += 1

                    if side == 1
                        shownBuy += 1
                    else
                        shownSell += 1
            trimBoxArrayTo(liq_pool_boxes, liqPoolBoxUsed)
            trimLineArrayTo(liq_pool_lines, liqPoolLineUsed)
            trimLabelArrayTo(liq_pool_labels, liq_pools_showLabels ? liqPoolLabelUsed : 0)
    else if barstate.islast
        clearBoxArray(liq_pool_boxes)
        clearLineArray(liq_pool_lines)
        clearLabelArray(liq_pool_labels)

    //══════════════════════════════════════════════════════════════════════════════

runLiquidityVoidsOverlay() =>
    // LIQUIDITY VOIDS
    //══════════════════════════════════════════════════════════════════════════════
    if enableLiquidity and liq_void_show
        float liqVoidAtr = ta.atr(200) * liq_void_threshold
        bool liqVoidInRange = liq_void_mode == "Present" ? (last_bar_index - bar_index <= liq_void_period) : true

        if liqVoidInRange
            bool bullVoid = low - high[2] > liqVoidAtr and low > high[2] and close[1] > high[2]
            bool bearVoid = low[2] - high > liqVoidAtr and high < low[2] and close[1] < low[2]

            if bullVoid
                array.unshift(liq_void_tops, low)
                array.unshift(liq_void_bottoms, high[2])
                array.unshift(liq_void_leftBars, bar_index - 2)
                array.unshift(liq_void_biases, 1)
            if bearVoid
                array.unshift(liq_void_tops, low[2])
                array.unshift(liq_void_bottoms, high)
                array.unshift(liq_void_leftBars, bar_index - 2)
                array.unshift(liq_void_biases, -1)

        while array.size(liq_void_tops) > liq_void_store_cap_live
            array.pop(liq_void_tops)
            array.pop(liq_void_bottoms)
            array.pop(liq_void_leftBars)
            array.pop(liq_void_biases)

        int voidSz = array.size(liq_void_tops)
        int i = voidSz - 1
        while i >= 0
            int bias = array.get(liq_void_biases, i)
            float topV = array.get(liq_void_tops, i)
            float botV = array.get(liq_void_bottoms, i)
            float midV = math.avg(topV, botV)
            bool filled = liq_void_mitigation == "Touch" ? (bias == 1 ? low <= topV : high >= botV) : liq_void_mitigation == "Close" ? (bias == 1 ? close <= midV : close >= midV) : (bias == 1 ? low <= botV : high >= topV)
            bool tooOld = liq_void_mode == "Present" and bar_index - array.get(liq_void_leftBars, i) > liq_void_period
            if filled or tooOld
                array.remove(liq_void_tops, i)
                array.remove(liq_void_bottoms, i)
                array.remove(liq_void_leftBars, i)
                array.remove(liq_void_biases, i)
            i -= 1

        if doHeavyRender
            int voidRenderSz = array.size(liq_void_tops)
            int liqVoidBoxUsed = 0
            int liqVoidLabelUsed = 0
            string liqVoidLblSz = liq_aux_label_size_val
            if voidRenderSz > 0
                int voidRenderMax = math.min(voidRenderSz, liq_void_visible_live)
                for j = 0 to voidRenderMax - 1
                    float topV = array.get(liq_void_tops, j)
                    float botV = array.get(liq_void_bottoms, j)
                    int leftBar = math.max(array.get(liq_void_leftBars, j), bar_index - 4900)
                    int rightBar = math.max(leftBar + liq_void_extendBars, leftBar + 1)
                    int bias = array.get(liq_void_biases, j)
                    color voidC = bias == 1 ? liq_void_bullColor : liq_void_bearColor
                    if liqVoidBoxUsed >= array.size(liq_void_boxes)
                        array.push(liq_void_boxes, box.new(leftBar, topV, rightBar, botV, border_color=na, bgcolor=voidC))
                    box voidBx = array.get(liq_void_boxes, liqVoidBoxUsed)
                    box.set_left(voidBx, leftBar)
                    box.set_top(voidBx, topV)
                    box.set_right(voidBx, rightBar)
                    box.set_bottom(voidBx, botV)
                    box.set_border_color(voidBx, na)
                    box.set_bgcolor(voidBx, voidC)
                    liqVoidBoxUsed += 1
                    if liq_void_showLabels
                        float midV = math.avg(topV, botV)
                        if liqVoidLabelUsed >= array.size(liq_void_labels)
                            array.push(liq_void_labels, label.new(leftBar + 1, midV, "Liquidity Void", xloc=xloc.bar_index, yloc=yloc.price, style=label.style_none, color=color.new(color.black, 100), textcolor=color.new(chart.fg_color, 25), size=liqVoidLblSz))
                        label voidLb = array.get(liq_void_labels, liqVoidLabelUsed)
                        label.set_x(voidLb, leftBar + 1)
                        label.set_y(voidLb, midV)
                        label.set_text(voidLb, "Liquidity Void")
                        label.set_style(voidLb, label.style_none)
                        label.set_color(voidLb, color.new(color.black, 100))
                        label.set_textcolor(voidLb, color.new(chart.fg_color, 25))
                        label.set_size(voidLb, liqVoidLblSz)
                        liqVoidLabelUsed += 1
            trimBoxArrayTo(liq_void_boxes, liqVoidBoxUsed)
            trimLabelArrayTo(liq_void_labels, liq_void_showLabels ? liqVoidLabelUsed : 0)
    else if barstate.islast
        clearBoxArray(liq_void_boxes)
        clearLabelArray(liq_void_labels)

    //══════════════════════════════════════════════════════════════════════════════

runBprOverlay() =>
    // BPR
    //══════════════════════════════════════════════════════════════════════════════
    if enableLiquidity and bpr_show
        bool bpr_rawBull = low > high[2]
        bool bpr_rawBear = high < low[2]
        float bprMinSize = atrVal * bpr_minSizeAtr

        if bpr_rawBull
            array.push(bpr_allBullTops, low)
            array.push(bpr_allBullBots, high[2])
            if array.size(bpr_allBullTops) > bpr_gap_store_cap_live
                array.shift(bpr_allBullTops)
                array.shift(bpr_allBullBots)

            int nbear = array.size(bpr_allBearTops)
            if nbear > 0
                for bj = nbear - 1 to 0
                    float bT = array.get(bpr_allBearTops, bj)
                    float bB = array.get(bpr_allBearBots, bj)
                    bool hasOvlp = low > bB and high[2] < bT
                    if hasOvlp
                        float bprTop = math.min(low, bT)
                        float bprBot = math.max(high[2], bB)
                        if bprTop > bprBot and (bprTop - bprBot) >= bprMinSize
                            array.push(bpr_bullZoneTops, bprTop)
                            array.push(bpr_bullZoneBots, bprBot)
                            array.push(bpr_bullZoneLeft, bar_index - 1)
                            while array.size(bpr_bullZoneTops) > bpr_zone_store_cap_live
                                array.shift(bpr_bullZoneTops)
                                array.shift(bpr_bullZoneBots)
                                array.shift(bpr_bullZoneLeft)
                        break

        if bpr_rawBear
            array.push(bpr_allBearTops, low[2])
            array.push(bpr_allBearBots, high)
            if array.size(bpr_allBearTops) > bpr_gap_store_cap_live
                array.shift(bpr_allBearTops)
                array.shift(bpr_allBearBots)

            int nbull = array.size(bpr_allBullTops)
            if nbull > 0
                for bi = nbull - 1 to 0
                    float bT = array.get(bpr_allBullTops, bi)
                    float bB = array.get(bpr_allBullBots, bi)
                    bool hasOvlp = low[2] > bB and high < bT
                    if hasOvlp
                        float bprTop = math.min(low[2], bT)
                        float bprBot = math.max(high, bB)
                        if bprTop > bprBot and (bprTop - bprBot) >= bprMinSize
                            array.push(bpr_bearZoneTops, bprTop)
                            array.push(bpr_bearZoneBots, bprBot)
                            array.push(bpr_bearZoneLeft, bar_index - 1)
                            while array.size(bpr_bearZoneTops) > bpr_zone_store_cap_live
                                array.shift(bpr_bearZoneTops)
                                array.shift(bpr_bearZoneBots)
                                array.shift(bpr_bearZoneLeft)
                        break

        int bullMitSz = array.size(bpr_bullZoneTops)
        int bullMitI = bullMitSz - 1
        while bullMitI >= 0
            float topV = array.get(bpr_bullZoneTops, bullMitI)
            float botV = array.get(bpr_bullZoneBots, bullMitI)
            int leftV = array.get(bpr_bullZoneLeft, bullMitI)
            bool canMitigate = bar_index > leftV + 1
            bool mitigated = false
            if canMitigate
                mitigated := bpr_mitigationMode == "Touch" ? (low <= topV and high >= botV) : bpr_mitigationMode == "Close" ? (close <= topV and close >= botV) : low <= botV
            bool expired = bar_index > leftV + bpr_extend
            if mitigated or expired
                array.remove(bpr_bullZoneTops, bullMitI)
                array.remove(bpr_bullZoneBots, bullMitI)
                array.remove(bpr_bullZoneLeft, bullMitI)
            bullMitI -= 1

        int bearMitSz = array.size(bpr_bearZoneTops)
        int bearMitI = bearMitSz - 1
        while bearMitI >= 0
            float topV = array.get(bpr_bearZoneTops, bearMitI)
            float botV = array.get(bpr_bearZoneBots, bearMitI)
            int leftV = array.get(bpr_bearZoneLeft, bearMitI)
            bool canMitigate = bar_index > leftV + 1
            bool mitigated = false
            if canMitigate
                mitigated := bpr_mitigationMode == "Touch" ? (high >= botV and low <= topV) : bpr_mitigationMode == "Close" ? (close <= topV and close >= botV) : high >= topV
            bool expired = bar_index > leftV + bpr_extend
            if mitigated or expired
                array.remove(bpr_bearZoneTops, bearMitI)
                array.remove(bpr_bearZoneBots, bearMitI)
                array.remove(bpr_bearZoneLeft, bearMitI)
            bearMitI -= 1

        if doHeavyRender
            int bprBullUsed = 0
            int bprBearUsed = 0

            if bpr_showBull
                int bullSz = array.size(bpr_bullZoneTops)
                if bullSz > 0
                    int bullStart = bpr_renderMode == "Latest Only" ? bullSz - 1 : math.max(0, bullSz - bpr_limit_live)
                    for i = bullStart to bullSz - 1
                        bool showText = bpr_labelMode == "All Visible" or (bpr_labelMode == "Latest Only" and i == bullSz - 1)
                        string boxTxt = bpr_labelMode == "Off" ? "" : showText ? "BPR Zone" : ""
                        int leftB = array.get(bpr_bullZoneLeft, i)
                        int rightB = leftB + bpr_extend
                        float topB = array.get(bpr_bullZoneTops, i)
                        float botB = array.get(bpr_bullZoneBots, i)
                        if bprBullUsed >= array.size(bpr_bullBoxes)
                            array.push(bpr_bullBoxes, box.new(leftB, topB, rightB, botB, bgcolor=bpr_bullColor, border_color=color.new(bpr_bullColor, 100), border_width=0, text=boxTxt, text_color=color.white, text_size=bpr_label_size_val, text_halign=text.align_center, text_valign=text.align_center))
                        box bx = array.get(bpr_bullBoxes, bprBullUsed)
                        box.set_left(bx, leftB)
                        box.set_right(bx, rightB)
                        box.set_top(bx, topB)
                        box.set_bottom(bx, botB)
                        box.set_bgcolor(bx, bpr_bullColor)
                        box.set_border_color(bx, color.new(bpr_bullColor, 100))
                        box.set_border_width(bx, 0)
                        box.set_text(bx, boxTxt)
                        box.set_text_color(bx, color.white)
                        box.set_text_size(bx, bpr_label_size_val)
                        box.set_text_halign(bx, text.align_center)
                        box.set_text_valign(bx, text.align_center)
                        bprBullUsed += 1

            if bpr_showBear
                int bearSz = array.size(bpr_bearZoneTops)
                if bearSz > 0
                    int bearStart = bpr_renderMode == "Latest Only" ? bearSz - 1 : math.max(0, bearSz - bpr_limit_live)
                    for i = bearStart to bearSz - 1
                        bool showText = bpr_labelMode == "All Visible" or (bpr_labelMode == "Latest Only" and i == bearSz - 1)
                        string boxTxt = bpr_labelMode == "Off" ? "" : showText ? "BPR Zone" : ""
                        int leftB = array.get(bpr_bearZoneLeft, i)
                        int rightB = leftB + bpr_extend
                        float topB = array.get(bpr_bearZoneTops, i)
                        float botB = array.get(bpr_bearZoneBots, i)
                        if bprBearUsed >= array.size(bpr_bearBoxes)
                            array.push(bpr_bearBoxes, box.new(leftB, topB, rightB, botB, bgcolor=bpr_bearColor, border_color=color.new(bpr_bearColor, 100), border_width=0, text=boxTxt, text_color=color.white, text_size=bpr_label_size_val, text_halign=text.align_center, text_valign=text.align_center))
                        box bx = array.get(bpr_bearBoxes, bprBearUsed)
                        box.set_left(bx, leftB)
                        box.set_right(bx, rightB)
                        box.set_top(bx, topB)
                        box.set_bottom(bx, botB)
                        box.set_bgcolor(bx, bpr_bearColor)
                        box.set_border_color(bx, color.new(bpr_bearColor, 100))
                        box.set_border_width(bx, 0)
                        box.set_text(bx, boxTxt)
                        box.set_text_color(bx, color.white)
                        box.set_text_size(bx, bpr_label_size_val)
                        box.set_text_halign(bx, text.align_center)
                        box.set_text_valign(bx, text.align_center)
                        bprBearUsed += 1
            trimBoxArrayTo(bpr_bullBoxes, bprBullUsed)
            trimBoxArrayTo(bpr_bearBoxes, bprBearUsed)
    else if barstate.islast
        clearBoxArray(bpr_bullBoxes)
        clearBoxArray(bpr_bearBoxes)
        array.clear(bpr_allBullTops)
        array.clear(bpr_allBullBots)
        array.clear(bpr_allBearTops)
        array.clear(bpr_allBearBots)
        array.clear(bpr_bullZoneTops)
        array.clear(bpr_bullZoneBots)
        array.clear(bpr_bullZoneLeft)
        array.clear(bpr_bearZoneTops)
        array.clear(bpr_bearZoneBots)
        array.clear(bpr_bearZoneLeft)

    //══════════════════════════════════════════════════════════════════════════════

runLiquiditySweeps() =>
    float _liq_lastHigh = liq_lastHigh
    float _liq_lastLow = liq_lastLow
    int _liq_lastHighBar = liq_lastHighBar
    int _liq_lastLowBar = liq_lastLowBar
    bool _liq_lastHighSwept = liq_lastHighSwept
    bool _liq_lastLowSwept = liq_lastLowSwept
    int _liq_lastBearSignalBar = liq_lastBearSignalBar
    int _liq_lastBullSignalBar = liq_lastBullSignalBar
    // LIQUIDITY SWEEPS
    //══════════════════════════════════════════════════════════════════════════════
    if enableLiquidity and liq_sweeps_show
        if not na(liq_ph)
            _liq_lastHigh      := liq_ph
            _liq_lastHighBar   := bar_index - liq_pivotRightBars
            _liq_lastHighSwept := false
        if not na(liq_pl)
            _liq_lastLow       := liq_pl
            _liq_lastLowBar    := bar_index - liq_pivotRightBars
            _liq_lastLowSwept  := false

        if not na(_liq_lastHigh) and bar_index - _liq_lastHighBar > liq_maxLookbackBars
            _liq_lastHigh      := na
            _liq_lastHighSwept := false
        if not na(_liq_lastLow) and bar_index - _liq_lastLowBar > liq_maxLookbackBars
            _liq_lastLow       := na
            _liq_lastLowSwept  := false

        bool liq_showClassic = liq_sweepDisplayMode == "Classic Sweeps" or liq_sweepDisplayMode == "Both"
        bool liq_showLabelsMode = liq_sweepDisplayMode == "LG/SFP Only" or liq_sweepDisplayMode == "Both"
        bool liq_simpleText = liq_labelStyleMode == "Simple Text"
        string lgLabelSize = getLabelSize(liq_signalLabelSize)
        string sfpLabelSize = getLabelSize(liq_signalLabelSize)

        float liq_filterAtr = ta.atr(liq_filterAtrLen)
        float liq_avgVol = ta.sma(volume, 20)
        float liq_barRange = math.max(high - low, syminfo.mintick)
        float liq_bodySize = math.max(math.abs(close - open), syminfo.mintick)
        float liq_upperWick = math.max(high - math.max(open, close), 0.0)
        float liq_lowerWick = math.max(math.min(open, close) - low, 0.0)
        int liq_highAge = not na(_liq_lastHigh) ? bar_index - _liq_lastHighBar : 1000000
        int liq_lowAge = not na(_liq_lastLow) ? bar_index - _liq_lastLowBar : 1000000
        bool liq_highContextValid = not na(_liq_lastHigh) and liq_highAge >= liq_minLevelLengthBars and liq_highAge <= liq_maxLookbackBars
        bool liq_lowContextValid = not na(_liq_lastLow) and liq_lowAge >= liq_minLevelLengthBars and liq_lowAge <= liq_maxLookbackBars
        bool liq_rawBearSweep = liq_highContextValid and not _liq_lastHighSwept and high > _liq_lastHigh
        bool liq_rawBullSweep = liq_lowContextValid and not _liq_lastLowSwept and low < _liq_lastLow
        bool liq_closeBackInsideBear = liq_rawBearSweep and close < _liq_lastHigh
        bool liq_closeBackInsideBull = liq_rawBullSweep and close > _liq_lastLow
        bool liq_sfpCloseBear = liq_rawBearSweep and math.max(open, close) < _liq_lastHigh
        bool liq_sfpCloseBull = liq_rawBullSweep and math.min(open, close) > _liq_lastLow

        float liq_bearSweepSize = liq_highContextValid ? math.max(high - _liq_lastHigh, 0.0) : 0.0
        float liq_bullSweepSize = liq_lowContextValid ? math.max(_liq_lastLow - low, 0.0) : 0.0
        float liq_bearReclaim = liq_highContextValid ? math.max(_liq_lastHigh - close, 0.0) : 0.0
        float liq_bullReclaim = liq_lowContextValid ? math.max(close - _liq_lastLow, 0.0) : 0.0

        float liq_sfpSweepReq = liq_filterAtr * liq_minSweepAtr
        float liq_lgSweepReq = liq_filterAtr * (liq_minSweepAtr * (1.25 + liq_lgStrictnessBoost))
        float liq_sfpReclaimReq = liq_barRange * (liq_minReclaimPct * 0.01)
        float liq_lgReclaimReq = liq_barRange * ((liq_minReclaimPct + 5.0 + liq_lgStrictnessBoost * 10.0) * 0.01)
        float liq_sfpWickReq = liq_bodySize * liq_minWickBodyRatio
        float liq_lgWickReq = liq_bodySize * (liq_minWickBodyRatio + 0.35 + liq_lgStrictnessBoost * 0.5)

        bool liq_bearAtrOkSfp = liq_bearSweepSize >= liq_sfpSweepReq
        bool liq_bullAtrOkSfp = liq_bullSweepSize >= liq_sfpSweepReq
        bool liq_bearAtrOkLg = liq_bearSweepSize >= liq_lgSweepReq
        bool liq_bullAtrOkLg = liq_bullSweepSize >= liq_lgSweepReq
        bool liq_bearTicksOk = liq_bearSweepSize >= syminfo.mintick * liq_minSweepTicks
        bool liq_bullTicksOk = liq_bullSweepSize >= syminfo.mintick * liq_minSweepTicks
        bool liq_volumeOk = not liq_useVolumeFilter or volume >= liq_avgVol * liq_minVolumeMult
        bool liq_bearCooldownOk = na(_liq_lastBearSignalBar) or bar_index - _liq_lastBearSignalBar > liq_signalCooldownBars
        bool liq_bullCooldownOk = na(_liq_lastBullSignalBar) or bar_index - _liq_lastBullSignalBar > liq_signalCooldownBars
        bool liq_bearReclaimOkSfp = liq_bearReclaim >= liq_sfpReclaimReq
        bool liq_bullReclaimOkSfp = liq_bullReclaim >= liq_sfpReclaimReq
        bool liq_bearReclaimOkLg = liq_bearReclaim >= liq_lgReclaimReq
        bool liq_bullReclaimOkLg = liq_bullReclaim >= liq_lgReclaimReq
        bool liq_bearWickOkSfp = liq_upperWick >= liq_sfpWickReq
        bool liq_bullWickOkSfp = liq_lowerWick >= liq_sfpWickReq
        bool liq_bearWickOkLg = liq_upperWick >= liq_lgWickReq
        bool liq_bullWickOkLg = liq_lowerWick >= liq_lgWickReq

        bool liq_bearSfpValidation = switch liq_validationMode
            "Close Back Inside" => liq_closeBackInsideBear and liq_bearAtrOkSfp
            "Wick Dominance"    => liq_closeBackInsideBear and liq_bearReclaimOkSfp and liq_bearWickOkSfp
            "ATR Sweep Only"    => liq_closeBackInsideBear and liq_bearAtrOkSfp
            "Strict Confluence" => liq_closeBackInsideBear and liq_sfpCloseBear and liq_bearAtrOkSfp and liq_bearReclaimOkSfp and liq_bearWickOkSfp
            => liq_closeBackInsideBear and liq_bearAtrOkSfp and liq_bearReclaimOkSfp and liq_bearWickOkSfp
        bool liq_bullSfpValidation = switch liq_validationMode
            "Close Back Inside" => liq_closeBackInsideBull and liq_bullAtrOkSfp
            "Wick Dominance"    => liq_closeBackInsideBull and liq_bullReclaimOkSfp and liq_bullWickOkSfp
            "ATR Sweep Only"    => liq_closeBackInsideBull and liq_bullAtrOkSfp
            "Strict Confluence" => liq_closeBackInsideBull and liq_sfpCloseBull and liq_bullAtrOkSfp and liq_bullReclaimOkSfp and liq_bullWickOkSfp
            => liq_closeBackInsideBull and liq_bullAtrOkSfp and liq_bullReclaimOkSfp and liq_bullWickOkSfp

        bool liq_bearLgValidation = switch liq_validationMode
            "Close Back Inside" => liq_closeBackInsideBear and liq_bearAtrOkLg and liq_bearReclaimOkLg
            "Wick Dominance"    => liq_closeBackInsideBear and liq_bearReclaimOkLg and liq_bearWickOkLg
            "ATR Sweep Only"    => liq_closeBackInsideBear and liq_bearAtrOkLg and liq_bearReclaimOkLg
            "Strict Confluence" => liq_closeBackInsideBear and liq_bearAtrOkLg and liq_bearReclaimOkLg and liq_bearWickOkLg and liq_sfpCloseBear
            => liq_closeBackInsideBear and liq_bearAtrOkLg and liq_bearReclaimOkLg and liq_bearWickOkLg
        bool liq_bullLgValidation = switch liq_validationMode
            "Close Back Inside" => liq_closeBackInsideBull and liq_bullAtrOkLg and liq_bullReclaimOkLg
            "Wick Dominance"    => liq_closeBackInsideBull and liq_bullReclaimOkLg and liq_bullWickOkLg
            "ATR Sweep Only"    => liq_closeBackInsideBull and liq_bullAtrOkLg and liq_bullReclaimOkLg
            "Strict Confluence" => liq_closeBackInsideBull and liq_bullAtrOkLg and liq_bullReclaimOkLg and liq_bullWickOkLg and liq_sfpCloseBull
            => liq_closeBackInsideBull and liq_bullAtrOkLg and liq_bullReclaimOkLg and liq_bullWickOkLg

        bool liq_sweepBull = liq_showClassic and liq_closeBackInsideBear and liq_bearTicksOk
        bool liq_sweepBear = liq_showClassic and liq_closeBackInsideBull and liq_bullTicksOk
        bool liq_lgBearEvt = liq_showLabelsMode and liq_lg_show and liq_rawBearSweep and liq_bearLgValidation and liq_bearTicksOk and liq_volumeOk and liq_bearCooldownOk
        bool liq_lgBullEvt = liq_showLabelsMode and liq_lg_show and liq_rawBullSweep and liq_bullLgValidation and liq_bullTicksOk and liq_volumeOk and liq_bullCooldownOk
        bool liq_sfpBear   = liq_showLabelsMode and liq_sfp_show and liq_rawBearSweep and liq_sfpCloseBear and liq_bearSfpValidation and liq_bearTicksOk and liq_volumeOk and liq_bearCooldownOk
        bool liq_sfpBull   = liq_showLabelsMode and liq_sfp_show and liq_rawBullSweep and liq_sfpCloseBull and liq_bullSfpValidation and liq_bullTicksOk and liq_volumeOk and liq_bullCooldownOk

        if not liq_showClassic and barstate.islast
            clearLineArray(liq_sweepLines)
            clearBoxArray(liq_sweepBoxes)
        if not liq_showLabelsMode and barstate.islast
            clearLabelArray(liq_lgLabels)
            clearLabelArray(liq_sfpLabels)
            clearLineArray(liq_confirmLines)
            clearLineArray(liq_wickLines)

        if liq_sweepBull or liq_lgBearEvt or liq_sfpBear
            if liq_sweepBull
                line liqL_b = line.new(_liq_lastHighBar, _liq_lastHigh, bar_index, _liq_lastHigh, color=liq_buysideColor, style=liq_sweep_style_val, width=liq_sweepLineWidth)
                box  liqB_b = box.new(bar_index - 1, _liq_lastHigh, bar_index + 1, high, bgcolor=color.new(liq_buysideColor, liq_sweepBoxOpacity), border_color=color.new(liq_buysideColor, 100), border_width=0)
                array.push(liq_sweepLines, liqL_b)
                array.push(liq_sweepBoxes, liqB_b)
                while array.size(liq_sweepLines) > liq_history_live
                    line.delete(array.shift(liq_sweepLines))
                    box.delete(array.shift(liq_sweepBoxes))
            if liq_showConfirmLines and liq_showLabelsMode and (liq_lgBearEvt or liq_sfpBear)
                line bearConf = line.new(bar_index, _liq_lastHigh, bar_index + 2, _liq_lastHigh, color=liq_buysideColor, style=line.style_dotted, width=1)
                pushLineLimited(liq_confirmLines, bearConf, liq_history_live)
            if liq_showWickHighlight and liq_showLabelsMode and (liq_lgBearEvt or liq_sfpBear)
                line bearWick = line.new(bar_index, high, bar_index, math.max(open, close), color=liq_buysideColor, width=math.min(4, liq_sweepLineWidth + 1))
                pushLineLimited(liq_wickLines, bearWick, liq_history_live)
            bool showLgBear = liq_lgBearEvt and not (liq_sfpPriority and liq_sfpBear)
            if showLgBear
                label lgBearLbl = liq_simpleText ? label.new(bar_index, high, "LG", xloc=xloc.bar_index, yloc=yloc.price, style=label.style_none, color=color.new(color.black, 100), textcolor=liq_lg_bearColor, size=lgLabelSize) : label.new(bar_index, high, "LG", xloc=xloc.bar_index, yloc=yloc.price, style=label.style_label_down, color=liq_lg_bearColor, textcolor=color.white, size=lgLabelSize)
                pushLabelLimited(liq_lgLabels, lgBearLbl, liq_history_live)
            if liq_sfpBear
                label sfpBearLbl = liq_simpleText ? label.new(bar_index, high, "SFP", xloc=xloc.bar_index, yloc=yloc.price, style=label.style_none, color=color.new(color.black, 100), textcolor=liq_sfp_bearColor, size=sfpLabelSize) : label.new(bar_index, high, "SFP", xloc=xloc.bar_index, yloc=yloc.price, style=label.style_label_down, color=liq_sfp_bearColor, textcolor=color.white, size=sfpLabelSize)
                pushLabelLimited(liq_sfpLabels, sfpBearLbl, liq_history_live)
            _liq_lastHighSwept := true
            if liq_lgBearEvt or liq_sfpBear
                _liq_lastBearSignalBar := bar_index

        if liq_sweepBear or liq_lgBullEvt or liq_sfpBull
            if liq_sweepBear
                line liqL_s = line.new(_liq_lastLowBar, _liq_lastLow, bar_index, _liq_lastLow, color=liq_sellsideColor, style=liq_sweep_style_val, width=liq_sweepLineWidth)
                box  liqB_s = box.new(bar_index - 1, low, bar_index + 1, _liq_lastLow, bgcolor=color.new(liq_sellsideColor, liq_sweepBoxOpacity), border_color=color.new(liq_sellsideColor, 100), border_width=0)
                array.push(liq_sweepLines, liqL_s)
                array.push(liq_sweepBoxes, liqB_s)
                while array.size(liq_sweepLines) > liq_history_live
                    line.delete(array.shift(liq_sweepLines))
                    box.delete(array.shift(liq_sweepBoxes))
            if liq_showConfirmLines and liq_showLabelsMode and (liq_lgBullEvt or liq_sfpBull)
                line bullConf = line.new(bar_index, _liq_lastLow, bar_index + 2, _liq_lastLow, color=liq_sellsideColor, style=line.style_dotted, width=1)
                pushLineLimited(liq_confirmLines, bullConf, liq_history_live)
            if liq_showWickHighlight and liq_showLabelsMode and (liq_lgBullEvt or liq_sfpBull)
                line bullWick = line.new(bar_index, math.min(open, close), bar_index, low, color=liq_sellsideColor, width=math.min(4, liq_sweepLineWidth + 1))
                pushLineLimited(liq_wickLines, bullWick, liq_history_live)
            bool showLgBull = liq_lgBullEvt and not (liq_sfpPriority and liq_sfpBull)
            if showLgBull
                label lgBullLbl = liq_simpleText ? label.new(bar_index, low, "LG", xloc=xloc.bar_index, yloc=yloc.price, style=label.style_none, color=color.new(color.black, 100), textcolor=liq_lg_bullColor, size=lgLabelSize) : label.new(bar_index, low, "LG", xloc=xloc.bar_index, yloc=yloc.price, style=label.style_label_up, color=liq_lg_bullColor, textcolor=color.white, size=lgLabelSize)
                pushLabelLimited(liq_lgLabels, lgBullLbl, liq_history_live)
            if liq_sfpBull
                label sfpBullLbl = liq_simpleText ? label.new(bar_index, low, "SFP", xloc=xloc.bar_index, yloc=yloc.price, style=label.style_none, color=color.new(color.black, 100), textcolor=liq_sfp_bullColor, size=sfpLabelSize) : label.new(bar_index, low, "SFP", xloc=xloc.bar_index, yloc=yloc.price, style=label.style_label_up, color=liq_sfp_bullColor, textcolor=color.white, size=sfpLabelSize)
                pushLabelLimited(liq_sfpLabels, sfpBullLbl, liq_history_live)
            _liq_lastLowSwept := true
            if liq_lgBullEvt or liq_sfpBull
                _liq_lastBullSignalBar := bar_index
    else if barstate.islast
        clearLineArray(liq_sweepLines)
        clearBoxArray(liq_sweepBoxes)
        clearLineArray(liq_confirmLines)
        clearLineArray(liq_wickLines)
        clearLabelArray(liq_lgLabels)
        clearLabelArray(liq_sfpLabels)

    [_liq_lastHigh, _liq_lastLow, _liq_lastHighBar, _liq_lastLowBar, _liq_lastHighSwept, _liq_lastLowSwept, _liq_lastBearSignalBar, _liq_lastBullSignalBar]

// SUPPORT / RESISTANCE
//══════════════════════════════════════════════════════════════════════════════
drawFlipLabel(int x, string txt, color clr, string shapeStr, string posStr, string sizeStr, float priceY, int dir, color txtColor) =>
    string defaultStyle = dir == 1 ? label.style_arrowup : label.style_arrowdown
    string lStyle = getLabelShape(shapeStr, defaultStyle)
    string lSz    = getLabelSize(sizeStr)
    label newLbl = na
    if posStr == "abovebar"
        newLbl := label.new(x, priceY, txt, xloc=xloc.bar_index, yloc=yloc.abovebar, color=clr, textcolor=txtColor, style=lStyle, size=lSz)
    else if posStr == "belowbar"
        newLbl := label.new(x, priceY, txt, xloc=xloc.bar_index, yloc=yloc.belowbar, color=clr, textcolor=txtColor, style=lStyle, size=lSz)
    else if posStr == "high"
        newLbl := label.new(x, high, txt, xloc=xloc.bar_index, yloc=yloc.price, color=clr, textcolor=txtColor, style=lStyle, size=lSz)
    else if posStr == "low"
        newLbl := label.new(x, low, txt, xloc=xloc.bar_index, yloc=yloc.price, color=clr, textcolor=txtColor, style=lStyle, size=lSz)
    else
        newLbl := label.new(x, priceY, txt, xloc=xloc.bar_index, yloc=yloc.price, color=clr, textcolor=txtColor, style=lStyle, size=lSz)
    pushLabelLimited(dsr_event_labels, newLbl, 250)


// Support & Resistance engine (local only)
// Support & Resistance engine reference block
var array<dsrSrLevel> dsr_sr_levels = array.new<dsrSrLevel>()
var array<label> dsr_sr_breakLabels = array.new<label>()
var array<label> dsr_sr_sweepLabels = array.new<label>()
// dsrSrSensInt declared above for shared local/MTF S/R engine
float dsrSrGlobalAtr = ta.atr(int(dsr_sr_atrPeriod_input))
float dsrSrCumRange  = ta.cum(math.abs(high - low))
// (6 cálculos ta.* muertos eliminados — dsrSrDonch*/dsrSrCsid* no se usaban)

dsr_sr_get_atr() =>
    float res = dsrSrGlobalAtr
    if na(res)
        res := dsrSrCumRange / (bar_index + 1)
    res

dsr_sr_format_val(float val) =>
    if val >= 1000000000
        str.format("{0,number,#.#}B", val / 1000000000)
    else if val >= 1000000
        str.format("{0,number,#.#}M", val / 1000000)
    else if val >= 1000
        str.format("{0,number,#.#}K", val / 1000)
    else
        str.tostring(val, "#.#")

dsr_sr_handle_structure(float top, float btm, float base, int start, bool isSup, string overlapMode) =>
    bool shouldAdd = true
    int sz = array.size(dsr_sr_levels)
    if sz > 0
        for i = sz - 1 to 0
            dsrSrLevel l = array.get(dsr_sr_levels, i)
            if not l.isMitigated and not l.isUserHidden and l.isSupport == isSup
                bool overlaps = math.max(btm, l.btm) < math.min(top, l.top)
                if overlaps
                    if overlapMode == "Hide Overlapping (Oldest Precedence)"
                        shouldAdd := false
                        break
                    else if overlapMode == "Hide Overlapping (Youngest Precedence)"
                        l.isUserHidden := true
                        array.set(dsr_sr_levels, i, l)
                    else if overlapMode == "Merge Overlapping"
                        l.top := math.max(l.top, top)
                        l.btm := math.min(l.btm, btm)
                        array.set(dsr_sr_levels, i, l)
                        shouldAdd := false
                        break
    if shouldAdd
        array.unshift(dsr_sr_levels, dsrSrLevel.new(top, btm, base, start, 0, isSup, false, false, 0, 0, 0, 0.0, na, na, na))
        true
    else
        false


// (_dsr_* variables, dsr_handle, legacy S/R block — todo eliminado, solo se usa el motor activo)
// dsrSrSignalBundle declared above for shared local/MTF S/R engine

// ===== Support & Resistance local engine (shared detection motor with HTF) =====
if dsr_sr_engine_enabled
    [srSupEvtCur, srSupTopCur, srSupBotCur, srSupBaseCur, srSupTimeCur, srResEvtCur, srResTopCur, srResBotCur, srResBaseCur, srResTimeCur, _dsrCurO, _dsrCurH, _dsrCurL, _dsrCurC, _dsrCurV] = dsrSrSignalBundle(dsr_detectionMethod_input, dsrSrSensInt, dsr_swingSensitivity_input, dsr_zoneDepth_input, dsr_sr_breakoutBuffer_input, int(dsr_sr_atrPeriod_input))
    int srPhBar = na
    int srPlBar = na
    if srResEvtCur == 1 and not na(srResTimeCur)
        for j = 0 to math.min(bar_index, 500)
            if time[j] == srResTimeCur
                srPhBar := bar_index - j
                break
    if srSupEvtCur == 1 and not na(srSupTimeCur)
        for j = 0 to math.min(bar_index, 500)
            if time[j] == srSupTimeCur
                srPlBar := bar_index - j
                break

    if srResEvtCur == 1 and not na(srPhBar)
        dsr_sr_handle_structure(srResTopCur, srResBotCur, srResBaseCur, srPhBar, false, dsr_overlapMode_input)
    if srSupEvtCur == 1 and not na(srPlBar)
        dsr_sr_handle_structure(srSupTopCur, srSupBotCur, srSupBaseCur, srPlBar, true, dsr_overlapMode_input)

    if array.size(dsr_sr_levels) > 50
        array.pop(dsr_sr_levels)

    array.clear(dsr_visible_tops)
    array.clear(dsr_visible_bottoms)
    array.clear(dsr_visible_biases)
    dsr_visible_above_used := 0
    dsr_visible_below_used := 0
    int activeTotalSr = 0
    int srAboveUsed = 0
    int srBelowUsed = 0
    int srLineUsed = 0
    int srBoxUsed = 0
    int srLabelUsed = 0
    string _szSREngine = dsr_labelSize == "Tiny" ? size.tiny : dsr_labelSize == "Small" ? size.small : dsr_labelSize == "Normal" ? size.normal : size.large

    if array.size(dsr_sr_levels) > 0
        for i = 0 to array.size(dsr_sr_levels) - 1
            dsrSrLevel l = array.get(dsr_sr_levels, i)
            if not l.isMitigated
                if l.isSupport
                    if close < l.btm
                        l.isMitigated := true
                        l.mitigationBar := bar_index
                    else
                        if high >= l.btm and low <= l.top
                            l.tradedVolume += volume
                        if low <= l.top and close >= l.btm
                            l.entries += 1
                        if low < l.btm and math.min(close, open) > l.btm
                            l.sweeps += 1
                else
                    if close > l.top
                        l.isMitigated := true
                        l.mitigationBar := bar_index
                    else
                        if high >= l.btm and low <= l.top
                            l.tradedVolume += volume
                        if high >= l.btm and close <= l.top
                            l.entries += 1
                        if high > l.top and math.max(close, open) < l.top
                            l.sweeps += 1

            int curD = l.isMitigated ? l.mitigationBar - l.startBar : bar_index - l.startBar
            bool meets = l.entries >= dsr_sr_minEntries_input and l.strength >= dsr_sr_minStrength_input and l.sweeps >= dsr_sr_minSweeps_input and l.tradedVolume >= dsr_sr_minVolume_input and curD >= dsr_sr_minDuration_input and not l.isUserHidden
            bool show = false
            float boxMid = (l.top + l.btm) / 2.0
            bool isAbove = boxMid >= close
            bool allowSide = isAbove ? srAboveUsed < dsr_visibleAbove_input : srBelowUsed < dsr_visibleBelow_input
            if meets
                if not l.isMitigated and activeTotalSr < dsr_maxLevels_input and allowSide
                    show := true
                    activeTotalSr += 1
                    if isAbove
                        srAboveUsed += 1
                    else
                        srBelowUsed += 1
                else if l.isMitigated and dsr_sr_showBroken_input and allowSide
                    show := true
                    if isAbove
                        srAboveUsed += 1
                    else
                        srBelowUsed += 1

            if show
                int lBias = l.isSupport ? 1 : -1
                array.push(dsr_visible_tops, l.top)
                array.push(dsr_visible_bottoms, l.btm)
                array.push(dsr_visible_biases, lBias)
                if isAbove
                    dsr_visible_above_used += 1
                else
                    dsr_visible_below_used += 1
                int endB = l.isMitigated ? l.mitigationBar : (dsr_sr_extend_input ? bar_index + 25 : bar_index)
                color c = l.isSupport ? dsr_supportColor : dsr_resistColor
                color zoneCoreC = solidColor(c)
                float zoneBaseT = color.t(c)
                float zoneFillT = l.isMitigated ? math.min(100.0, zoneBaseT + 45.0) : zoneBaseT
                color zoneFill = color.new(zoneCoreC, int(math.round(zoneFillT)))
                color lineColor = color.new(zoneCoreC, math.max(0, zoneBaseT - 10))
                int drawStart = math.max(l.startBar, bar_index - 4900)
                [dispTop, dispBot] = dsrRenderBand(l.top, l.btm, l.basePrice)
                float srBoxMid = math.avg(dispTop, dispBot)
                string zoneExtend = l.isMitigated ? extend.none : (dsr_sr_extend_input ? extend.right : extend.none)
                string lTfList = dsrCombinedTfListLocal(l.top, l.btm, l.basePrice, lBias)
                string lTxt = l.isSupport ? (str.length(lTfList) > 0 ? "SUPPORT [" + lTfList + "]" : "SUPPORT") : (str.length(lTfList) > 0 ? "RESISTANCE [" + lTfList + "]" : "RESISTANCE")
                if dsr_displayType_input == "Zones"
                    if srBoxUsed >= array.size(dsr_boxes)
                        array.push(dsr_boxes, box.new(drawStart, dispTop, endB, dispBot, border_color=na, bgcolor=zoneFill, border_width=0, extend=zoneExtend, text=dsr_showLabels ? lTxt : "", text_color=dsr_labelColor, text_size=_szSREngine, text_halign=text.align_left, text_valign=text.align_center))
                    box bx = array.get(dsr_boxes, srBoxUsed)
                    box.set_left(bx, drawStart)
                    box.set_top(bx, dispTop)
                    box.set_right(bx, endB)
                    box.set_bottom(bx, dispBot)
                    box.set_bgcolor(bx, zoneFill)
                    box.set_border_color(bx, na)
                    box.set_border_width(bx, 0)
                    box.set_extend(bx, zoneExtend)
                    box.set_text(bx, dsr_showLabels ? lTxt : "")
                    box.set_text_color(bx, dsr_labelColor)
                    box.set_text_size(bx, _szSREngine)
                    box.set_text_halign(bx, text.align_left)
                    box.set_text_valign(bx, text.align_center)
                    srBoxUsed += 1
                else
                    if srLineUsed >= array.size(dsr_lines_arr)
                        array.push(dsr_lines_arr, line.new(drawStart, l.basePrice, endB, l.basePrice, extend=zoneExtend, color=lineColor, width=1))
                    line ln = array.get(dsr_lines_arr, srLineUsed)
                    line.set_x1(ln, drawStart)
                    line.set_y1(ln, l.basePrice)
                    line.set_x2(ln, endB)
                    line.set_y2(ln, l.basePrice)
                    line.set_color(ln, lineColor)
                    line.set_width(ln, 1)
                    line.set_extend(ln, zoneExtend)
                    srLineUsed += 1
                    if dsr_showLabels
                        int labelX = math.min(endB, bar_index)
                        if srLabelUsed >= array.size(dsr_labels_arr)
                            array.push(dsr_labels_arr, label.new(labelX, srBoxMid, lTxt, xloc=xloc.bar_index, yloc=yloc.price, style=label.style_label_left, color=color.new(color.black,100), textcolor=dsr_labelColor, size=_szSREngine))
                        label lb = array.get(dsr_labels_arr, srLabelUsed)
                        label.set_x(lb, labelX)
                        label.set_y(lb, srBoxMid)
                        label.set_text(lb, lTxt)
                        label.set_style(lb, label.style_label_left)
                        label.set_color(lb, color.new(color.black,100))
                        label.set_textcolor(lb, dsr_labelColor)
                        label.set_size(lb, _szSREngine)
                        srLabelUsed += 1

                if not na(l.statsLabel)
                    label.delete(l.statsLabel)
                    l.statsLabel := na
            else
                if not na(l.lineId)
                    line.delete(l.lineId)
                    l.lineId := na
                if not na(l.boxId)
                    box.delete(l.boxId)
                    l.boxId := na
                if not na(l.statsLabel)
                    label.delete(l.statsLabel)
                    l.statsLabel := na

            array.set(dsr_sr_levels, i, l)

    trimLineArrayTo(dsr_lines_arr, dsr_displayType_input == "Zones" ? 0 : srLineUsed)
    trimBoxArrayTo(dsr_boxes, dsr_displayType_input == "Zones" ? srBoxUsed : 0)
    trimLabelArrayTo(dsr_labels_arr, dsr_showLabels and dsr_displayType_input != "Zones" ? srLabelUsed : 0)

else if barstate.islast
    clearBoxArray(dsr_boxes)
    clearLabelArray(dsr_labels_arr)
    clearLineArray(dsr_lines_arr)
    clearLineArray(dsr_break_lines)
    clearLabelArray(dsr_event_labels)

//══════════════════════════════════════════════════════════════════════════════
// MTF S/R + OB OVERLAY
//══════════════════════════════════════════════════════════════════════════════
[_mtfSrAboveUsed, _mtfSrBelowUsed] = runMtfSrOverlay(dsr_visible_above_used, dsr_visible_below_used)
[_mtfObAboveUsed, _mtfObBelowUsed] = runMtfObOverlay(ob_visible_above_used, ob_visible_below_used)
runLiquidityPoolsOverlay()
runLiquidityVoidsOverlay()
runBprOverlay()

// MARKET STRUCTURE
//══════════════════════════════════════════════════════════════════════════════
if enableStruct
    if not na(struct_ph)
        struct_lastHigh       := struct_ph
        struct_lastHighBar    := bar_index - struct_pivotLen
        struct_lastHighBroken := false
    if not na(struct_pl)
        struct_lastLow        := struct_pl
        struct_lastLowBar     := bar_index - struct_pivotLen
        struct_lastLowBroken  := false

    bool struct_crossHighRaw = ta.crossover(close, nz(struct_lastHigh, 10e10))
    bool struct_crossLowRaw  = ta.crossunder(close, nz(struct_lastLow, -10e10))
    bool struct_brkHigh      = not na(struct_lastHigh) and struct_crossHighRaw and not struct_lastHighBroken
    bool struct_brkLow       = not na(struct_lastLow) and struct_crossLowRaw and not struct_lastLowBroken

    string structLblSize = getLabelSize(struct_labelSize)

    if struct_brkHigh and (na(struct_lastBreakBar) or bar_index > struct_lastBreakBar)
        struct_lastBreakBar      := bar_index
        struct_lastBreakDir      := 1
        struct_lastBreakExtreme  := high
        struct_lastOppBar        := struct_lastLowBar
        struct_lastOppPrice      := struct_lastLow

        bool isBOS_H   = struct_trendInit and struct_trendBull
        bool isCHoCH_H = struct_trendInit and not struct_trendBull
        bool isMSS_H   = not struct_trendInit
        string structTextH = isCHoCH_H ? "CHoCH" : isMSS_H ? "MSS" : "BOS"
        bool allowStructH = isCHoCH_H ? struct_showCHoCH : isMSS_H ? struct_showMSS : struct_showBOS
        string structStyleH = isCHoCH_H ? sLineStyle(struct_chochStyle) : isMSS_H ? sLineStyle(struct_mssStyle) : sLineStyle(struct_lineStyle)

        if allowStructH
            line sl_h = line.new(struct_lastHighBar, struct_lastHigh, bar_index, struct_lastHigh, color=struct_bullColor, style=structStyleH, width=struct_lineWidth)
            array.push(struct_lines, sl_h)
            if struct_showLabels
                label lbl_h = label.new(int(math.avg(struct_lastHighBar, bar_index)), struct_lastHigh, structTextH, color=color.new(color.black, 100), textcolor=struct_bullColor, style=label.style_none, size=structLblSize)
                array.push(struct_labels, lbl_h)
        if array.size(struct_lines) > 60
            line.delete(array.shift(struct_lines))
        if array.size(struct_labels) > 60
            label.delete(array.shift(struct_labels))

        struct_trendBull      := true
        struct_trendInit      := true
        struct_lastHighBroken := true

    if struct_brkLow and (na(struct_lastBreakBar) or bar_index > struct_lastBreakBar)
        struct_lastBreakBar      := bar_index
        struct_lastBreakDir      := -1
        struct_lastBreakExtreme  := low
        struct_lastOppBar        := struct_lastHighBar
        struct_lastOppPrice      := struct_lastHigh

        bool isBOS_L   = struct_trendInit and not struct_trendBull
        bool isCHoCH_L = struct_trendInit and struct_trendBull
        bool isMSS_L   = not struct_trendInit
        string structTextL = isCHoCH_L ? "CHoCH" : isMSS_L ? "MSS" : "BOS"
        bool allowStructL = isCHoCH_L ? struct_showCHoCH : isMSS_L ? struct_showMSS : struct_showBOS
        string structStyleL = isCHoCH_L ? sLineStyle(struct_chochStyle) : isMSS_L ? sLineStyle(struct_mssStyle) : sLineStyle(struct_lineStyle)

        if allowStructL
            line sl_l = line.new(struct_lastLowBar, struct_lastLow, bar_index, struct_lastLow, color=struct_bearColor, style=structStyleL, width=struct_lineWidth)
            array.push(struct_lines, sl_l)
            if struct_showLabels
                label lbl_l = label.new(int(math.avg(struct_lastLowBar, bar_index)), struct_lastLow, structTextL, color=color.new(color.black, 100), textcolor=struct_bearColor, style=label.style_none, size=structLblSize)
                array.push(struct_labels, lbl_l)
        if array.size(struct_lines) > 60
            line.delete(array.shift(struct_lines))
        if array.size(struct_labels) > 60
            label.delete(array.shift(struct_labels))

        struct_trendBull     := false
        struct_trendInit     := true
        struct_lastLowBroken := true

    if struct_lastBreakDir == 1 and high > struct_lastBreakExtreme
        struct_lastBreakExtreme := high
        struct_lastBreakBar := bar_index
    if struct_lastBreakDir == -1 and low < struct_lastBreakExtreme
        struct_lastBreakExtreme := low
        struct_lastBreakBar := bar_index
else if barstate.islast
    clearLineArray(struct_lines)
    clearLabelArray(struct_labels)

//══════════════════════════════════════════════════════════════════════════════
// PREMIUM / DISCOUNT ZONES — Trailing Swing Calculation (Patch C1)
//══════════════════════════════════════════════════════════════════════════════
if enableLiquidity and liq_zone_show
    float _liq_zone_ph = ta.pivothigh(high, liq_zone_swingLen, liq_zone_swingLen)
    float _liq_zone_pl = ta.pivotlow(low, liq_zone_swingLen, liq_zone_swingLen)
    if not na(_liq_zone_ph)
        liq_trailingTop      := _liq_zone_ph
        liq_trailingBarTime  := time[liq_zone_swingLen]
        liq_trailingBarIndex := bar_index - liq_zone_swingLen
    if not na(_liq_zone_pl)
        liq_trailingBottom   := _liq_zone_pl
        if na(liq_trailingBarTime)
            liq_trailingBarTime  := time[liq_zone_swingLen]
            liq_trailingBarIndex := bar_index - liq_zone_swingLen

if enableLiquidity and liq_zone_show
    bool zoneReady = not na(liq_trailingTop) and not na(liq_trailingBottom) and liq_trailingTop > liq_trailingBottom and not na(liq_trailingBarTime)

    if zoneReady and doHeavyRender
        float premiumTop        = liq_trailingTop
        float premiumBottom     = 0.95 * liq_trailingTop + 0.05 * liq_trailingBottom
        float equilibriumTop    = 0.525 * liq_trailingTop + 0.475 * liq_trailingBottom
        float equilibriumBottom = 0.525 * liq_trailingBottom + 0.475 * liq_trailingTop
        float discountTop       = 0.95 * liq_trailingBottom + 0.05 * liq_trailingTop
        float discountBottom    = liq_trailingBottom

        int zoneLeftTime  = liq_trailingBarTime
        int zoneRightTime = last_bar_time + (liq_zone_extendBars * 2) * nz(time - time[1], 60000)
        int zoneMidTime   = zoneLeftTime + int(math.floor((zoneRightTime - zoneLeftTime) * 0.5))

        color premiumFill  = color.new(solidColor(liq_zone_premiumColor), 80)
        color eqFill       = color.new(solidColor(liq_zone_eqColor), 80)
        color discountFill = color.new(solidColor(liq_zone_discountColor), 80)

        if na(liq_premiumBox)
            liq_premiumBox := box.new(zoneLeftTime, premiumTop, zoneRightTime, premiumBottom, xloc=xloc.bar_time, bgcolor=premiumFill, border_color=na)
        else
            box.set_left(liq_premiumBox, zoneLeftTime)
            box.set_right(liq_premiumBox, zoneRightTime)
            box.set_top(liq_premiumBox, premiumTop)
            box.set_bottom(liq_premiumBox, premiumBottom)
            box.set_bgcolor(liq_premiumBox, premiumFill)
            box.set_border_color(liq_premiumBox, na)

        if na(liq_eqBox)
            liq_eqBox := box.new(zoneLeftTime, equilibriumTop, zoneRightTime, equilibriumBottom, xloc=xloc.bar_time, bgcolor=eqFill, border_color=na)
        else
            box.set_left(liq_eqBox, zoneLeftTime)
            box.set_right(liq_eqBox, zoneRightTime)
            box.set_top(liq_eqBox, equilibriumTop)
            box.set_bottom(liq_eqBox, equilibriumBottom)
            box.set_bgcolor(liq_eqBox, eqFill)
            box.set_border_color(liq_eqBox, na)

        if na(liq_discountBox)
            liq_discountBox := box.new(zoneLeftTime, discountTop, zoneRightTime, discountBottom, xloc=xloc.bar_time, bgcolor=discountFill, border_color=na)
        else
            box.set_left(liq_discountBox, zoneLeftTime)
            box.set_right(liq_discountBox, zoneRightTime)
            box.set_top(liq_discountBox, discountTop)
            box.set_bottom(liq_discountBox, discountBottom)
            box.set_bgcolor(liq_discountBox, discountFill)
            box.set_border_color(liq_discountBox, na)

        box.set_text(liq_premiumBox, "")
        box.set_text(liq_eqBox, "")
        box.set_text(liq_discountBox, "")

        if liq_zone_showLabels
            if na(liq_premiumLbl)
                liq_premiumLbl := label.new(zoneMidTime, math.avg(premiumTop, premiumBottom), "Premium", xloc=xloc.bar_time, yloc=yloc.price, style=label.style_label_center, color=color.new(color.black, 100), textcolor=color.white, size=liq_aux_label_size_val, textalign=text.align_center)
            else
                label.set_x(liq_premiumLbl, zoneMidTime)
                label.set_y(liq_premiumLbl, math.avg(premiumTop, premiumBottom))
                label.set_text(liq_premiumLbl, "Premium")
                label.set_size(liq_premiumLbl, liq_aux_label_size_val)

            if na(liq_eqLbl)
                liq_eqLbl := label.new(zoneMidTime, math.avg(equilibriumTop, equilibriumBottom), "Equilibrium", xloc=xloc.bar_time, yloc=yloc.price, style=label.style_label_center, color=color.new(color.black, 100), textcolor=color.white, size=liq_aux_label_size_val, textalign=text.align_center)
            else
                label.set_x(liq_eqLbl, zoneMidTime)
                label.set_y(liq_eqLbl, math.avg(equilibriumTop, equilibriumBottom))
                label.set_text(liq_eqLbl, "Equilibrium")
                label.set_size(liq_eqLbl, liq_aux_label_size_val)

            if na(liq_discountLbl)
                liq_discountLbl := label.new(zoneMidTime, math.avg(discountTop, discountBottom), "Discount", xloc=xloc.bar_time, yloc=yloc.price, style=label.style_label_center, color=color.new(color.black, 100), textcolor=color.white, size=liq_aux_label_size_val, textalign=text.align_center)
            else
                label.set_x(liq_discountLbl, zoneMidTime)
                label.set_y(liq_discountLbl, math.avg(discountTop, discountBottom))
                label.set_text(liq_discountLbl, "Discount")
                label.set_size(liq_discountLbl, liq_aux_label_size_val)
        else
            if not na(liq_premiumLbl)
                label.delete(liq_premiumLbl)
                liq_premiumLbl := na
            if not na(liq_eqLbl)
                label.delete(liq_eqLbl)
                liq_eqLbl := na
            if not na(liq_discountLbl)
                label.delete(liq_discountLbl)
                liq_discountLbl := na
else
    if not na(liq_premiumBox)
        box.delete(liq_premiumBox)
        liq_premiumBox := na
    if not na(liq_eqBox)
        box.delete(liq_eqBox)
        liq_eqBox := na
    if not na(liq_discountBox)
        box.delete(liq_discountBox)
        liq_discountBox := na
    if not na(liq_premiumLbl)
        label.delete(liq_premiumLbl)
        liq_premiumLbl := na
    if not na(liq_eqLbl)
        label.delete(liq_eqLbl)
        liq_eqLbl := na
    if not na(liq_discountLbl)
        label.delete(liq_discountLbl)
        liq_discountLbl := na

//══════════════════════════════════════════════════════════════════════════════
// LIQUIDITY POOLS / VOIDS / BPR
//══════════════════════════════════════════════════════════════════════════════
// Already handled inside runMtfOverlay()

// LIQUIDITY SWEEPS
//══════════════════════════════════════════════════════════════════════════════
[_liq_lastHigh_r, _liq_lastLow_r, _liq_lastHighBar_r, _liq_lastLowBar_r, _liq_lastHighSwept_r, _liq_lastLowSwept_r, _liq_lastBearSignalBar_r, _liq_lastBullSignalBar_r] = runLiquiditySweeps()
liq_lastHigh := _liq_lastHigh_r
liq_lastLow := _liq_lastLow_r
liq_lastHighBar := _liq_lastHighBar_r
liq_lastLowBar := _liq_lastLowBar_r
liq_lastHighSwept := _liq_lastHighSwept_r
liq_lastLowSwept := _liq_lastLowSwept_r
liq_lastBearSignalBar := _liq_lastBearSignalBar_r
liq_lastBullSignalBar := _liq_lastBullSignalBar_r
