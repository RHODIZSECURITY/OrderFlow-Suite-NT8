//@version=6
indicator(
     title            = "SMC / ICT Suite Pro v25 Stable MTF Overlay v10.11p1",
     shorttitle       = "SMC / ICT Suite Pro v25 v10.11p1",
     overlay          = true,
     precision        = 4,
     max_lines_count  = 300,
     max_labels_count = 300,
     max_boxes_count  = 300,
     max_bars_back    = 3000)

//══════════════════════════════════════════════════════════════════════════════
// HELPERS
//══════════════════════════════════════════════════════════════════════════════
getLineStyle(style) =>
    style == "⎯⎯⎯" ? line.style_solid : style == "---" ? line.style_dashed : line.style_dotted

sLineStyle(string s) =>
    s == "Dotted" ? line.style_dotted : s == "Dashed" ? line.style_dashed : line.style_solid

getLineWeight(w) =>
    w == "─" ? 1 : w == "━━" ? 2 : w == "━━━" ? 3 : 4

getLabelSize(s) =>
    s == "Tiny" ? size.tiny : s == "Small" ? size.small : s == "Medium" ? size.normal : s == "Large" ? size.large : size.huge

getLabelShape(shapeStr, defaultStyle) =>
    switch shapeStr
        "triangleup"   => label.style_triangleup
        "triangledown" => label.style_triangledown
        "arrowup"      => label.style_arrowup
        "arrowdown"    => label.style_arrowdown
        "flag"         => label.style_flag
        "circle"       => label.style_circle
        "square"       => label.style_square
        "diamond"      => label.style_diamond
        "xcross"       => label.style_xcross
        "label_up"     => label.style_label_up
        "label_down"   => label.style_label_down
        => defaultStyle

ma_bb(source, length, _type) =>
    switch _type
        "SMA"        => ta.sma(source, length)
        "EMA"        => ta.ema(source, length)
        "SMMA (RMA)" => ta.rma(source, length)
        "WMA"        => ta.wma(source, length)
        "VWMA"       => ta.vwma(source, length)

fmtVol(float v) =>
    v >= 1000000 ? str.tostring(v / 1000000, "#.##") + "M" : v >= 1000 ? str.tostring(v / 1000, "#.##") + "K" : str.tostring(v, "#")

safe_div(float num, float den) =>
    den != 0 ? num / den : 0.0


solidColor(color c) =>
    color.rgb(color.r(c), color.g(c), color.b(c))

pushLabelLimited(array<label> arr, label lb, int maxCount) =>
    if not na(lb)
        array.push(arr, lb)
        while array.size(arr) > maxCount
            label oldLb = array.shift(arr)
            if not na(oldLb)
                label.delete(oldLb)

pushLineLimited(array<line> arr, line ln, int maxCount) =>
    if not na(ln)
        array.push(arr, ln)
        while array.size(arr) > maxCount
            line oldLn = array.shift(arr)
            if not na(oldLn)
                line.delete(oldLn)

clearBoxArray(array<box> arr) =>
    int sz = array.size(arr)
    if sz > 0
        for i = 0 to sz - 1
            box b = array.get(arr, i)
            if not na(b)
                box.delete(b)
    array.clear(arr)

clearLineArray(array<line> arr) =>
    int sz = array.size(arr)
    if sz > 0
        for i = 0 to sz - 1
            line ln = array.get(arr, i)
            if not na(ln)
                line.delete(ln)
    array.clear(arr)

clearLabelArray(array<label> arr) =>
    int sz = array.size(arr)
    if sz > 0
        for i = 0 to sz - 1
            label lb = array.get(arr, i)
            if not na(lb)
                label.delete(lb)
    array.clear(arr)

getPriceSrc(string srcName) =>
    switch srcName
        "HL2"   => hl2
        "HLC3"  => hlc3
        "OHLC4" => ohlc4
        "Close" => close
        => hlc3

obOverlapRatio(float aH, float aL, float bH, float bL) =>
    float overlapSz = math.max(0.0, math.min(aH, bH) - math.max(aL, bL))
    float minSz     = math.min(aH - aL, bH - bL)
    minSz > 0 ? overlapSz / minSz : 0.0

obInside(float innerH, float innerL, float outerH, float outerL) =>
    innerH <= outerH and innerL >= outerL

srZonesNearOrOverlap(float top1, float btm1, float top2, float btm2, float tol) =>
    math.max(btm1, btm2) <= math.min(top1, top2) + tol

tfPretty(string tf) =>
    string u = str.upper(tf)
    string out = u
    if str.length(u) == 0
        out := ""
    else
        float tfNum = str.tonumber(u)
        if not na(tfNum)
            int tfInt = int(tfNum)
            if tfInt >= 1440 and tfInt % 1440 == 0
                out := str.tostring(int(tfInt / 1440)) + "D"
            else if tfInt >= 60 and tfInt % 60 == 0
                out := str.tostring(int(tfInt / 60)) + "H"
            else
                out := str.tostring(tfInt) + "M"
    out

mtfContainedRatio(float lowerTop, float lowerBot, float higherTop, float higherBot) =>
    float overlapSz = math.max(0.0, math.min(lowerTop, higherTop) - math.max(lowerBot, higherBot))
    float lowerSz = math.max(lowerTop - lowerBot, syminfo.mintick)
    overlapSz / lowerSz

mtfZoneOverlapRatio(float top1, float bot1, float top2, float bot2) =>
    float overlapSz = math.max(0.0, math.min(top1, top2) - math.max(bot1, bot2))
    float minSz = math.max(math.min(top1 - bot1, top2 - bot2), syminfo.mintick)
    overlapSz / minSz

obMtfNestedHit(float lowTop, float lowBot, float highTop, float highBot, float nestedThreshold) =>
    float ratioLocalInHtf = mtfContainedRatio(lowTop, lowBot, highTop, highBot)
    float ratioHtfInLocal = mtfContainedRatio(highTop, highBot, lowTop, lowBot)
    float ratioOverlap = obOverlapRatio(lowTop, lowBot, highTop, highBot)
    math.max(math.max(ratioLocalInHtf, ratioHtfInLocal), ratioOverlap) >= nestedThreshold

mtfPriorityMatch(float lowTop, float lowBot, float highTop, float highBot, float nestedThreshold) =>
    float ratioLocalInHtf = mtfContainedRatio(lowTop, lowBot, highTop, highBot)
    float ratioHtfInLocal = mtfContainedRatio(highTop, highBot, lowTop, lowBot)
    float ratioOverlap = mtfZoneOverlapRatio(lowTop, lowBot, highTop, highBot)
    float lowSz = math.max(lowTop - lowBot, syminfo.mintick)
    float highSz = math.max(highTop - highBot, syminfo.mintick)
    float refSz = math.max(math.min(lowSz, highSz), syminfo.mintick)
    float midLow = math.avg(lowTop, lowBot)
    float midHigh = math.avg(highTop, highBot)
    float topGapRatio = math.abs(lowTop - highTop) / refSz
    float botGapRatio = math.abs(lowBot - highBot) / refSz
    float midGapRatio = math.abs(midLow - midHigh) / refSz
    float edgeLimit = math.max(0.25, 1.0 - nestedThreshold + 0.22)
    float centerLimit = math.max(0.18, 1.0 - nestedThreshold + 0.18)
    bool similarEnvelope = topGapRatio <= edgeLimit and botGapRatio <= edgeLimit
    bool similarCenter = midGapRatio <= centerLimit and (topGapRatio <= edgeLimit or botGapRatio <= edgeLimit)
    math.max(math.max(ratioLocalInHtf, ratioHtfInLocal), ratioOverlap) >= nestedThreshold or similarEnvelope or similarCenter


mtfRepresentationMatch(float lowTop, float lowBot, float highTop, float highBot, float nestedThreshold) =>
    float ratioOverlap = mtfZoneOverlapRatio(lowTop, lowBot, highTop, highBot)
    float lowSz = math.max(lowTop - lowBot, syminfo.mintick)
    float highSz = math.max(highTop - highBot, syminfo.mintick)
    float refSz = math.max(math.min(lowSz, highSz), syminfo.mintick)
    float sizeRatio = math.max(lowSz, highSz) / math.max(math.min(lowSz, highSz), syminfo.mintick)
    float midLow = math.avg(lowTop, lowBot)
    float midHigh = math.avg(highTop, highBot)
    float topGapRatio = math.abs(lowTop - highTop) / refSz
    float botGapRatio = math.abs(lowBot - highBot) / refSz
    float midGapRatio = math.abs(midLow - midHigh) / refSz
    float edgeLimit = math.max(0.16, 1.0 - nestedThreshold + 0.06)
    float centerLimit = math.max(0.12, 1.0 - nestedThreshold + 0.04)
    float overlapLimit = math.max(0.45, nestedThreshold - 0.15)
    bool similarEnvelope = topGapRatio <= edgeLimit and botGapRatio <= edgeLimit
    bool similarCenter = midGapRatio <= centerLimit
    bool comparableSize = sizeRatio <= 2.4
    ratioOverlap >= overlapLimit and comparableSize and (similarEnvelope or similarCenter)

mtfCandidateWins(int candTfSec, int candTime, float candDist, int keepTfSec, int keepTime, float keepDist) =>
    candTfSec > keepTfSec or (candTfSec == keepTfSec and (candDist < keepDist or (candDist == keepDist and candTime > keepTime)))

mtfTfToSec(string tf) =>
    int tfSec = 0
    if str.length(tf) > 0
        tfSec := timeframe.in_seconds(tf)
    tfSec

mtfTfIsUsable(string tf, int chartTfSec, bool requireHigherTf) =>
    int tfSec = mtfTfToSec(tf)
    tfSec > 0 and (not requireHigherTf or tfSec > chartTfSec)

mtfTfIsDuplicate(string tf, string ref1, string ref2, string ref3, string ref4) =>
    str.length(tf) > 0 and (tf == ref1 or tf == ref2 or tf == ref3 or tf == ref4)


tfPrettyFromSec(int tfSec) =>
    string out = ""
    if tfSec > 0
        if tfSec % 86400 == 0
            out := str.tostring(int(tfSec / 86400)) + "D"
        else if tfSec % 3600 == 0
            out := str.tostring(int(tfSec / 3600)) + "H"
        else if tfSec % 60 == 0
            out := str.tostring(int(tfSec / 60)) + "M"
        else
            out := str.tostring(tfSec) + "s"
    out

mtfResolvedTfLabel(string tfLbl, int tfSec) =>
    str.length(str.trim(tfLbl)) > 0 ? str.trim(tfLbl) : tfPrettyFromSec(tfSec)


mtfIsValidZone(float topV, float botV) =>
    not na(topV) and not na(botV) and topV > botV and (topV - botV) >= syminfo.mintick


mtfSrSignalsFull(string method, int len, float atrMult, float breakBufMult) =>
    float atrV = ta.atr(14)
    float phPivot = ta.pivothigh(high, len, len)
    float plPivot = ta.pivotlow(low, len, len)
    float ph = na
    float pl = na
    if method == "Pivots"
        ph := phPivot
        pl := plPivot
    float donchH = ta.highest(high, math.max(1, len))
    float donchL = ta.lowest(low, math.max(1, len))
    float csidH  = ta.highest(high, math.max(1, len))
    float csidL  = ta.lowest(low, math.max(1, len))
    int   csidHB = ta.highestbars(high, math.max(1, len))
    int   csidLB = ta.lowestbars(low, math.max(1, len))

    var int donchOs = 0
    var float donchVal = na
    var int donchTime = na
    var int bullCount = 0
    var int bearCount = 0

    float detPH = na
    float detPL = na
    int   detPHT = na
    int   detPLT = na

    if method == "Pivots"
        if not na(ph)
            detPH := ph
            detPHT := time[len]
        if not na(pl)
            detPL := pl
            detPLT := time[len]
    else if method == "Donchian"
        donchOs := donchH > donchH[1] ? 1 : donchL < donchL[1] ? -1 : donchOs
        if donchOs != donchOs[1]
            if donchOs == 1
                detPL := donchVal
                detPLT := donchTime
                donchVal := high
                donchTime := time
            else
                detPH := donchVal
                detPHT := donchTime
                donchVal := low
                donchTime := time
        else
            if donchOs == 1 and high >= nz(donchVal, -1e10)
                donchVal := high
                donchTime := time
            if donchOs == -1 and low <= nz(donchVal, 1e10)
                donchVal := low
                donchTime := time
    else if method == "CSID"
        bullCount := close > open ? bullCount + 1 : 0
        bearCount := close < open ? bearCount + 1 : 0
        if bullCount == len
            detPH := csidH
            detPHT := time[int(math.abs(csidHB))]
        if bearCount == len
            detPL := csidL
            detPLT := time[int(math.abs(csidLB))]

    int supEvt = 0
    float supTop = na
    float supBot = na
    float supBase = na
    int supTime = na
    int resEvt = 0
    float resTop = na
    float resBot = na
    float resBase = na
    int resTime = na

    if not na(detPL) and not na(detPLT)
        float breakBuf = atrV * breakBufMult
        float zoneDepth = atrV * atrMult
        supEvt := 1
        supTop := detPL + zoneDepth
        supBot := detPL - breakBuf
        supBase := detPL
        supTime := detPLT

    if not na(detPH) and not na(detPHT)
        float breakBuf = atrV * breakBufMult
        float zoneDepth = atrV * atrMult
        resEvt := 1
        resTop := detPH + breakBuf
        resBot := detPH - zoneDepth
        resBase := detPH
        resTime := detPHT

    [supEvt, supTop, supBot, supBase, supTime, resEvt, resTop, resBot, resBase, resTime]

// (mtfSrBundle eliminado — nunca se llamaba)

//══════════════════════════════════════════════════════════════════════════════
// TYPES
//══════════════════════════════════════════════════════════════════════════════
// (type srLevel eliminado — reemplazado por dsrSrLevel en el motor activo)

type dsrSrLevel
    float top
    float btm
    float basePrice
    int   startBar
    int   mitigationBar
    bool  isSupport
    bool  isMitigated
    bool  isUserHidden
    int   entries
    int   strength
    int   sweeps
    float tradedVolume
    line  lineId
    box   boxId
    label statsLabel


