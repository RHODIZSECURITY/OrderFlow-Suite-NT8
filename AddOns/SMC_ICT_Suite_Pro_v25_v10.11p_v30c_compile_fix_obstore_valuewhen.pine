mtfSrSyncedSize() =>
    int sz = array.size(mtf_sr_tops)
    sz := math.min(sz, array.size(mtf_sr_bottoms))
    sz := math.min(sz, array.size(mtf_sr_biases))
    sz := math.min(sz, array.size(mtf_sr_times))
    sz := math.min(sz, array.size(mtf_sr_tfSecs))
    sz := math.min(sz, array.size(mtf_sr_tfLabels))
    sz := math.min(sz, array.size(mtf_sr_startBars))
    sz := math.min(sz, array.size(mtf_sr_basePrices))
    sz := math.min(sz, array.size(mtf_sr_isFlips))
    sz := math.min(sz, array.size(mtf_sr_isMitigated))
    sz := math.min(sz, array.size(mtf_sr_isUserHidden))
    sz := math.min(sz, array.size(mtf_sr_mitTimes))
    sz := math.min(sz, array.size(mtf_sr_entries))
    sz := math.min(sz, array.size(mtf_sr_sweeps))
    sz := math.min(sz, array.size(mtf_sr_tradedVolume))
    sz

mtfObSyncedSize() =>
    int sz = array.size(mtf_ob_tops)
    sz := math.min(sz, array.size(mtf_ob_bottoms))
    sz := math.min(sz, array.size(mtf_ob_biases))
    sz := math.min(sz, array.size(mtf_ob_times))
    sz := math.min(sz, array.size(mtf_ob_tfSecs))
    sz := math.min(sz, array.size(mtf_ob_tfLabels))
    sz := math.min(sz, array.size(mtf_ob_vols))
    sz

int fvg_eff_maxCount         = fvg_maxCount
int ob_maxSwing_live        = ob_maxSwing_input
int ob_maxInternal_live     = ob_maxInternal_input
